{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/workspace-plugin",
    "declaration": true,
    "types": ["node"],
    "composite": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*.ts", "src/**/*.json"],
  "exclude": [
    "jest.config.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "src/**/files/**"
  ],
  "references": [
    {
      "path": "../../packages/nx/tsconfig.lib.json"
    },
    {
      "path": "../../packages/js/tsconfig.lib.json"
    },
    {
      "path": "../../packages/plugin/tsconfig.lib.json"
    },
    {
      "path": "../../packages/eslint/tsconfig.lib.json"
    },
    {
      "path": "../../packages/devkit/tsconfig.lib.json"
    }
  ]
}

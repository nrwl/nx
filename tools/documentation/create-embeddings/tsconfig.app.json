{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "out-tsc",
    "tsBuildInfoFile": "out-tsc/tsconfig.app.tsbuildinfo",
    "rootDir": "src",
    "types": ["node"],
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "allowJs": true,
    "composite": false
  },
  "exclude": [
    "out-tsc",
    "jest.config.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts"
  ],
  "include": ["src/**/*.ts", "src/**/*.mts"]
}

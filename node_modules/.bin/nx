#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/Users/jack/projects/nx/node_modules/.pnpm/nx@23.0.0-beta.12/node_modules/nx/node_modules:/Users/jack/projects/nx/node_modules/.pnpm/nx@23.0.0-beta.12/node_modules:/Users/jack/projects/nx/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/Users/jack/projects/nx/node_modules/.pnpm/nx@23.0.0-beta.12/node_modules/nx/node_modules:/Users/jack/projects/nx/node_modules/.pnpm/nx@23.0.0-beta.12/node_modules:/Users/jack/projects/nx/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../.pnpm/nx@23.0.0-beta.12/node_modules/nx/dist/bin/nx.js" "$@"
else
  exec node  "$basedir/../.pnpm/nx@23.0.0-beta.12/node_modules/nx/dist/bin/nx.js" "$@"
fi

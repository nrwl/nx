{
  "compilerOptions": {
    "target": "ES2021",
    "importHelpers": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "types": ["node", "jest"],
    "typeRoots": ["./node_modules/@types", "./node_modules"],
    "lib": ["ES2022"],
    "declaration": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "allowJs": true,
    "composite": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    // TS6 stopgap: suppress deprecated-option errors (moduleResolution node, baseUrl)
    // and pin the pre-TS6 strict default; real option migration deferred to TS7 prep
    "ignoreDeprecations": "6.0",
    "strict": false
  }
}

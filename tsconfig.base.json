{
  "compilerOptions": {
    "target": "ES2021",
    "importHelpers": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "types": ["node", "jest"],
    "typeRoots": ["./node_modules/@types", "./node_modules"],
    "lib": ["ES2022"],
    "declaration": true,
    "resolveJsonModule": true,
    "strict": false,
    "allowJs": true,
    "composite": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  }
}

{
  "name": "nx-dev",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "nx-dev/nx-dev",
  "projectType": "application",
  "targets": {
    "build": {
      "inputs": [
        "{projectRoot}/public/**/*",
        "{projectRoot}/_redirects",
        "{projectRoot}/scripts/build-site.mjs",
        { "env": "NEXT_PUBLIC_ASTRO_URL" },
        { "env": "NX_DEV_URL" },
        { "env": "NEXT_PUBLIC_NO_INDEX" }
      ],
      "outputs": ["{projectRoot}/dist"],
      "command": "node ./scripts/build-site.mjs",
      "options": {
        "cwd": "nx-dev/nx-dev"
      }
    },
    "deploy-build": {
      "dependsOn": ["build"],
      "outputs": ["{projectRoot}/dist"],
      "configurations": {
        "netlify": {}
      }
    }
  },
  "tags": ["scope:nx-dev", "type:app"]
}

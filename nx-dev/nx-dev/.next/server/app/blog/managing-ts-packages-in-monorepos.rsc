xt-center text-4xl font-semibold text-slate-900 dark:text-white","children":"Managing TypeScript Packages in Monorepos"}]}],["$","div",null,{"className":"mx-auto mb-16 w-full max-w-screen-md","children":["$","$Lc",null,{"className":"w-full object-cover md:rounded-md","src":"/documentation/blog/images/articles/bg-managing-typescript-packages.jpg","alt":"Managing TypeScript Packages in Monorepos","width":1400,"height":735}]}]]}],["$","div",null,{"className":"mx-auto max-w-7xl px-4 lg:px-8","data-content-area":true,"children":["$","div",null,{"className":"relative isolate grid grid-cols-1 gap-8 xl:grid-cols-[200px_minmax(0,1fr)_200px]","children":[["$","div",null,{"className":"hidden min-h-full xl:block","children":"$undefined"}],["$","div",null,{"className":"w-full min-w-0 md:mx-auto md:max-w-screen-md","children":["$undefined",["$","div",null,{"data-document":"main","className":"prose prose-lg prose-slate dark:prose-invert w-full max-w-none","children":["$","article",null,{"children":[["$","$Ld",null,{"type":"deepdive","title":"TypeScript Project References Series","expanded":true,"children":[["$","p",null,{"children":"This article is part of the TypeScript Project References series:"}],["$","ul",null,{"children":[["$","li",null,{"children":["$","$Lb",null,{"prefetch":false,"href":"/blog/typescript-project-references","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"Everything You Need to Know About TypeScript Project References","target":"$undefined","rel":"$undefined","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}]}],["$","li",null,{"children":["$","strong",null,{"children":"Managing TypeScript Packages in Monorepos"}]}],["$","li",null,{"children":["$","$Lb",null,{"prefetch":false,"href":"/blog/new-nx-experience-for-typescript-monorepos","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"A new Nx Experience For TypeScript Monorepos and Beyond","target":"$undefined","rel":"$undefined","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}]}]]}]]}],["$","p",null,{"children":"Managing TypeScript packages in a monorepo presents unique challenges. As your monorepo grows, so does the complexity of structuring and resolving dependencies between packages. From using simple relative imports to taking advantage of TypeScript path aliases, project references, and your package manager's workspaces feature, developers have a variety of strategies at their disposal. But which approach is the best fit for you?"}],["$","$Le",null,{"maxDepth":3}],["$","h2",null,{"id":"what-does-it-mean-to-manage-and-share-typescript-code-in-a-monorepo","className":"group scroll-mt-20","children":["What Does it Mean to Manage and Share TypeScript Code in a Monorepo?",["$","$Lb",null,{"aria-hidden":"true","href":"#what-does-it-mean-to-manage-and-share-typescript-code-in-a-monorepo","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":"When you work in a monorepo, the goal is to split logic into separate packages. Why? To create smaller, self-contained, and maintainable units. This approach not only enhances reusability but also helps scale: whether that's scaling teams or optimizing CI pipelines."}],["$","p",null,{"children":["As you split logic into packages, you'll inevitably need to somehow connect them together. At the ",["$","strong",null,{"children":"code level"}],", this is typically expressed through an import statement on the consumer side—whether that's an application using a package or one package depending on another."]}],["$","$Lf",null,{"language":"ts","fileName":"","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"import { something } from '@tsmono/mypackage';\n"}],["$","p",null,{"children":["To have this work we need to be able to resolve the ",["$","code",null,{"children":"@tsmono/mypackage"}]," import to the actual file path. This needs to happen during:"]}],["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Build:"}]," This includes type checking and compilation/transpilation."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Runtime:"}]," This is when the application runs in the browser/on the server."]}]]}],["$","p",null,{"children":["In this article we'll mostly ",["$","strong",null,{"children":"focus on the building part, in particular type checking"}],". In real world applications you'll most often have some sort of bundler in the pipeline where ",["$","code",null,{"children":"tsc"}]," is used for type checking and the actual compilation part is being taken care of by the bundler (e.g. esbuild, Rspack, or Vite)."]}],["$","p",null,{"children":"There are several approaches to connect TypeScript packages in a monorepo, each with its own trade-offs. Let's explore them in detail."}],["$","h2",null,{"id":"using-relative-imports","className":"group scroll-mt-20","children":["Using Relative Imports",["$","$Lb",null,{"aria-hidden":"true","href":"#using-relative-imports","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":["Example: ",["$","$Lb",null,{"prefetch":false,"href":"https://stackblitz.com/github/juristr/ts-monorepo-linking/tree/relative-imports","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"Stackblitz","target":"_blank","rel":"noreferrer","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}]," - ",["$","$Lb",null,{"prefetch":false,"href":"https://github.com/juristr/ts-monorepo-linking/tree/relative-imports","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"Github","target":"_blank","rel":"noreferrer","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}]]}],["$","p",null,{"children":"The simplest approach to connecting packages is using relative imports. Here's an example of the setup:"}],["$","$Lf",null,{"fileName":"","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"└─ .\n   ├─ apps\n   │  └─ myapp\n   │     ├─ src\n   │     │  └─ index.ts\n   │     └─ tsconfig.json\n   ├─ packages\n   │  └─ lib-a\n   │     ├─ src\n   │     │  └─ index.ts\n   │     └─ tsconfig.json\n   └─ tsconfig.base.json\n\n"}],["$","p",null,{"children":"Here's the content of the main TypeScript configuration files:"}],["$","$L10",null,{"labels":["tsconfig.base.json","apps/myapp/tsconfig.json","packages/lib-a/tsconfig.json"],"children":[["$","$L11",null,{"label":"tsconfig.base.json","children":[["$","p",null,{"children":["Starting at the root, the ",["$","code",null,{"children":"tsconfig.base.json"}]," looks as follows. It is meant to set some of the base compilation properties which can then be adjusted further by individual projects in your workspace."]}],["$","$Lf",null,{"language":"json","fileName":"tsconfig.base.json","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"{\n  \"compilerOptions\": {\n    \"target\": \"ES2020\",\n    \"module\": \"NodeNext\",\n    \"strict\": true,\n    \"moduleResolution\": \"NodeNext\",\n    \"baseUrl\": \".\",\n    \"rootDir\": \".\"\n  }\n}\n"}]]}],["$","$L11",null,{"label":"apps/myapp/tsconfig.json","children":[["$","p",null,{"children":["The application extends from the ",["$","code",null,{"children":"tsconfig.base.json"}]," and adds some minor adjustments which are relatively uninteresting for our setup:"]}],["$","$Lf",null,{"language":"json","fileName":"apps/myapp/tsconfig.json","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"{\n  \"extends\": \"../../tsconfig.base.json\",\n  \"compilerOptions\": {\n    \"outDir\": \"../../dist\",\n    \"declaration\": true\n  },\n  \"include\": [\"src/**/*\"]\n}\n"}]]}],["$","$L11",null,{"label":"packages/lib-a/tsconfig.json","children":[["$","p",null,{"children":["Similarly this is the config for our ",["$","code",null,{"children":"lib-a"}]," package. The library package has its own TypeScript configuration:"]}],["$","$Lf",null,{"language":"json","fileName":"packages/lib-a/tsconfig.json","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"{\n  \"extends\": \"../../tsconfig.base.json\",\n  \"compilerOptions\": {\n    \"outDir\": \"../../dist\",\n    \"declaration\": true\n  },\n  \"include\": [\"src/**/*\"]\n}\n"}]]}]]}],["$","p",null,{"children":["With this setup, the main application can consume the library ",["$","strong",null,{"children":"using a relative import"}],":"]}],["$","$Lf",null,{"language":"ts","fileName":"apps/myapp/src/index.ts","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"import { greet } from '../../../packages/lib-a/src/index';\n\nconsole.log(greet('World'));\n"}],["$","p",null,{"children":["We can have some scripts in our main ",["$","code",null,{"children":"package.json"}]," at the workspace root to run our TypeScript code directly, compile it to JavaScript and for performing type checking."]}],["$","$Lf",null,{"language":"json","fileName":"package.json","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"{\n  \"name\": \"ts-monorepo-linking\",\n  \"private\": true,\n  \"devDependencies\": {\n    \"typescript\": \"^5.3.3\",\n    \"tsx\": \"^4.1.0\"\n  },\n  \"scripts\": {\n    \"dev\": \"tsx apps/myapp/src/index.ts\",\n    \"build\": \"tsc -p apps/myapp/tsconfig.json\",\n    \"typecheck\": \"tsc -p apps/myapp/tsconfig.json --noEmit\"\n  }\n}\n"}],["$","h3",null,{"id":"observations-relative-imports","className":"group scroll-mt-20","children":["Observations: Relative Imports",["$","$Lb",null,{"aria-hidden":"true","href":"#observations-relative-imports","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":[["$","strong",null,{"children":"Dependency resolution:"}],["$","br",null,{}],"Relative imports are the simplest way to link packages, but they are fragile. Restructuring your codebase will require updating import paths, which can become unmanageable in larger workspaces."]}],["$","p",null,{"children":[["$","strong",null,{"children":"Modularity:"}],["$","br",null,{}],"This setup enables modularization at the organizational level. Apps and libraries are placed in separate folders, making the workspace easier to navigate. However, from TypeScript's perspective, the entire workspace is treated as a single, unified project. This means there are no strict boundaries between packages at the type-checking level."]}],["$","p",null,{"children":[["$","strong",null,{"children":"Performance:"}],["$","br",null,{}],"Treating the entire workspace as a single TypeScript project generally works for small setups but can become problematic as the workspace grows. Type checking and compilation span the entire repo, which may lead to higher memory usage, slower builds, and sluggish editor responsiveness in larger workspaces."]}],["$","h2",null,{"id":"fixing-relative-imports-with-typescript-path-aliases","className":"group scroll-mt-20","children":["Fixing Relative Imports with TypeScript Path Aliases",["$","$Lb",null,{"aria-hidden":"true","href":"#fixing-relative-imports-with-typescript-path-aliases","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":["Example: ",["$","$Lb",null,{"prefetch":false,"href":"https://stackblitz.com/github/juristr/ts-monorepo-linking/tree/ts-path-aliases","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"Stackblitz","target":"_blank","rel":"noreferrer","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}]," - ",["$","$Lb",null,{"prefetch":false,"href":"https://github.com/juristr/ts-monorepo-linking/tree/ts-path-aliases","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"Github","target":"_blank","rel":"noreferrer","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}]]}],["$","p",null,{"children":["Relative imports are functional but difficult to maintain in larger workspaces. A simple improvement is to use ",["$","strong",null,{"children":"TypeScript path aliases"}],". These allow you to create custom paths for imports, making the codebase easier to navigate and refactor."]}],["$","p",null,{"children":["In the ",["$","code",null,{"children":"tsconfig.base.json"}]," you can define a path alias for the ",["$","code",null,{"children":"lib-a"}]," package:"]}],["$","$Lf",null,{"language":"json","fileName":"tsconfig.base.json","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"{\n  \"compilerOptions\": {\n    ...\n    \"paths\": {\n      \"@ts-monorepo-linking/lib-a\": [\"packages/lib-a/src/index.ts\"]\n    }\n  }\n}\n"}],["$","blockquote",null,{"children":["$","p",null,{"children":["Note you can use whatever name you want for the alias. Choosing ",["$","code",null,{"children":"@ts-monorepo-linking/lib-a"}]," makes it look like an actual import of an external package, thus closer to a structure we want to achieve."]}]}],["$","p",null,{"children":"With this setup, you can simplify the import in your application:"}],["$","$Lf",null,{"language":"ts","fileName":"apps/myapp/src/index.ts","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"import { greet } from '@ts-monorepo-linking/lib-a';\n\nconsole.log(greet('World'));\n"}],["$","h3",null,{"id":"observations-typescript-path-aliases","className":"group scroll-mt-20","children":["Observations: TypeScript Path Aliases",["$","$Lb",null,{"aria-hidden":"true","href":"#observations-typescript-path-aliases","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":[["$","strong",null,{"children":"Dependency resolution:"}],["$","br",null,{}],"Path aliases eliminate the need for relative imports, resulting in a cleaner and more maintainable structure. If the underlying paths change, you only need to update the alias in ",["$","code",null,{"children":"tsconfig.base.json"}],"."]}],["$","blockquote",null,{"children":["$","p",null,{"children":"As a side note: While this article focuses on the build and type-checking phase, it's worth noting that running the transpiled TypeScript code directly wouldn't work out of the box. This is because TypeScript path aliases are purely a compile-time construct—they don't exist in the output JavaScript. To run the application, you'd need a runtime plugin or bundler (like Webpack, esbuild, or Vite) that can resolve these aliases to actual file paths."}]}],["$","p",null,{"children":[["$","strong",null,{"children":"Modularity:"}],["$","br",null,{}],"This approach doesn't change the modularity from the relative imports setup. TypeScript still treats the entire workspace as one large project, without enforcing strict boundaries between packages."]}],["$","p",null,{"children":[["$","strong",null,{"children":"Performance:"}],["$","br",null,{}],"Path aliases don't improve performance compared to relative imports. The entire workspace is still treated as a single TypeScript project, so type checking and compilation remain unchanged. This approach focuses on maintainability and readability rather than optimizing performance."]}],["$","h2",null,{"id":"improving-performance-with-project-references","className":"group scroll-mt-20","children":["Improving Performance with Project References",["$","$Lb",null,{"aria-hidden":"true","href":"#improving-performance-with-project-references","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":["Example: ",["$","$Lb",null,{"prefetch":false,"href":"https://stackblitz.com/github/juristr/ts-monorepo-linking/tree/ts-proj-references-simple","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"Stackblitz","target":"_blank","rel":"noreferrer","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}]," - ",["$","$Lb",null,{"prefetch":false,"href":"https://github.com/juristr/ts-monorepo-linking/tree/ts-proj-references-simple","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"Github","target":"_blank","rel":"noreferrer","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}]]}],["$","p",null,{"children":"TypeScript project references let you break a large TypeScript project into smaller, manageable units. This approach aligns with monorepo structures, allowing each package to act as its own TypeScript program while maintaining relationships between them."}],["$","p",null,{"children":"To use project references:"}],["$","ul",null,{"children":[["$","li",null,{"children":["Add the ",["$","code",null,{"children":"references"}]," property in ",["$","code",null,{"children":"tsconfig.json"}]," files to point to dependent projects."]}],["$","li",null,{"children":["Enable ",["$","code",null,{"children":"composite: true"}]," in ",["$","code",null,{"children":"compilerOptions"}]," (this also enables ",["$","code",null,{"children":"incremental"}]," and ",["$","code",null,{"children":"declaration"}]," by default)."]}],["$","li",null,{"children":["Use ",["$","code",null,{"children":"tsc --build"}]," (",["$","code",null,{"children":"tsc -b"}],") for compilation and type checking."]}]]}],["$","blockquote",null,{"children":["$","p",null,{"children":["For a more deep-dive on TypeScript project references, make sure to check out our article on ",["$","$Lb",null,{"prefetch":false,"href":"/blog/typescript-project-references","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"\"Everything You Need to Know About TypeScript Project References\"","target":"$undefined","rel":"$undefined","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}],"."]}]}],["$","p",null,{"children":["Our workspace structure still remains the same with the exception of adding another root-level ",["$","code",null,{"children":"tsconfig.json"}],":"]}],["$","$Lf",null,{"fileName":"","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"ts-monorepo-linking\n   ├─ apps\n   │  └─ myapp\n   │     ├─ src\n   │     │  └─ index.ts\n   │     └─ tsconfig.json\n   ├─ packages\n   │  └─ lib-a\n   │     ├─ src\n   │     │  └─ index.ts\n   │     └─ tsconfig.json\n   ├─ tsconfig.base.json\n   └─ tsconfig.json\n"}],["$","p",null,{"children":["This new ",["$","code",null,{"children":"tsconfig.json"}]," is the entry point for TypeScript project references, pointing to all individual TypeScript configs of the projects that are part of the monorepo workspace."]}],["$","$Lf",null,{"language":"json","fileName":"tsconfig.json","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"{\n  \"files\": [],\n  \"references\": [{ \"path\": \"./packages/lib-a\" }, { \"path\": \"./apps/myapp\" }]\n}\n"}],["$","p",null,{"children":["This is distinct from ",["$","code",null,{"children":"tsconfig.base.json"}],", which is used to share common configurations across the workspace:"]}],["$","$Lf",null,{"language":"diff","fileName":"tsconfig.base.json","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"{\n  \"compilerOptions\": {\n    \"target\": \"ES2020\",\n    \"module\": \"NodeNext\",\n    \"strict\": true,\n    \"moduleResolution\": \"NodeNext\",\n    \"composite\": true,\n    \"declaration\": true,\n    \"declarationMap\": true,\n    \"sourceMap\": true,\n    \"paths\": {\n      \"@ts-monorepo-linking/lib-a\": [\"packages/lib-a/src/index.ts\"]\n    }\n  }\n}\n"}],["$","p",null,{"children":["Note that in the ",["$","code",null,{"children":"tsconfig.base.json"}]," we removed the ",["$","code",null,{"children":"rootDir"}]," from our TypeScript configuration (compared to the pure TypeScript path aliases setup). The reason is that we no longer treat the entire workspace as a single TypeScript project. Instead, each project's ",["$","code",null,{"children":"tsconfig.json"}]," forms its own TypeScript root and will be processed by TypeScript's project references individually."]}],["$","p",null,{"children":["The ",["$","code",null,{"children":"myapp"}]," and ",["$","code",null,{"children":"lib-a"}]," configurations look as follows:"]}],["$","$L10",null,{"labels":["apps/myapp/tsconfig.json","lib-a TSConfig"],"children":[["$","$L11",null,{"label":"apps/myapp/tsconfig.json","children":["$","$Lf",null,{"language":"json","fileName":"apps/myapp/tsconfig.json","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"{\n  \"extends\": \"../../tsconfig.base.json\",\n  \"compilerOptions\": {\n    \"outDir\": \"../../dist/apps/myapp\",\n    \"rootDir\": \"src\",\n    \"tsBuildInfoFile\": \"../../dist/apps/myapp/tsconfig.tsbuildinfo\"\n  },\n  \"references\": [{ \"path\": \"../../packages/lib-a\" }],\n  \"include\": [\"src/**/*\"]\n}\n"}]}],["$","$L11",null,{"label":"lib-a TSConfig","children":["$","$Lf",null,{"language":"json","fileName":"packages/lib-a/tsconfig.json","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"{\n  \"extends\": \"../../tsconfig.base.json\",\n  \"compilerOptions\": {\n    \"outDir\": \"../../dist/packages/lib-a\",\n    \"rootDir\": \"src\",\n    \"tsBuildInfoFile\": \"../../dist/packages/lib-a/tsconfig.tsbuildinfo\"\n  },\n  \"include\": [\"src/**/*\"]\n}\n"}]}]]}],["$","p",null,{"children":["Changing the configuration alone isn't enough. If you continue using ",["$","code",null,{"children":"tsc"}]," (or ",["$","code",null,{"children":"tsc -p"}],"), TypeScript will ignore your project references and treat the workspace as a single large project. To fully leverage project references, you must switch to using the ",["$","code",null,{"children":"--build"}]," (",["$","code",null,{"children":"-b"}],") flag with ",["$","code",null,{"children":"tsc"}],". This mode enables TypeScript to process each project individually, respecting dependencies defined in the references property."]}],["$","$Lf",null,{"language":"json","fileName":"package.json","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"{\n  \"name\": \"ts-monorepo-linking\",\n  ...\n  \"scripts\": {\n    \"dev\": \"tsx --tsconfig tsconfig.base.json apps/myapp/src/index.ts\",\n    \"build\": \"tsc --build\",\n    \"clean\": \"tsc --build --clean\",\n    \"typecheck\": \"tsc --build --emitDeclarationOnly\"\n  }\n}\n"}],["$","blockquote",null,{"children":["$","p",null,{"children":["Note: ",["$","code",null,{"children":"--noEmit"}]," is not compatible with the ",["$","code",null,{"children":"--build"}]," flag. Use ",["$","code",null,{"children":"--emitDeclarationOnly"}],"."]}]}],["$","h3",null,{"id":"observations-project-references","className":"group scroll-mt-20","children":["Observations: Project References",["$","$Lb",null,{"aria-hidden":"true","href":"#observations-project-references","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":[["$","strong",null,{"children":"Dependency resolution:"}],["$","br",null,{}],"Imports remain the same, relying on TypeScript path aliases to resolve dependencies. Project references don't change how TypeScript resolves paths; they focus on modularizing type checking and compilation."]}],["$","p",null,{"children":[["$","strong",null,{"children":"Modularity:"}],["$","br",null,{}],"Project references create stronger boundaries by treating each package as an independent TypeScript program. This enforces better isolation and ensures dependencies are type-checked at the package level."]}],["$","p",null,{"children":[["$","strong",null,{"children":"Performance:"}],["$","br",null,{}],"This approach introduces incremental builds, where only modified packages are recompiled. TypeScript generates ",["$","code",null,{"children":".tsbuildinfo"}]," files to track changes, reducing memory usage and speeding up type checking and compilation. This is particularly beneficial for large workspaces or CI pipelines."]}],["$","p",null,{"children":"From a TypeScript program structure we now don't have a single TypeScript program, but multiple ones."}],["$","$Lf",null,{"fileName":"","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"ts-monorepo-linking\n   ├─ apps\n   │  └─ myapp\n   │     ├─ src\n   │     └─ tsconfig.json  <<< myapp TS program\n   ├─ packages\n   │  └─ lib-a\n   │     ├─ src\n   │     └─ tsconfig.json  <<< lib-a TS program\n   ├─ tsconfig.base.json\n   └─ tsconfig.json        <<< root-level solution tsconfig\n"}],["$","p",null,{"children":"The incremental nature of project references allows TypeScript to track changes and skip unnecessary recompilation, resulting in:"}],["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Faster builds:"}]," Only projects affected by changes are recompiled, saving time during development and on CI."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Lower memory usage:"}]," Processing smaller, isolated projects is more memory efficient, which is particularly helpful in large workspaces or resource-constrained environments like CI pipelines."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Improved editor performance:"}]," TypeScript's incremental setup ensures quicker type-checking and autocomplete, even in large monorepos."]}]]}],["$","h2",null,{"id":"combining-typescript-project-references-and-package-manager-workspaces","className":"group scroll-mt-20","children":["Combining TypeScript Project References and Package Manager Workspaces",["$","$Lb",null,{"aria-hidden":"true","href":"#combining-typescript-project-references-and-package-manager-workspaces","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":["Example: ",["$","$Lb",null,{"prefetch":false,"href":"https://stackblitz.com/github/juristr/ts-monorepo-linking/tree/workspaces-ts-proj-refs","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"Stackblitz","target":"_blank","rel":"noreferrer","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}]," - ",["$","$Lb",null,{"prefetch":false,"href":"https://github.com/juristr/ts-monorepo-linking/tree/workspaces-ts-proj-refs","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"Github","target":"_blank","rel":"noreferrer","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}]]}],["$","p",null,{"children":"Modern package managers like NPM, PNPM, Yarn, and Bun have a so-called \"workspaces feature\" that allows for a more seamless resolution of local packages that allows for a more seamless resolution of local packages."}],["$","$L10",null,{"labels":["NPM/Yarn/Bun Workspaces","PNPM Workspaces"],"children":[["$","$L11",null,{"label":"NPM/Yarn/Bun Workspaces","children":[["$","p",null,{"children":["For most package managers, you can use the ",["$","code",null,{"children":"workspaces"}]," property in the root ",["$","code",null,{"children":"package.json"}]," to define the packages that are part of the monorepo."]}],["$","$Lf",null,{"language":"json","fileName":"package.json","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"{\n  \"name\": \"ts-monorepo-linking\",\n  ...\n  \"workspaces\": [\n    \"apps/*\",\n    \"packages/*\"\n  ]\n}\n\n"}]]}],["$","$L11",null,{"label":"PNPM Workspaces","children":[["$","p",null,{"children":["PNPM uses a ",["$","code",null,{"children":"pnpm-workspace.yaml"}]," file to define the packages that are part of the monorepo."]}],["$","$Lf",null,{"language":"yaml","fileName":"pnpm-workspace.yaml","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"packages:\n  - 'apps/*'\n  - 'packages/*'\n"}]]}]]}],["$","p",null,{"children":["This approach ",["$","strong",null,{"children":"eliminates the need for TypeScript path aliases for module resolution"}],"."]}],["$","$Lf",null,{"language":"diff","fileName":"tsconfig.base.json","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"{\n  \"compilerOptions\": {\n    \"target\": \"ES2020\",\n    \"module\": \"NodeNext\",\n    \"strict\": true,\n    \"moduleResolution\": \"NodeNext\",\n    \"composite\": true,\n    \"declaration\": true,\n    \"declarationMap\": true,\n    \"sourceMap\": true,\n  }\n}\n"}],["$","p",null,{"children":["Instead, the package manager's workspaces feature makes sure to link the packages properly such that they can be resolved correctly at build and runtime. This doesn't have any impact on our TypeScript project references setup which cares about type checking and resolves dependencies via the ",["$","code",null,{"children":"references"}]," property."]}],["$","blockquote",null,{"children":["$","p",null,{"children":"Note, setting up package resolution with workspaces is the generally recommended approach. More on that later."}]}],["$","p",null,{"children":["In an NPM/Yarn/PNPM workspace packages tend to be more self-contained. As such it is common to have the output directly in a ",["$","code",null,{"children":"dist"}]," folder within the package itself. We also adjust the ",["$","code",null,{"children":"baseUrl"}]," to be at the package root."]}],["$","$L10",null,{"labels":["apps/myapp/tsconfig.json","packages/lib-a/tsconfig.json"],"children":[["$","$L11",null,{"label":"apps/myapp/tsconfig.json","children":["$","$Lf",null,{"language":"json","fileName":"apps/myapp/tsconfig.json","highlightLines":[4,6,7],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"{\n  \"extends\": \"../../tsconfig.base.json\",\n  \"compilerOptions\": {\n    \"outDir\": \"dist\",\n    \"rootDir\": \"src\",\n    \"baseUrl\": \".\",\n    \"tsBuildInfoFile\": \"dist/tsconfig.tsbuildinfo\"\n  },\n  \"references\": [{ \"path\": \"../../packages/lib-a\" }],\n  \"include\": [\"src/**/*\"]\n}\n"}]}],["$","$L11",null,{"label":"packages/lib-a/tsconfig.json","children":["$","$Lf",null,{"language":"json","fileName":"packages/lib-a/tsconfig.json","highlightLines":[4,6,7],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"{\n  \"extends\": \"../../tsconfig.base.json\",\n  \"compilerOptions\": {\n    \"baseUrl\": \".\",\n    \"rootDir\": \"src\",\n    \"outDir\": \"dist\",\n    \"tsBuildInfoFile\": \"dist/tsconfig.tsbuildinfo\"\n  },\n  \"include\": [\"src/**/*\"]\n}\n"}]}]]}],["$","p",null,{"children":["Each package requires to have a ",["$","code",null,{"children":"package.json"}]," that defines the contract for its entry points, types, and dependencies on other packages."]}],["$","p",null,{"children":["Here's our updated ",["$","code",null,{"children":"package.json"}]," for ",["$","code",null,{"children":"lib-a"}],":"]}],["$","$Lf",null,{"language":"json","fileName":"packages/lib-a/package.json","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"{\n  \"name\": \"@ts-monorepo-linking/lib-a\",\n  ...\n  \"type\": \"module\",\n  \"exports\": {\n    \".\": {\n      \"types\": \"./src/index.ts\",\n      \"import\": \"./src/index.ts\",\n      \"default\": \"./src/index.ts\"\n    },\n    \"./package.json\": \"./package.json\"\n  },\n  \"main\": \"./src/index.ts\",\n  \"types\": \"./src/index.ts\",\n  \"module\": \"./src/index.ts\"\n}\n"}],["$","p",null,{"children":["Note how it directly exports the ",["$","code",null,{"children":"index.ts"}]," file, eliminating the need for pre-compilation. This approach works regardless of whether you use TypeScript project references, as long as the consuming application handles compilation or transpilation. The package manager's workspaces feature makes sure that the packages are properly linked so they can be resolved at runtime (by Node or respective bundler)."]}],["$","h3",null,{"id":"do-i-need-to-reference-dependent-packages-in-the-consuming-packages-packagejson","className":"group scroll-mt-20","children":[["Do I need to reference dependent packages in the consuming package's ",["$","code",null,{"children":"package.json"}],"?"],["$","$Lb",null,{"aria-hidden":"true","href":"#do-i-need-to-reference-dependent-packages-in-the-consuming-packages-packagejson","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":["For NPM workspaces you don't necessarily have to reference dependent packages in the consuming package's ",["$","code",null,{"children":"package.json"}],". Like in our example, ",["$","code",null,{"children":"myapp"}]," has a dependency on ",["$","code",null,{"children":"lib-a"}],", so ",["$","strong",null,{"children":["we could list it in the ",["$","code",null,{"children":"dependencies"}]," section, but we don't have to"]}],":"]}],["$","$Lf",null,{"language":"json","fileName":"apps/myapp/package.json","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"{\n  \"name\": \"@ts-monorepo-linking/myapp\",\n  ...\n  \"dependencies\": {\n    \"@ts-monorepo-linking/lib-a\": \"*\" // optional for NPM workspaces\n  }\n}\n"}],["$","blockquote",null,{"children":["$","p",null,{"children":["The ",["$","code",null,{"children":"*"}]," version specifier tells the package manager to resolve the dependency locally if available."]}]}],["$","p",null,{"children":"There's an exception to this:"}],["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"publishable packages"}],": Clearly, if you want to ",["$","$Lb",null,{"prefetch":false,"href":"/features/manage-releases","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"publish a package","target":"$undefined","rel":"$undefined","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}],", it needs to have all its dependencies listed properly in the ",["$","code",null,{"children":"package.json"}],"."]}],["$","li",null,{"children":[["$","strong",null,{"children":"PNPM workspaces"}],": Due to how PNPM links packages, you need to reference the dependent packages in the consuming package's ",["$","code",null,{"children":"package.json"}],". To avoid having to manually maintain such dependency in every consumer ",["$","code",null,{"children":"package.json"}]," you could resort to declaring such dependencies in the root ",["$","code",null,{"children":"package.json"}]," instead."]}]]}],["$","p",null,{"children":["Also note that ",["$","$Lb",null,{"prefetch":false,"href":"https://pnpm.io/workspaces","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"PNPM","target":"_blank","rel":"noreferrer","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}],", ",["$","$Lb",null,{"prefetch":false,"href":"https://yarnpkg.com/features/workspaces","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"Yarn v2+","target":"_blank","rel":"noreferrer","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}]," and ",["$","$Lb",null,{"prefetch":false,"href":"https://bun.sh/docs/install/workspaces","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"Bun","target":"_blank","rel":"noreferrer","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}]," support a dedicated \"Workspaces Protocol\" allowing you to prefix local dependencies with ",["$","code",null,{"children":"workspace:"}],". This makes it more evident that the dependency is resolved locally. For example:"]}],["$","$Lf",null,{"language":"json","fileName":"apps/myapp/package.json","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"{\n  \"name\": \"@ts-monorepo-linking/myapp\",\n  ...\n  \"dependencies\": {\n    \"@ts-monorepo-linking/lib-a\": \"workspace:*\"\n  }\n}\n"}],["$","h3",null,{"id":"observations-workspaces-and-project-references","className":"group scroll-mt-20","children":["Observations: Workspaces and Project References",["$","$Lb",null,{"aria-hidden":"true","href":"#observations-workspaces-and-project-references","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":[["$","strong",null,{"children":"Dependency resolution:"}],["$","br",null,{}],"With workspaces we delegate the package resolution to the package manager, making it independent of TypeScript. Unlike the previous solution with TypeScript path aliases, this approach works seamlessly at runtime since the package resolution is handled natively by Node.js or the package manager. This makes the setup more robust and platform-aligned."]}],["$","p",null,{"children":[["$","strong",null,{"children":"Modularity:"}],["$","br",null,{}],"Each package's ",["$","code",null,{"children":"package.json"}]," defines its public API and dependencies, making the structure explicit and easy to understand. One important detail is that in our example the ",["$","code",null,{"children":"package.json"}]," directly exports TypeScript files, making the consumer responsible for transpilation and bundling. As a result, these libraries are primarily intended for local use within the monorepo workspace."]}],["$","p",null,{"children":[["$","strong",null,{"children":"Performance:"}],["$","br",null,{}],"Compared to previous solutions, performance remains largely the same in this setup. The TypeScript project references still handle incremental type checking and compilation, which guarantees performance improvements. Package resolution is handled by the package manager's workspaces feature and Node itself, so it doesn't impact TypeScript's performance."]}],["$","h2",null,{"id":"using-typescript-project-references-workspaces-and-prebuilding-packages","className":"group scroll-mt-20","children":["Using TypeScript Project References, Workspaces and Pre-building Packages",["$","$Lb",null,{"aria-hidden":"true","href":"#using-typescript-project-references-workspaces-and-prebuilding-packages","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":["Example: ",["$","$Lb",null,{"prefetch":false,"href":"https://stackblitz.com/github/juristr/ts-monorepo-linking/tree/workspaces-ts-proj-refs-precompiled","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"Stackblitz","target":"_blank","rel":"noreferrer","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}]," - ",["$","$Lb",null,{"prefetch":false,"href":"https://github.com/juristr/ts-monorepo-linking/tree/workspaces-ts-proj-refs-precompiled","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"Github","target":"_blank","rel":"noreferrer","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}]]}],["$","p",null,{"children":["In the previous setup, the ",["$","code",null,{"children":"lib-a"}]," package directly exported TypeScript files through its ",["$","code",null,{"children":"package.json"}],":"]}],["$","$Lf",null,{"language":"json","fileName":"packages/lib-a/package.json","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"{\n  \"name\": \"@ts-monorepo-linking/lib-a\",\n  ...\n  \"type\": \"module\",\n  \"exports\": {\n    \".\": {\n      \"types\": \"./src/index.ts\",\n      \"import\": \"./src/index.ts\",\n      \"default\": \"./src/index.ts\"\n    },\n    \"./package.json\": \"./package.json\"\n  },\n  \"main\": \"./src/index.ts\",\n  \"types\": \"./src/index.ts\"\n}\n"}],["$","p",null,{"children":"This configuration works well for local monorepo use cases but delegates the responsibility of bundling to the consumer. To avoid that, you can pre-compile the package. You'll need to:"}],["$","ul",null,{"children":[["$","li",null,{"children":["Adjust our ",["$","code",null,{"children":"lib-a"}],"'s ",["$","code",null,{"children":"package.json"}]," to point to the compiled artifacts in ",["$","code",null,{"children":"dist"}],"."]}],["$","li",null,{"children":"Setting up a pre-compilation step."}],["$","li",null,{"children":"Ensure all projects are compiled in the correct order based on their dependencies."}]]}],["$","p",null,{"children":["In our simple setup, the TypeScript project references already establish a dependency graph. Running ",["$","code",null,{"children":"tsc --build"}]," from the root of the workspace ensures that projects are compiled in the correct order based on their dependencies."]}],["$","blockquote",null,{"children":["$","p",null,{"children":["In a more complex setup you might need to rely on additional tooling such as Nx that has ",["$","$Lb",null,{"prefetch":false,"href":"/concepts/task-pipeline-configuration","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"a task pipelines functionality","target":"$undefined","rel":"$undefined","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}]," built-in."]}]}],["$","p",null,{"children":["The resulting structure of the ",["$","code",null,{"children":"dist"}]," folder looks like this: (notice the ",["$","code",null,{"children":"*.js"}]," and ",["$","code",null,{"children":"*.d.ts"}]," files)"]}],["$","$Lf",null,{"fileName":"","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"ts-monorepo-linking\n   ├─ apps\n   │  └─ myapp\n   │     ├─ ...\n   │     ├─ package.json\n   │     └─ tsconfig.json\n   ├─ package.json\n   ├─ packages\n   │  └─ lib-a\n   │     ├─ dist\n   │     │  ├─ index.d.ts\n   │     │  ├─ index.d.ts.map\n   │     │  ├─ index.js\n   │     │  ├─ index.js.map\n   │     │  └─ tsconfig.tsbuildinfo\n   │     ├─ package.json\n   │     ├─ src\n   │     │  └─ index.ts\n   │     └─ tsconfig.json\n   ├─ tsconfig.base.json\n   └─ tsconfig.json\n"}],["$","p",null,{"children":["To make the compiled ",["$","code",null,{"children":"lib-a"}]," usable for other packages, we need to update its ",["$","code",null,{"children":"package.json"}]," to point to the compiled artifacts in ",["$","code",null,{"children":"dist"}],". Here's the updated version:"]}],["$","$Lf",null,{"language":"json","fileName":"packages/lib-a/package.json","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"{\n  \"name\": \"@ts-monorepo-linking/lib-a\",\n  \"version\": \"0.0.0\",\n  \"private\": true,\n  \"type\": \"module\",\n  \"exports\": {\n    \".\": {\n      \"types\": \"./dist/index.d.ts\",\n      \"import\": \"./dist/index.js\",\n      \"default\": \"./dist/index.js\"\n    },\n    \"./package.json\": \"./package.json\"\n  },\n  \"main\": \"./dist/index.js\",\n  \"types\": \"./dist/index.d.ts\",\n  \"module\": \"./dist/index.js\"\n}\n"}],["$","h3",null,{"id":"observations-prebuilding-packages","className":"group scroll-mt-20","children":["Observations: Pre-building Packages",["$","$Lb",null,{"aria-hidden":"true","href":"#observations-prebuilding-packages","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":[["$","strong",null,{"children":"Dependency resolution:"}],["$","br",null,{}],"Precompiling dependent packages allows the application bundler to rely on prebuilt outputs, avoiding the need to compile package dependencies during application bundling. A ",["$","$Lb",null,{"prefetch":false,"href":"/concepts/task-pipeline-configuration","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"task pipeline","target":"$undefined","rel":"$undefined","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}]," ensures that packages are compiled beforehand, streamlining the workflow."]}],["$","p",null,{"children":[["$","strong",null,{"children":"Modularity:"}],["$","br",null,{}],"Compared to the previous approach of directly referencing TypeScript source files, this setup slightly increases modularity. Each package is now self-contained, with its compiled outputs and defined entry points in the ",["$","code",null,{"children":"package.json"}],". By precompiling and packaging the library, it can be distributed outside the monorepo if needed, which enhances its modularity and reusability. However, the primary focus remains internal use within the monorepo."]}],["$","p",null,{"children":[["$","strong",null,{"children":"Performance:"}],["$","br",null,{}],"This setup can slightly improve type-checking performance, especially within code editors. Since the type information is already generated as ",["$","code",null,{"children":".d.ts"}]," files during precompilation, the editor can directly rely on these instead of processing TypeScript source files through project references. While cached project references can achieve similar speeds, precompiled declaration files might potentially reduce some overhead."]}],["$","h2",null,{"id":"which-one-should-i-choose","className":"group scroll-mt-20","children":["Which One Should I Choose?",["$","$Lb",null,{"aria-hidden":"true","href":"#which-one-should-i-choose","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":"Here are some thoughts on which approach to use."}],["$","p",null,{"children":["$","strong",null,{"children":"TypeScript Path Aliases: A Simple Option"}]}],["$","p",null,{"children":["TypeScript path aliases have been a reliable way to manage package resolution, particularly before package managers introduced the workspaces feature. They're straightforward to set up, requiring only a global ",["$","code",null,{"children":"tsconfig.json"}]," without additional. However, there are limitations to consider as they require additional bundling support/alias resolvers at runtime and might come with some performance degradation in large workspaces."]}],["$","$Ld",null,{"type":"deepdive","title":"Isn't Nx using TS Path Aliases?","expanded":false,"children":[["$","p",null,{"children":["Yes and no. Nx has been around since before package managers introduced workspaces. As a result, the default setup in Nx traditionally leveraged a root-level ",["$","code",null,{"children":"tsconfig.base.json"}]," containing path aliases to link packages within the monorepo."]}],["$","p",null,{"children":["That said, Nx can also be used in combination with NPM/Yarn/PNPM/Bun workspaces, as ",["$","$Lb",null,{"prefetch":false,"href":"/recipes/adopting-nx/adding-to-monorepo","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"shown here","target":"$undefined","rel":"$undefined","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}],". This led to two distinct setups for monorepos with Nx: one using TypeScript path aliases and the other leveraging workspaces. To address the confusion this created, the Nx team has spent the last year enhancing Nx to unify these approaches. The goal is to align with \"the platform\" by adopting and promoting package manager workspaces, while updating Nx plugins to fully support it, preserving the developer experience (DX) benefits Nx users have come to love."]}],["$","p",null,{"children":"If you're currently using the TypeScript path aliases approach, there's no need to worry. The Nx team is working on comprehensive documentation and semi-automated tools to help with migration. Additionally, it's possible to migrate manually and even incrementally, allowing you to adopt the workspaces at your own pace."}]]}],["$","p",null,{"children":["$","strong",null,{"children":"Workspaces: The Recommended Approach"}]}],["$","p",null,{"children":"With widespread support in modern package managers (NPM, PNPM, Yarn, Bun), the workspaces feature has become the preferred method for managing package resolution. It aligns closely with the Node.js platform, leveraging native package resolution mechanisms that also work at runtime. This eliminates the portability issues inherent to TypeScript path aliases."}],["$","p",null,{"children":["When combined with ",["$","strong",null,{"children":"TypeScript project references"}],", this method becomes even more powerful. Workspaces handles package linking such that Node can resolve them properly, while TypeScript project references optimize type-checking and enable incremental builds (for TypeScript). Together, they improve performance, reduce memory usage, and simplify dependency management in larger workspaces. This combination is the recommended way to structure and manage TypeScript packages in a monorepo."]}],["$","p",null,{"children":["$","strong",null,{"children":"To Prebuild or Not to Prebuild?"}]}],["$","p",null,{"children":"Prebuilding packages isn't always necessary. Modern bundlers like Vite and Rspack are optimized for speed, often making in-place compilation sufficient. Some things to consider:"}],["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Cost of Prebuilding:"}]," Precompiling packages introduces a small overhead, as each package must be built individually. Tools like Nx mitigate this cost with ",["$","$Lb",null,{"prefetch":false,"href":"/features/cache-task-results","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"computation caching","target":"$undefined","rel":"$undefined","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}],", allowing you to skip redundant builds. If cache results are available, builds can be significantly faster."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Selective Prebuilding:"}]," Prebuilding doesn't have to be applied universally. You can start without prebuilding and add it for specific subsets of your projects, such as the leaf nodes in your monorepo's project graph."]}],["$","li",null,{"children":[["$","strong",null,{"children":"External Publishing:"}]," Prebuilding is essential if your packages need to be published outside the monorepo with tools like ",["$","$Lb",null,{"prefetch":false,"href":"/features/manage-releases","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"Nx release","target":"$undefined","rel":"$undefined","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}],"."]}]]}],["$","h2",null,{"id":"are-there-any-downsides-to-typescript-project-references","className":"group scroll-mt-20","children":["Are There Any Downsides to TypeScript Project References?",["$","$Lb",null,{"aria-hidden":"true","href":"#are-there-any-downsides-to-typescript-project-references","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":["While TypeScript project references offer significant benefits, they can be maintenance-heavy, especially in large workspaces where their incremental type-checking capabilities are most valuable. The challenge lies in keeping the references array in each ",["$","code",null,{"children":"tsconfig.json"}]," file up to date, ensuring all project dependencies are correctly linked."]}],["$","p",null,{"children":"This is where Nx comes in, eliminating much of the manual effort involved in maintaining TypeScript project references:"}],["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Automated Setup with Generators:"}]," Nx provides generators for scaffolding applications and library packages. These generators handle the ",["$","code",null,{"children":"tsconfig.json"}]," setup automatically, ensuring that TypeScript project references are correctly configured from the start."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Automatic Synchronization:"}]," Nx includes a ",["$","$Lb",null,{"prefetch":false,"href":"/concepts/sync-generators","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"sync command","target":"$undefined","rel":"$undefined","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}]," that is automatically triggered before critical operations like building or serving a project. This command verifies whether the TypeScript project references are in sync across the workspace. If discrepancies are found, Nx automatically updates the references arrays, keeping your configuration consistent and accurate without manual intervention."]}]]}],["$","h2",null,{"id":"wrapping-up","className":"group scroll-mt-20","children":["Wrapping Up",["$","$Lb",null,{"aria-hidden":"true","href":"#wrapping-up","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":"We've explored various strategies for configuring TypeScript-based packages in a monorepo, starting with relative imports, moving to TS path aliases, and finally leveraging the workspaces in combination with TypeScript project references."}],["$","p",null,{"children":["If you want to try these approaches, check out the companion GitHub repository at ",["$","$Lb",null,{"prefetch":false,"href":"https://github.com/juristr/ts-monorepo-linking","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"https://github.com/juristr/ts-monorepo-linking","target":"_blank","rel":"noreferrer","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}],", or create a new workspace with Nx:"]}],["$","$Lf",null,{"language":"shell","fileName":"","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"npx create-nx-workspace mymonorepo --workspaces\n"}],["$","blockquote",null,{"children":["$","p",null,{"children":["Note ",["$","code",null,{"children":"--workspaces"}]," is a temporary flag to instruct Nx to generate a workspaces based monorepo setup."]}]}],["$","p",null,{"children":"Also check out our docs:"}],["$","ul",null,{"children":[["$","li",null,{"children":["$","$Lb",null,{"prefetch":false,"href":"/concepts/typescript-project-linking","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"TypeScript Project Linking","target":"$undefined","rel":"$undefined","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}]}],["$","li",null,{"children":["$","$Lb",null,{"prefetch":false,"href":"/recipes/tips-n-tricks/switch-to-workspaces-project-references","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"Switching to Workspaces and Project References","target":"$undefined","rel":"$undefined","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}]}]]}],["$","hr",nul
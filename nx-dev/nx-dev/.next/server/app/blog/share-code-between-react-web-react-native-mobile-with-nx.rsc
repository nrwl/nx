 code more re-usable we could slightly refactor the creation of the root reducer with ",["$","$Lb",null,{"prefetch":false,"href":"https://github.com/supasate/connected-react-router","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"connected-react-router","target":"_blank","rel":"noreferrer","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}],", such that it takes the ",["$","code",null,{"children":"history"}]," object as an argument:"]}],["$","$Ld",null,{"language":"typescript","fileName":"","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"import { combineReducers } from '@reduxjs/toolkit';\nimport { connectRouter } from 'connected-react-router';\nimport { History } from 'history';\nimport { filmsSlice } from '../films/films.slice';\nimport { peopleSlice } from '../people/people.slice';\nimport { searchSlice } from '../search/search.slice';\nimport { RootState } from './root-state.interface';\nexport const createRootReducer = (history: History) =>\n  combineReducers<RootState>({\n    films: filmsSlice.reducer,\n    router: connectRouter(history) as any,\n    search: searchSlice.reducer,\n    people: peopleSlice.reducer,\n  });\n"}],["$","h3",null,{"id":"query-parameters","className":"group scroll-mt-20","children":["Query Parameters",["$","$Lb",null,{"aria-hidden":"true","href":"#query-parameters","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":["When you develop on the web, the easiest way to pass ahead state or information, in general, is to leverage the URL query parameters. In our search app example, we can simply have something like ",["$","code",null,{"children":"?search=searchText"}],"."]}],["$","p",null,{"children":["We can use ",["$","$Lb",null,{"prefetch":false,"href":"https://v5.reactrouter.com/web/guides/quick-start","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"react-router-dom","target":"_blank","rel":"noreferrer","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}]," to push a new history entry."]}],["$","$Ld",null,{"language":"typescript","fileName":"","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"import { useHistory } from 'react-router-dom';\nconst history = useHistory();\nconst submitSearchForm = (text: string) => {\n  history.push(`${AppRoutes.results}?search=${text}`);\n};\n"}],["$","p",null,{"children":["To read and parse the current query parameter ",["$","code",null,{"children":"search"}],":"]}],["$","$Ld",null,{"language":"typescript","fileName":"","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"import { useLocation } from 'react-router-dom';\nconst params = new URLSearchParams(useLocation().search);\nconst searchParam = params.get('search');\n"}],["$","p",null,{"children":["Although the mobile app URLs are not visible, we can still pass parameters. Note that we have to use a different package ",["$","code",null,{"children":"@react-navigation/native"}]," though."]}],["$","$Ld",null,{"language":"typescript","fileName":"","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"import { useNavigation } from '@react-navigation/native';\nconst navigation = useNavigation();\nconst submitSearchForm = () => {\n  navigation.navigate(AppRoutes.results, { search: text });\n};\n"}],["$","p",null,{"children":"To read and parse the parameter:"}],["$","$Ld",null,{"language":"typescript","fileName":"","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"import { RouteProp, useRoute } from '@react-navigation/native';\nconst route = useRoute<RouteProp<{ params: { search: string } }>>();\nconst searchParam = route.params?.search;\n"}],["$","p",null,{"children":["To type checking with typescript for react-navigation, we need to create a type ",["$","code",null,{"children":"RootStackParamList"}]," for mappings of route name to the params of the route:"]}],["$","$Ld",null,{"language":"typescript","fileName":"","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"export type RootStackParamList = {\n  [AppRoutes.search]: undefined;\n  [AppRoutes.results]: { search: string };\n};\n"}],["$","p",null,{"children":"We also need to specify a global type for your root navigator:"}],["$","$Ld",null,{"language":"typescript","fileName":"","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"declare global {\n  // eslint-disable-next-line @typescript-eslint/no-namespace\n  namespace ReactNavigation {\n    // eslint-disable-next-line @typescript-eslint/no-empty-interface\n    interface RootParamList extends RootStackParamList {}\n  }\n}\n"}],["$","p",null,{"children":["So we create the stack navigator, we need to pass the above ",["$","code",null,{"children":"RootStackParamList"}]," type:"]}],["$","$Ld",null,{"language":"typescript","fileName":"","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"import { createNativeStackNavigator } from '@react-navigation/native-stack';\nconst Stack = createNativeStackNavigator<**RootStackParamList**>();\n"}],["$","h3",null,{"id":"environment-variables","className":"group scroll-mt-20","children":["Environment Variables",["$","$Lb",null,{"aria-hidden":"true","href":"#environment-variables","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":["Nx comes with a set of different options for ",["$","$Lb",null,{"prefetch":false,"href":"/reference/environment-variables","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"handling environment variables","target":"$undefined","rel":"$undefined","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}],". In our workspace, we have a simple ",["$","code",null,{"children":".env"}]," file at the workspace root:"]}],["$","$Ld",null,{"language":"text","fileName":"","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"NX_REQUEST_BASE_URL=://ghibliapi.herokuapp.com\n"}],["$","p",null,{"children":["This works nicely for our React web build, but it doesn't for our React Native application. This is because React Native and React apps use different Javascript bundlers. React Native uses ",["$","$Lb",null,{"prefetch":false,"href":"https://facebook.github.io/metro/","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"Metro","target":"_blank","rel":"noreferrer","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}]," and React uses ",["$","$Lb",null,{"prefetch":false,"href":"https://webpack.js.org/","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"Webpack","target":"_blank","rel":"noreferrer","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}],". Therefore, when we try to access ",["$","code",null,{"children":"process.env.NX_REQUEST_BASE_URL"}],", we get ",["$","code",null,{"children":"undefined"}],"."]}],["$","p",null,{"children":["To solve this, we can use the ",["$","$Lb",null,{"prefetch":false,"href":"https://github.com/luggit/react-native-config","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"react-native-config","target":"_blank","rel":"noreferrer","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}]," library"]}],["$","$Ld",null,{"language":"shell","fileName":"","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"# npm\nnpm install react-native-config --save-dev# yarn\nyarn add react-native-config --dev\n"}],["$","p",null,{"children":["Here's an example of how to set up ",["$","$Lb",null,{"prefetch":false,"href":"https://github.com/luggit/react-native-config","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"react-native-config","target":"_blank","rel":"noreferrer","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}],": ",["$","$Lb",null,{"prefetch":false,"href":"https://github.com/luggit/react-native-config#setup","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"https://github.com/luggit/react-native-config#setup","target":"_blank","rel":"noreferrer","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}],"."]}],["$","p",null,{"children":"After that, we can have a simple utility function to retrieve the environment variables in our app."}],["$","$Ld",null,{"language":"typescript","fileName":"","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"import Config from 'react-native-config';\nexport function getEnv(envName: string) {\n  return process.env[envName] || Config[envName];\n}\n"}],["$","p",null,{"children":["To access the environment variable ",["$","code",null,{"children":"NX_REQUEST_BASE_URL"}],", we can then simply use the above function:",["$","code",null,{"children":"getEnv('NX_REQUEST_BASE_URL')"}],"."]}],["$","h3",null,{"id":"fetch-with-http","className":"group scroll-mt-20","children":["Fetch With HTTP",["$","$Lb",null,{"aria-hidden":"true","href":"#fetch-with-http","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":["On the web, you most probably lean on the ",["$","$Lb",null,{"prefetch":false,"href":"https://developer.mozilla.org/en-US/docs/Web/API/Fetch_API","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"fetch API","target":"_blank","rel":"noreferrer","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}]," to make network requests. On iOS, however, you'll get an error saying: ",["$","code",null,{"children":"TypeError: Network request failed"}],"."]}],["$","p",null,{"children":["It turns out that React Native does not allow HTTP requests by default: ",["$","$Lb",null,{"prefetch":false,"href":"https://stackoverflow.com/questions/38418998/react-native-fetch-network-request-failed","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"https://stackoverflow.com/questions/38418998/react-native-fetch-network-request-failed","target":"_blank","rel":"noreferrer","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}],"."]}],["$","p",null,{"children":["To fix this, for iOS, open ",["$","code",null,{"children":"apps/studio-ghibli-search-engine-mobile/ios/StudioGhibliSearchEngineApp/Info.plist"}]," and add the request URL to ",["$","code",null,{"children":"NSExceptionDomains"}]," under ",["$","code",null,{"children":"NSAppTransportSecurity"}],":"]}],["$","$Ld",null,{"language":"xml","fileName":"","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"<key>NSAppTransportSecurity</key>\n <dict>\n  <key>NSExceptionDomains</key>\n  <dict>\n   <key>localhost</key>\n   <dict>\n    <key>NSExceptionAllowsInsecureHTTPLoads</key>\n    <true/>\n   </dict>\n   <key>ghibliapi.herokuapp.com</key>\n   <dict>\n    <key>NSExceptionAllowsInsecureHTTPLoads</key>\n    <true/>\n   </dict>\n  </dict>\n </dict>\n"}],["$","p",null,{"children":["Similarly, for Android, open ",["$","code",null,{"children":"apps/studio-ghibli-search-engine-mobile/android/app/src/main/res/xml/network_security_config.xml"}],", and add the request URL to this config file:"]}],["$","$Ld",null,{"language":"xml","fileName":"","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"<?xml version=\"1.0\" encoding=\"utf-8\"?>\n<network-security-config>\n    <domain-config cleartextTrafficPermitted=\"true\">\n        <domain includeSubdomains=\"true\">10.0.2.2</domain>\n        <domain includeSubdomains=\"true\">localhost</domain>\n        <domain includeSubdomains=\"true\">herokuapp.com</domain>\n    </domain-config>\n</network-security-config>\n"}],["$","p",null,{"children":"This should get rid of the network error."}],["$","p",null,{"children":"It seems like there are quite a few customizations that need to be done for React Native apps. However, the majority of non-UI code could be reused."}],["$","h2",null,{"id":"code-that-could-be-shared","className":"group scroll-mt-20","children":["Code that Could be Shared",["$","$Lb",null,{"aria-hidden":"true","href":"#code-that-could-be-shared","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":"All the business logic code that is not UI could be shared. For this example, I got 3 libraries in my monorepo and all of them could be shared:"}],["$","ul",null,{"children":[["$","li",null,{"children":"models: types and interface definitions"}],["$","li",null,{"children":"services: services that interact with API"}],["$","li",null,{"children":"store: redux store"}]]}],["$","p",null,{"children":["With Nx, it requires zero configuration to share the above library code. Even though when I created these libraries for a web app, I used commands like ",["$","code",null,{"children":"nx generate @nrwl/react:lib store"}],", I could still use them directly in my react native mobile app."]}],["$","p",null,{"children":"For example, I need to create a film page to display film details with film id passed in as a parameter:"}],["$","p",null,{"children":[["$","img",null,{"src":"/documentation/blog/images/2022-02-01/zD_5omXSG-hIVHbgpCb-bA.avif","alt":"","loading":"lazy"}]," ",["$","em",null,{"children":"Screenshot of Film Page on Mobile (left: iOS, right: Android)"}]]}],["$","p",null,{"children":"I would do import from the store library directly:"}],["$","$Ld",null,{"language":"typescript","fileName":"","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"import {\n  filmsActions,\n  filmsSelectors,\n  RootState,\n} from '@studio-ghibli-search-engine/store';\n"}],["$","p",null,{"children":"The film component would become:"}],["$","$Ld",null,{"language":"typescript","fileName":"film.props.ts","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"import { AnyAction, ThunkDispatch } from '@reduxjs/toolkit';\nimport {\n  filmsActions,\n  filmsSelectors,\n  RootState,\n} from '@studio-ghibli-search-engine/store';\n\nconst mapStateToProps = (state: RootState) => {\n  return {\n    getFilm: (id: string) => filmsSelectors.selectFilmById(id)(state),\n  };\n};\n\nconst mapDispatchToProps = (\n  dispatch: ThunkDispatch<RootState, void, AnyAction>\n) => {\n  return {\n    fetchFilms() {\n      dispatch(filmsActions.fetchFilms());\n    },\n  };\n};\n\ntype mapStateToPropsType = ReturnType<typeof mapStateToProps>;\ntype mapDispatchToPropsType = ReturnType<typeof mapDispatchToProps>;\n\ntype FilmProps = mapStateToPropsType & mapDispatchToPropsType;\n\nexport { mapStateToProps, mapDispatchToProps };\nexport type { FilmProps };\n"}],["$","$Ld",null,{"language":"tsx","fileName":"film.tsx","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"$e"}],["$","p",null,{"children":["Note I could import from ",["$","code",null,{"children":"@studio-ghibli-search-engine/models"}],", ",["$","code",null,{"children":"@studio-ghibli-search-engine/services"}]," and ",["$","code",null,{"children":"@studio-ghibli-search-engine/store"}]," directly."]}],["$","p",null,{"children":["Now when I run ",["$","code",null,{"children":"nx dep-graph"}],", it shows the dependency graph below where all these 3 libraries are shared between web and mobile:"]}],["$","p",null,{"children":[["$","img",null,{"src":"/documentation/blog/images/2022-02-01/697qjtaGr4mTSnuRq6vpPw.avif","alt":"","loading":"lazy"}]," ",["$","em",null,{"children":"Dependency graph"}]]}],["$","p",null,{"children":"For this example project, to create the mobile app, it took me some time to rewrite the entire UI. However, I do not need to make any changes to the above libraries."}],["$","p",null,{"children":[["$","img",null,{"src":"/documentation/blog/images/2022-02-01/Ldob3R4V50WG4gP-UzKAOg.avif","alt":"","loading":"lazy"}]," ",["$","em",null,{"children":"Screenshots of Mobile App (left: iOS, right: Android)"}]]}],["$","h2",null,{"id":"conclusion","className":"group scroll-mt-20","children":["Conclusion",["$","$Lb",null,{"aria-hidden":"true","href":"#conclusion","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":"In this article, we ended up building both, a React-based web application and a corresponding React Native app in the same repository using Nx."}],["$","p",null,{"children":["Nx's architecture promotes the separation of concerns, splitting things into ",["$","code",null,{"children":"apps"}]," (which are technology-specific) and ",["$","code",null,{"children":"libs"}]," which can be technology-specific or technology-independent. That allows us to easily have our common business logic in a technology-independent library which in turn (thanks to Nx's setup) be easily linked to both, our React web and React Native mobile app."]}],["$","p",null,{"children":"Although there are UI-specific differences we need to account for, that simply comes with one being a web tech stack and the other being a native app, we were still able to share big chunks of the technology-independent business logic of our application. That ultimately helps with maintenance and having feature parity across different platforms."}],["$","p",null,{"children":["$","em",null,{"children":"(Note, the repository with the code for this article is linked at the very top)"}]}]]}]}]]}],["$","div",null,{"className":"hidden xl:block","children":["$","div",null,{"className":"sticky top-24"}]}]]}]}],["$","section",null,{"className":"mt-24 border-b border-t border-slate-200 bg-slate-50 py-24 sm:py-32 dark:border-slate-800 dark:bg-slate-900","children":["$","div",null,{"className":"mx-auto max-w-7xl px-4 sm:px-6 lg:px-8","children":["$","div",null,{"className":"mx-auto max-w-2xl lg:mx-0 lg:max-w-none","children":[["$","h2",null,{"className":"mb-8 flex items-center gap-3 text-2xl font-semibold text-slate-900 dark:text-white","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"h-7 w-7","children":[null,["$","path",null,{"strokeLinecap":"round","st
b/storage';\nconst persistConfig = {\n  key: 'root',\n  storage: storage,\n  whitelist: ['search', 'films', 'people'],\n  transforms: [transformEntityStateToPersist],\n};\n"}],["$","p",null,{"children":["However, for the mobile, we need to install the library ",["$","$Lb",null,{"prefetch":false,"href":"https://github.com/react-native-async-storage/async-storage","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":["$","code",null,{"children":"@react-native-async-storage/async-storage"}],"target":"_blank","rel":"noreferrer","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}],":"]}],["$","$Ld",null,{"language":"shell","fileName":"","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"# npm\nnpm install @react-native-async-storage/async-storage --save-dev# yarn\nyarn add @react-native-async-storage/async-storage --dev\n"}],["$","p",null,{"children":["As a result, the ",["$","code",null,{"children":"persistConfig"}]," passed to persistStore from redux-persist becomes:"]}],["$","$Ld",null,{"language":"typescript","fileName":"","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"import AsyncStorage from '@react-native-async-storage/async-storage';\nconst persistConfig = {\n  key: 'root',\n  storage: AsyncStorage,\n  whitelist: ['search', 'films', 'people'],\n  transforms: [transformEntityStateToPersist],\n};\n"}],["$","h3",null,{"id":"history","className":"group scroll-mt-20","children":["History",["$","$Lb",null,{"aria-hidden":"true","href":"#history","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacit
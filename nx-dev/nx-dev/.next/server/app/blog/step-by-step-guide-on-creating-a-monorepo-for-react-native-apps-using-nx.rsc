n          />\n        </Stack.Navigator>\n      </NavigationContainer>\n    </Provider>\n  );\n};\n\nexport default App;\n"}],["$","p",null,{"children":"If you run the code in the simulator, the app should look similar to before except for the header."}],["$","p",null,{"children":[["$","img",null,{"src":"/documentation/blog/images/2021-10-14/X_A3v107SDFSmYWwBhki1A.avif","alt":"","loading":"lazy"}]," ",["$","em",null,{"children":"Add React Navigation in iOS and Android simulator"}]]}],["$","h3",null,{"id":"create-second-page","className":"group scroll-mt-20","children":["Create Second Page",["$","$Lb",null,{"aria-hidden":"true","href":"#create-second-page","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":["Now you need to create the 2nd page to be navigated. Create a component called ",["$","code",null,{"children":"horoscope-card"}]," under ui:"]}],["$","$Ld",null,{"language":"shell","fileName":"","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"nx generate component horoscope-card --project=ui --export\n"}],["$","p",null,{"children":["This should generate ",["$","code",null,{"children":"libs/ui/src/lib/horoscope-card"}]," folder."]}],["$","p",null,{"children":["Add the below code to ",["$","code",null,{"children":"libs/ui/src/lib/horoscope-card/horoscope-card.tsx"}],". For now, this component is going to use mock static data. It just displays a title for the zodiac Leo. It uses the ",["$","$Lb",null,{"prefetch":false,"href":"https://reactnativeelements.com/docs/card","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"Card","target":"_blank","rel":"noreferrer","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}]," component from React Native Elements."]}],["$","$Ld",null,{"language":"tsx","fileName":"horoscope-card.tsx","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"import { AdhZodiacSign } from '@aztro-daily-horoscope/models';\nimport React from 'react';\nimport { Card, Text } from '@rneui/base';\nimport Icon from 'react-native-vector-icons/MaterialCommunityIcons';\n\n/* eslint-disable-next-line */\nexport interface HoroscopeCardProps {}\n\nexport function HoroscopeCard(props: HoroscopeCardProps) {\n  return (\n    <Card>\n      <Card.Title>\n        <Icon name=\"zodiac-leo\" size={40} />\n      </Card.Title>\n      <Card.Title>{AdhZodiacSign.Leo}</Card.Title>\n      <Card.Divider />\n      <Text h4 style={{ width: '100%', textAlign: 'center' }}>\n        Your Horoscope for Today\n      </Text>\n    </Card>\n  );\n}\n\nexport default HoroscopeCard;\n"}],["$","h3",null,{"id":"navigate-between-screens","className":"group scroll-mt-20","children":["Navigate Between Screens",["$","$Lb",null,{"aria-hidden":"true","href":"#navigate-between-screens","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":["Now you need to add this screen to your app. In file ",["$","code",null,{"children":"apps/daily-horoscope-app/src/app/App.tsx"}],", you need to update it to add a stack screen for the ",["$","code",null,{"children":"horoscope-card"}]," component:"]}],["$","$Ld",null,{"language":"tsx","fileName":"zodiac-sign-list.tsx","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"$10"}],["$","p",null,{"children":"Now you should be able to navigate between 2 screens."}],["$","p",null,{"children":[["$","img",null,{"src":"/documentation/blog/images/2021-10-14/kA79kriH_l3OTWSvB5iQZQ.avif","alt":"","loading":"lazy"}]," ",["$","em",null,{"children":"Navigate between 2 screens"}]]}],["$","h2",null,{"id":"integrate-with-api","className":"group scroll-mt-20","children":["Integrate with API",["$","$Lb",null,{"aria-hidden":"true","href":"#integrate-with-api","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":["Now you need to update",["$","code",null,{"children":"horoscope-card"}]," with real data. This example uses a free and open API: ",["$","$Lb",null,{"prefetch":false,"href":"https://github.com/sameerkumar18/aztro","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"https://github.com/sameerkumar18/aztro","target":"_blank","rel":"noreferrer","className":"text-blue-600 transition-colors ease-ou
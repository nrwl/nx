lity: string;\n  mood: string;\n  color: string;\n  lucky_number: string;\n  lucky_time: string;\n}\n\nexport function transfromAztroHoroscpeResponseToAdhHoroscope(\n  responose: AztroHoroscpeResponse\n): AdhHoroscope {\n  return {\n    currentDate: new Date(responose.current_date),\n    description: responose.description,\n    compatibility: responose.compatibility as AdhZodiacSign,\n    mood: responose.mood,\n    color: responose.color,\n    luckyNumber: parseInt(responose.lucky_number),\n    luckyTime: responose.lucky_time,\n  };\n}\n"}],["$","$Ld",null,{"language":"typescript","fileName":"aztro.service.ts","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"import { AdhHoroscopeDay, AdhZodiacSign } from '@aztro-daily-horoscope/models';\n\nimport { AztroHoroscpeResponse } from './aztro-horoscope-response.interface';\n\nasync function getHoroscope(\n  zodiacSign: AdhZodiacSign,\n  day: AdhHoroscopeDay\n): Promise<AztroHoroscpeResponse> {\n  const response = await fetch(\n    `https://aztro.sameerkumar.website/?sign=${zodiacSign}&day=${day}`\n  );\n  if (response.ok) {\n    return response.json();\n  }\n  throw response;\n}\n\nexport const aztroService = { getHoroscope };\n"}],["$","p",null,{"children":["You also need to add 2 more files to the ",["$","code",null,{"children":"models"}]," library:"]}],["$","ul",null,{"children":[["$","li",null,{"children":[["$","code",null,{"children":"horoscope-day.type.ts"}]," defines the allowed day value to pass to API."]}],["$","li",null,{"children":[["$","code",null,{"children":"horoscope.interface.ts"}]," is the app domain interface that is transformed from the API response data."]}]]}],["$","$Ld",null,{"language":"typescript","fileName":"horoscope-day.type.ts","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"export type AdhHoroscopeDay = 'today' | 'tomorrow' | 'yesterday';\n"}],["$","$Ld",null,{"language":"typescript","fileName":"horoscope.interface.ts","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"import { AdhZodiacSign } from './zodiac-sign.enum';\n\nexport interface AdhHoroscope {\n  currentDate: Date;\n  description: string;\n  compatibility: AdhZodiacSign;\n  mood: string;\n  color: string;\n  luckyNumber: number;\n  luckyTime: string;\n}\n"}],["$","h3",null,{"id":"connect-to-redux","className":"group scroll-mt-20","children":["Connect to Redux",["$","$Lb",null,{"aria-hidden":"true","href":"#connect-to-redux","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":["Now you need to create action to call ",["$","code",null,{"children":"aztro.service"}]," and store its response to the redux state."]}],["$","p",null,{"children":["Now you need to update the interface for the horoscope state value in file ",["$","code",null,{"children":"libs/store/src/lib/horoscope/horoscope.slice.ts"}],":"]}],["$","$Ld",null,{"language":"typescript","fileName":"","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"import {\n  AdhHoroscope,\n  AdhHoroscopeDay,\n  AdhZodiacSignItem,\n} from '@aztro-daily-horoscope/models';\n\nexport interface HoroscopeState {\n  loadingStatus: 'not loaded' | 'loading' | 'loaded' | 'error';\n  error?: string;\n  zodiacSignItem?: AdhZodiacSignItem;\n  day?: AdhHoroscopeDay;\n  horoscope?: AdhHoroscope;\n}\n"}],["$","ul",null,{"children":[["$","li",null,{"children":[["$","code",null,{"children":"loadingStatus"}]," is the API request status from ",["$","code",null,{"children":"aztro.service"}],"."]}],["$","li",null,{"children":[["$","code",null,{"children":"error"}]," is the API request error from ",["$","code",null,{"children":"aztro.service"}],"."]}],["$","li",null,{"children":[["$","code",null,{"children":"zodiacSignItem"}]," is the user's selected zodiac sign."]}],["$","li",null,{"children":[["$","code",null,{"children":"day"}]," is the parameter passed to ",["$","code",null,{"children":"aztro.service"}],"."]}],["$","li",null,{"children":[["$","code",null,{"children":"horoscope"}]," is the transformed response from ",["$","code",null,{"children":"aztro.service."}]]}]]}],["$","p",null,{"children":"Then, you need to update this file to add a thunk action and reducers to fetch the horoscope:"}],["$","$Ld",null,{"language":"typescript","fileName":"horoscope.slice.ts","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"$11"}],["$","p",null,{"children":"It adds a thunk action and its corresponding reducers:"}],["$","ul",null,{"children":[["$","li",null,{"children":[["$","code",null,{"children":"fetchHoroscope"}],"is going to call ",["$","code",null,{"children":"aztro.service"}],"."]}],["$","li",null,{"children":[["$","code",null,{"children":"fetchHoroscope.pending"}]," is dispatched when ",["$","code",null,{"children":"fetchHoroscope"}]," is triggered"]}],["$","li",null,{"children":[["$","code",null,{"children":"fetchHoroscope.fulfilled"}]," is dispatched when ",["$","code",null,{"children":"aztro.service"}]," returns a successful response. It is going to assign the ",["$","code",null,{"children":"state.horoscope"}]," with its response"]}],["$","li",null,{"children":[["$","code",null,{"children":"fetchHoroscope.rejected"}]," is dispatched when ",["$","code",null,{"children":"aztro.service"}]," returns a failed response."]}]]}],["$","p",null,{"children":["Now you need to pass the redux state value to your ",["$","code",null,{"children":"horoscope-card"}]," component. Add below selectors to this file. These are pure functions that take the root state as input and derive data from it:"]}],["$","$Ld",null,{"language":"typescript","fileName":"horoscope.slice.ts","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"const getHoroscopeState = (rootState: RootState): HoroscopeState =>\n  rootState[HOROSCOPE_FEATURE_KEY];\n\nconst getUserZodiacItem = (\n  rootState: RootState\n): AdhZodiacSignItem | undefined => getHoroscopeState(rootState).zodiacSignItem;\n\nconst getUserZodiac = (rootState: RootState): AdhZodiacSign | undefined =>\n  getUserZodiacItem(rootState)?.zodiacSign;\n\nconst getUserHoroscope = (rootState: RootState): AdhHoroscope | undefined =>\n  getHoroscopeState(rootState).horoscope;\n\nconst getHoroscopeLoadingStatus = (rootState: RootState): LoadingStatus =>\n  getHoroscopeState(rootState).loadingStatus;\n\nexport const horoscopeSelectors = {\n  getUserZodiacItem,\n  getUserZodiac,\n  getUserHoroscope,\n  getHoroscopeLoadingStatus,\n};\n"}],["$","p",null,{"children":["To summarize, the file ",["$","code",null,{"children":"libs/store/src/lib/horoscope/horoscope.slice.ts"}]," will become like below:"]}],["$","$Ld",null,{"language":"typescript","fileName":"horoscope.slice.ts","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"$12"}],["$","p",null,{"children":["Then update ",["$","code",null,{"children":"horoscope-card"}]," component with the below code. Notice inside ",["$","code",null,{"children":"mapStateToProps"}]," function, it uses selector functions from above."]}],["$","$Ld",null,{"language":"typescript","
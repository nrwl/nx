e\". Add this prefix to distinguish model names from component names."]}],["$","p",null,{"children":["This example uses icons from ",["$","$Lb",null,{"prefetch":false,"href":"https://materialdesignicons.com/","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"Material Community Icons","target":"_blank","rel":"noreferrer","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}],". You need to create a list that contains the zodiac sign name and its matching icon."]}],["$","$Ld",null,{"language":"typescript","fileName":"zodiac-sign-item.interface.ts","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"import { AdhZodiacSign } from './zodiac-sign.enum';\n\nexport interface AdhZodiacSignItem {\n  icon: string;\n  zodiacSign: AdhZodiacSign;\n}\n"}],["$","$Ld",null,{"language":"typescript","fileName":"zodiac-sign-list.const.ts","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"$e"}],["$","h3",null,{"id":"create-a-component-for-zodiac-sign-list","className":"group scroll-mt-20","children":["Create a Component for Zodiac Sign List",["$","$Lb",null,{"aria-hidden":"true","href":"#create-a-component-for-zodiac-sign-list","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":["Then, create a library for the UI and 
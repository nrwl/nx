ace';\n\nexport const rootReducer = combineReducers<RootState>({\n  horoscope: horoscopeSlice.reducer,\n});\n"}],["$","$Ld",null,{"language":"typescript","fileName":"root.store.ts","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"import { configureStore } from '@reduxjs/toolkit';\n\nimport { initialRootState } from './root-state.initial';\nimport { rootReducer } from './root.reducer';\n\ndeclare const process: any;\n\nconst isDevelopment = process.env.NODE_ENV === 'development';\n\nconst rootStore = configureStore({\n  reducer: rootReducer,\n  middleware: (getDefaultMiddleware) => getDefaultMiddleware(),\n  devTools: isDevelopment,\n  preloadedState: initialRootState,\n});\n\nexport { rootStore };\n"}],["$","h3",null,{"id":"dispatch-action-from-zodiacsignlist-component","className":"group scroll-mt-20","children":["Dispatch Action from zodiac-sign-list Component",["$","$Lb",null,{"aria-hidden":"true","href":"#dispatch-action-from-zodiacsignlist-component","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":["You now need to dispatch ",["$","code",null,{"children":"setUserZodiacSignItem"}]," action from ",["$","code",null,{"children":"libs/ui/src/lib/zodiac-sign-list/zodiac-sign-list.tsx"}]," component."]}],["$","p",null,{"children":["Create a file at",["$","code",null,{"children":"libs/ui/src/lib/zodiac-sign-list/zodiac-sign-list.props.ts"}],", and add a function ",["$","code",null,{"children":"mapDispatchToProps"}],". In this function, dispatch the ",["$","code",null,{"children":"setUserZodiacSignItem"}]," action."]}],["$","$Ld",null,{"language":"typescript","fileName":"zodiac-sign-list.props.ts","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"import { AdhZodiacSignItem } from '@aztro-daily-horoscope/models';\nimport { horoscopeActions } from '@aztro-daily-horoscope/store';\nimport { Dispatch } from '@reduxjs/toolkit';\n\nconst mapDispatchToProps = (dispatch: Dispatch) => {\n  return {\n    setUserZodiacSignItem(zodiacSignItem: AdhZodiacSignItem) {\n      dispatch(horoscopeActions.setUserZodiacSignItem(zodiacSignItem));\n    },\n  };\n};\n\ntype mapDispatchToPropsType = ReturnType<typeof mapDispatchToProps>;\n\ntype ZodiacSignListProps = mapDispatchToPropsType;\n\nexport { mapDispatchToProps, ZodiacSignListProps };\n"}],["$","p",null,{"children":["The component ",["$","code",null,{"children":"zodiac-sign-list"}]," needs to import from the above ",["$","code",null,{"children":"zodiac-sign-list.props"}]," file. Then the component ",["$","code",null,{"children":"zodiac-sign-list"}]," becomes:"]}],["$","$Ld",null,{"language":"tsx","fileName":"zodiac-sign-list.tsx","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"$f"}],["$","p",null,{"children":"Notice that a container component is added. This container component is stateful that connects to the redux state."}],["$","$Ld",null,{"language":"typescript","fileName":"","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"export const ZodiacSignListContainer = connect(\n  null,\n  mapDispatchToProps\n)(ZodiacSignList);\n"}],["$","p",null,{"children":["This container component passes down props ",["$","code",null,{"children":"ZodiacSignListProps"}]," to ",["$","code",null,{"children":"ZodiacSignList"}],". So this prop ",["$","code",null,{"children":"setUserZodiacSignItem"}]," got called at the press event for ListItem: ",["$","code",null,{"children":"onPress={() => setUserZodiacSignItem(item)}"}],"."]}],["$","h3",null,{"id":"add-provider-to-app","className":"group scroll-mt-20","children":["Add Provider to App",["$","$Lb",null,{"aria-hidden":"true","href":"#add-provider-to-app","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":["Go back to the app file at ",["$","code",null,{"children":"apps/daily-horoscope-app/src/app/App.tsx"}],", now you need to replace the ",["$","code",null,{"children":"ZodiacSignList"}]," with ",["$","code",null,{"children":"ZodiacSignListContainer"}],", and add the provider for the root store."]}],["$","$Ld",null,{"language":"tsx","fileName":"zodiac-sign-list.tsx","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"import * as React from 'react';\nimport { Provider } from 'react-redux';\nimport { rootStore } from '@aztro-daily-horoscope/store';\nimport { ZodiacSignListContainer } from '@aztro-daily-horoscope/ui';\nimport { Header } from '@rneui/base';\n\nconst App = () => {\n  return (\n    <Provider store={rootStore}>\n      <Header centerComponent={{ text: 'Daily Horoscope' }} />\n      <ZodiacSignListContainer />\n    </Provider>\n  );\n};\n\nexport default App;\n"}],["$"
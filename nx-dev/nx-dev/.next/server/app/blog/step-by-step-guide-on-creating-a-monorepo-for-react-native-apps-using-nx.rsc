\nnpm install --save @react-navigation/native @react-navigation/stack react-native-reanimated react-native-gesture-handler react-native-screens @react-native-community/masked-view\n\n# yarn\nyarn add @react-navigation/native @react-navigation/stack react-native-reanimated react-native-gesture-handler react-native-screens @react-native-community/masked-view\n"}],["$","p",null,{"children":["In the app's package.json at ",["$","code",null,{"children":"apps/daily-horoscope-app/package.json"}],", under dependencies, add the above packages:"]}],["$","$Ld",null,{"language":"json5","fileName":"","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"{\n  name: 'daily-horoscope-app',\n  version: '0.0.1',\n  private: true,\n  dependencies: {\n    // other dependencies\n    '@react-native-masked-view/masked-view': '*',\n    '@react-navigation/native': '*',\n    '@react-navigation/stack': '*',\n    'react-native-gesture-handler': '*',\n    'react-native-reanimated': '*',\n    'react-native-screens': '*',\n  },\n}\n"}],["$","p",null,{"children":["Go to the iOS folder at ",["$","code",null,{"children":"apps/daily-horoscope-app/ios/Podfile"}]," and run ",["$","code",null,{"children":"Pod install"}],"."]}],["$","p",null,{"children":["In ",["$","code",null,{"children":"apps/daily-horoscope-app/src/main.tsx"}]," file, add below line at top of the file:"]}],["$","$Ld",null,{"language":"typescript","fileName":"","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"import 'react-native-gesture-handler';\n"}],["$","h3",null,{"id":"update-app-to-use-react-navigation","className":"group scroll-mt-20","children":["Update App to Use React Navigation",["$","$Lb",null,{"aria-hidden":"true","href":"#update-app-to-use-react-navigation","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","stro
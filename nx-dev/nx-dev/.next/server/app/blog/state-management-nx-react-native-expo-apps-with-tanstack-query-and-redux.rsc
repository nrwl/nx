ldren":"This state has 3 actions:"}],["$","ul",null,{"children":[["$","li",null,{"children":"like: when users click like"}],["$","li",null,{"children":"remove: when users cancel the like"}],["$","li",null,{"children":"clear: when users clear all the likes"}]]}],["$","h3",null,{"id":"root-store","className":"group scroll-mt-20","children":["Root Store",["$","$Lb",null,{"aria-hidden":"true","href":"#root-store","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":"Then you have to add the root store and create a transform function to stringify the redux state:"}],["$","$Ld",null,{"language":"typescript","fileName":"persist-transform.ts","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"import { EntityState } from '@reduxjs/toolkit';\nimport { createTransform } from 'redux-persist';\nimport { LIKES_FEATURE_KEY } from '../likes/likes.slice';\n\nconst transformEntityStateToPersist = createTransform(\n  // transform state on its way to being serialized and persisted.\n  (\n    entityState: EntityState<any>\n  ): {\n    ids: string;\n    entities: any;\n  } => {\n    return {\n      ...entityState,\n      ids: JSON.stringify(entityState.ids),\n      entities: JSON.stringify(entityState.entities),\n    };\n  },\n  // transform state being rehydrated\n  (entityState: { ids: string; entities: string }): EntityState<any> => {\n    return {\n      ...entityState,\n      ids: JSON.parse(entityState.ids),\n      entities: JSON.parse(entityState.entities),\n    };\n  },\n  // define which reducers this transform gets called for.\n  { whitelist: [LIKES_FEATURE_KEY] }\n);\n\nexport { transformEntityStateToPersist };\n"}],["$","$Ld",null,{"language":"typescript","fileName":"root-state.initial.ts","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"import { initialLikesState } from '../likes/likes.slice';\n\nimport { RootState } from './root-state.interface';\n\nexport const initialRootState: RootState = {\n  likes: initialLikesState,\n};\n"}],["$","$Ld",null,{"language":"typescript","fileName":"root-state.interface.ts","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"import { LikesState } from '../likes/likes.slice';\n\nexport interface RootState {\n  likes: LikesState;\n}\n"}],["$","$Ld",null,{"language":"typescript","fileName":"root-reducer.ts","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"import { combineReducers } from '@reduxjs/toolkit';\n\nimport { likesReducer } from '../likes/likes.slice';\nimport { RootState } from './root-state.interface';\n\nexport const createRootReducer = combineReducers<RootState>({\n  likes: likesReducer,\n});\n"}],["$","$Ld",null,{"language":"typescript","fileName":"root.store.ts","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"$11"}],["$","h3",null,{"id":"connect-redux-state-with-ui","className":"group scroll-mt-20","children":["Connect Redux State with UI",["$","$Lb",null,{"aria-hidden":"true","href":"#connect-redux-state-with-ui","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-h
following reasons:\n    1. You might have mismatching versions of React and the renderer (such as React DOM)\n    2. You might be breaking the Rules of Hooks\n    3. You might have more than one copy of React in the same app\n    See https://reactjs.org/link/invalid-hook-call for tips about how to debug and fix this problem.\n"}],["$","p",null,{"children":["To solve this, you need to wrap your component inside the renderHook function from ",["$","code",null,{"children":"@testing-library/react-native"}]," library:"]}],["$","p",null,{"children":["$","strong",null,{"children":"1. Install Library to Mock Fetch"}]}],["$","p",null,{"children":"Depending on which library you use to make HTTP requests. (e.g. fetch, axios), you need to install a library to mock the response."}],["$","ul",null,{"children":[["$","li",null,{"children":["If you use ",["$","code",null,{"children":"fetch"}]," to fetch data, you need to install ",["$","code",null,{"children":"jest*fetch-mock"}],"."]}],["$","li",null,{"children":["If you use ",["$","code",null,{"children":"axios"}]," to fetch data, you need to install ",["$","code",null,{"children":"axio*-mock-adapter"}],"."]}]]}],["$","p",null,{"children":["For this example, since it uses ",["$","code",null,{"children":"fetch"}],", you need to install ",["$","code",null,{"children":"jest-fetch-mock"}],":"]}],["$","$Ld",null,{"language":"shell","fileName":"","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"#npm\nnpm install jest-fetch-mock --save-dev\n\n#yarn\nyard add jest-fetch-mock --dev\n"}],["$","p",null,{"children":["You also need to mock ",["$","code",null,{"children":"fetch"}]," library in ",["$","code",null,{"children":"libs/queries/use-cat-fact/test-setup.ts"}],":"]}],["$","$Ld",null,{"language":"ts","fileName":"","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"import fetch
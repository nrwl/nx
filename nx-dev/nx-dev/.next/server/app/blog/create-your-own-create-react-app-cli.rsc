iles'), projectRoot, options);\n  await formatFiles(tree);\n\n  return addDependenciesToPackageJson(\n    tree,\n    {\n      react: 'latest',\n      'react-dom': 'latest',\n      'react-scripts': 'latest',\n    },\n    {\n      \"@types/react\": \"latest\",\n      \"@types/react-dom\": \"latest\",\n    }\n  );\n}\n"}],["$","h2",null,{"id":"step-4-run-the-new-version-that-creates-the-react-app","className":"group scroll-mt-20","children":["Step 4: Run the New Version that Creates the React App",["$","$Lb",null,{"aria-hidden":"true","href":"#step-4-run-the-new-version-that-creates-the-react-app","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":["Now you can publish a new version of ",["$","code",null,{"children":"my-own-react"}]," and ",["$","code",null,{"children":"create-my-own-react-app"}]," and run it again:"]}],["$","$Ld",null,{"language":"shell","fileName":"","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"cd ..\nnpx nx run-many --targets publish --ver 1.0.1 --tag latest\ncd tmp\nnpx create-my-own-react-app@1.0.1 test2\n"}],["$","p",null,{"children":["The CLI now creates a workspace with the dependencies we want and the code for the react application just like ",["$","code",null,{"children":"create-react-app"}],":"]}],["$","p",null,{"children":["$","img",null,{"src":"/documentation/blog/images/2023-08-10/gZ7ocdR49soEahM8TlGA4A.avif","alt":"","loading":"l
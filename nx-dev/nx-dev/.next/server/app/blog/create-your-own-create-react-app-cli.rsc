 ",["$","code",null,{"children":"package.json"}],". We need to modify our ",["$","code",null,{"children":"src/generators/preset/generator.ts"}]," as follows:"]}],["$","$Ld",null,{"language":"shell","fileName":"","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"import {\n  updateJson,\n  ...\n} from '@nx/devkit';\n...\n\nexport default async function (tree: Tree, options: PresetGeneratorSchema) {\n  ...\n  addProjectConfiguration(...);\n\n  updateJson(tree, 'package.json', (json) => {\n    json.scripts = json.scripts || {};\n\n    // generate a start script into the package.json\n    json.scripts.start = 'npx react-scripts start';\n    return json;\n  });\n\n  ...\n}\n"}],["$","p",null,{"children":["Note, we want to keep our ",["$","code",null,{"children":"project.json"}]," file even though it doesn't have any targets defined. That way Nx recognizes it as a proper project and applies caching and other optimization strategies."]}],["$","h3",null,{"id":"adding-the-target-to-the-projectjson-rather-than-packagejson","className":"group scroll-mt-20","children":[["Adding the target to the ",["$","code",null,{"children":"project.json"}]," rather than ",["$","code",null,{"children":"package.json"}]],["$","$Lb",null,{"aria-hidden":"true","href":"#adding-the-target-to-the-projectjson-rather-than-packagejson","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":["Alternativel
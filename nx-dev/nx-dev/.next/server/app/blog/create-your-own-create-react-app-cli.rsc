 dark:ring-slate-800","children":[["$","span",null,{"children":["$","$Lc",null,{"alt":"Emily Xiong","title":"Emily Xiong","loading":"lazy","width":"40","height":"40","decoding":"async","src":"/documentation/blog/images/authors/Emily Xiong.jpeg","className":"rounded-full ring-1 ring-white grayscale dark:ring-slate-900"}]}],["$","span",null,{"className":"text-balance","children":"Emily Xiong"}],["$","a",null,{"href":"https://twitter.com/xiongemily","target":"_blank","aria-label":"Follow Emily Xiong on X","children":["$","svg",null,{"fill":"currentColor","role":"img","preserveAspectRatio":"xMidYMid meet","viewBox":"0 0 24 24","xmlns":"http://www.w3.org/2000/svg","aria-hidden":"true","className":"h-5 w-5","children":["$","path",null,{"d":"M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"}]}]}],["$","a",null,{"href":"https://github.com/xiongemi","target":"_blank","aria-label":"View Emily Xiong's GitHub profile","children":["$","svg",null,{"fill":"currentColor","role":"img","xmlns":"http://www.w3.org/2000/svg","viewBox":"0 0 16 16","aria-hidden":"true","className":"h-5 w-5","children":["$","path",null,{"d":"M8 0a8 8 0 0 0-2.53 15.59c.4.07.55-.17.55-.38l-.01-1.49c-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.42 7.42 0 0 1 4 0c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48l-.01 2.2c0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8a8 8 0 0 0-8-8z"}]}]}]]}]]}]]}],["$","span",null,{"className":"text-sm text-slate-400 dark:text-slate-600","children":"August 10, 2023"}]]}]]}],["$","header",null,{"className":"mx-auto mb-16 mt-8 px-4","children":["$","h1",null,{"className":"text-center text-4xl font-semibold text-slate-900 dark:text-white","children":"Create Your Own create-react-app CLI"}]}],["$","div",null,{"className":"mx-auto mb-16 w-full max-w-screen-md","children":["$","$Lc",null,{"className":"w-full object-cover md:rounded-md","src":"/documentation/blog/images/2023-08-10/j2QU-hjxt-1krFST8CGFiA.png","alt":"Create Your Own create-react-app CLI","width":1400,"height":735}]}]]}],["$","div",null,{"className":"mx-auto max-w-7xl px-4 lg:px-8","data-content-area":true,"children":["$","div",null,{"className":"relative isolate grid grid-cols-1 gap-8 xl:grid-cols-[200px_minmax(0,1fr)_200px]","children":[["$","div",null,{"className":"hidden min-h-full xl:block","children":"$undefined"}],["$","div",null,{"className":"w-full min-w-0 md:mx-auto md:max-w-screen-md","children":["$undefined",["$","div",null,{"data-document":"main","className":"prose prose-lg prose-slate dark:prose-invert w-full max-w-none","children":["$","article",null,{"children":[["$","p",null,{"children":"Most technologies have a CLI to create a new workspace. In fact, it is so prevalent that NPM and other package managers support it natively. For example:"}],["$","ul",null,{"children":[["$","li",null,{"children":["Nx has ",["$","$Lb",null,{"prefetch":false,"href":"/getting-started/installation","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"create-nx-workspace","target":"$undefined","rel":"$undefined","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}]]}],["$","li",null,{"children":["React has, well, had ",["$","$Lb",null,{"prefetch":false,"href":"https://create-react-app.dev/","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"create-react-app","target":"_blank","rel":"noreferrer","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}]]}],["$","li",null,{"children":["Angular has ",["$","$Lb",null,{"prefetch":false,"href":"https://angular.io/cli","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"Angular CLI","target":"_blank","rel":"noreferrer","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}]]}],["$","li",null,{"children":["Vite has ",["$","$Lb",null,{"prefetch":false,"href":"https://vitejs.dev/guide/#scaffolding-your-first-vite-project","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"create-vite","target":"_blank","rel":"noreferrer","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}]]}]]}],["$","p",null,{"children":["Having a CLI to quickly scaffold a starting project is great for onboarding new people, but it can also be a burden for framework authors as they want to rather focus on building the framework. Additionally, building ",["$","strong",null,{"children":"and supporting"}]," a good CLI is another beast to tackle. And this is where Nx comes in."]}],["$","p",null,{"children":["Nx has had support for ",["$","$Lb",null,{"prefetch":false,"href":"/extending-nx/recipes/create-preset","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"creating custom \"presets\"","target":"$undefined","rel":"$undefined","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}]," for a while, allowing plugin authors to fully customize the workspace structure from the ground up. To use them you had to go via the ",["$","code",null,{"children":"create-nx-workspace"}]," command though, passing the name of your plugin as the ",["$","code",null,{"children":"--preset"}]," . This works, but you might want to have a more \"branded command\" experience, like ",["$","code",null,{"children":"npx create-my-own-app"}]," ."]}],["$","p",null,{"children":"And this is exactly what we're going to explore in this article. We will write our own CLI. And out of nostalgia, let's build our own version of Create-React-App."}],["$","p",null,{"children":["If you want to check out the final result, here's the corresponding Github repo: ",["$","$Lb",null,{"prefetch":false,"href":"https://github.com/nrwl/nx-recipes/tree/main/nx-devkit-create-own-cli","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"https://github.com/nrwl/nx-recipes/tree/main/nx-devkit-create-own-cli","target":"_blank","rel":"noreferrer","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}]]}],["$","p",null,{"children":["$","strong",null,{"children":"Prefer a video? We got you covered!"}]}],["$","div",null,{"className":"text-center","children":[" ",["$","iframe",null,{"src":"https://www.youtube.com/embed/ocllb5KEXZk","title":"$undefined","width":"100%","allow":"accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture; fullscreen","loading":"lazy","credentialless":"true","className":"rounded-lg shadow-lg"}],"$undefined"]}],["$","h2",null,{"id":"what-is-nx-and-what-is-an-nx-plugin","className":"group scroll-mt-20","children":["What is Nx and what is an Nx plugin?",["$","$Lb",null,{"aria-hidden":"true","href":"#what-is-nx-and-what-is-an-nx-plugin","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":"But before we jump right into the topic, what is Nx? And more specifically, what are Nx Plugins?"}],["$","p",null,{"children":["Nx is an open-source build system that provides tools and techniques to enhance developer productivity. ",["$","$Lb",null,{"prefetch":false,"href":"https://youtu.be/-_4WMl-Fn0w","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"Check out this 10 min video overview","target":"_blank","rel":"noreferrer","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}]," of Nx if you want to learn more."]}],["$","p",null,{"children":["Our example, in particular, uses Nx as a dev tool for creating a CLI and plugin. Nx plugins are npm packages that provide integrations between Nx and other technologies. You can use Nx without them, but they can provide great value if applied properly. ",["$","code",null,{"children":"my-own-react"}]," is the plugin to integrate React and Nx."]}],["$","h2",null,{"id":"step-1-create-a-cli-workspace","className":"group scroll-mt-20","children":["Step 1: Create a CLI workspace",["$","$Lb",null,{"aria-hidden":"true","href":"#step-1-create-a-cli-workspace","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":"Create a new Nx workspace that is preconfigured for plugin development, using the below command:"}],["$","$Ld",null,{"language":"shell","fileName":"","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"npx create-nx-plugin my-own-react --create-package-name=create-my-own-react-app\n"}],["$","p",null,{"children":"Note, if you already have an existing Nx plugin workspace, instead of creating a new workspace, you can simply run the following in your plugin repository to generate the create CLI:"}],["$","$Ld",null,{"fileName":"","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"nx g @nx/plugin:create-package <cli name> --project=<existing plugin name> --e2eProject e2e\n"}],["$","p",null,{"children":[["$","img",null,{"src":"/documentation/blog/images/2023-08-10/dL5XHPOGCtfFyTHhloaYcQ.avif","alt":"","loading":"lazy"}]," ",["$","em",null,{"children":"Project graph of the workspace"}]]}],["$","p",null,{"children":"The resulting workspace contains 2 projects: a CLI and an Nx plugin."}],["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"create-my-own-react-app:"}]," The CLI project. It contains the code to run when developers invoke ",["$","code",null,{"children":"npx create-my-own-react-app"}],". This will set up a workspace for the developer."]}],["$","li",null,{"children":[["$","strong",null,{"children":"my-own-react:"}]," Nx plugin to integrate react with Nx. It will contain the code for creating and serving an app. It is under the src folder. This will be installed in the user's workspace."]}]]}],["$","h3",null,{"id":"cli-package-structure","className":"group scroll-mt-20","children":["CLI Package Structure",["$","$Lb",null,{"aria-hidden":"true","href":"#cli-package-structure","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":["Let's focus on the ",["$","code",null,{"children":"create-my-own-react-app"}]," project which is our CLI."]}],["$","p",null,{"children":["$","img",null,{"src":"/documentation/blog/images/2023-08-10/00F7H_Z13uonZiflZSQd8Q.avif","alt":"","loading":"lazy"}]}],["$","p",null,{"children":["The ",["$","code",null,{"children":"index.ts"}]," file is the key part here. It is the one that gets invoked when someone runs ",["$","code",null,{"children":"npx create-my-own-react-app"}]," later once we publish it."]}],["$","$Ld",null,{"fileName":"","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"\n#!/usr/bin/env node\n\nimport { createWorkspace } from 'create-nx-workspace';\n\nasync function main() {\n const name = process.argv\\[2\\]; // TODO: use libraries like yargs or enquirer to set your workspace name\n if (!name) {\n throw new Error('Please provide a name for the workspace');\n }\n\nconsole.log(`Creating the workspace: ${name}`);\n\n// This assumes \"my-own-react\" and \"create-my-own-react-app\" are at the same version\n // eslint-disable-next-line @typescript-eslint/no-var-requires\n const presetVersion = require('../package.json').version;\n\n// TODO: update below to customize the workspace\n const { directory } = await createWorkspace(`my-own-react@${presetVersion}`, {\n name,\n nxCloud: false,\n packageManager: 'npm',\n });\n\nconsole.log(`Successfully created the workspace: ${directory}.`);\n}\n\nmain();\n\n"}],["$","p",null,{"children":["The main chunk of code is ",["$","code",null,{"children":"createWorkspace(`my-own-react@${presetVersion}`)"}],". This function creates an Nx workspace with the ",["$","code",null,{"children":"my-own-react"}]," plugin installed."]}],["$","ol",null,{"children":["$","li",null,{"children":[["$","code",null,{"children":"createWorkspace"}]," will also generate the preset generator defined by ",["$","code",null,{"children":"my-own-react"}]," located at ",["$","code",null,{"children":"src/generators/preset/generator.ts"}],". This is the logic which scaffolds a project which uses your technology."]}]}],["$","h2",null,{"id":"step-2-run-the-cli-locally","className":"group scroll-mt-20","children":["Step 2: Run the CLI Locally",["$","$Lb",null,{"aria-hidden":"true","href":"#step-2-run-the-cli-locally","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":["To properly test your CLI you can either publish it to NPM as a beta version or use a local npm registry like ",["$","$Lb",null,{"prefetch":false,"href":"https://verdaccio.org/","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"Verdaccio","target":"_blank","rel":"noreferrer","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}],". Luckily our Nx workspace already comes with a feature to make that a seamless process."]}],["$","ol",null,{"children":["$","li",null,{"children":"First, start a local Verdaccio-based npm registry using the following command:"}]}],["$","$Ld",null,{"language":"shell","fileName":"","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"npx nx local-registry\n"}],["$","p",null,{"children":"This will start the local registry on port 4873 and configure npm to use it instead of the real npm registry."}],["$","p",null,{"children":"2. In the second terminal, run the command to publish all the projects:"}],["$","$Ld",null,{"language":"shell","fileName":"","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"npx nx run-many --targets publish --ver 1.0.0 --tag latest\n"}],["$","p",null,{"children":[["$","em",null,{"children":"(Note,"}]," ",["$","code",null,{"children":"_publish_"}]," ",["$","em",null,{"children":"is a target defined in the"}]," ",["$","code",null,{"children":"_project.json_"}]," ",["$","em",null,{"children":"of our projects.)"}]]}],["$","p",null,{"children":["This command will publish both ",["$","code",null,{"children":"my-own-react"}]," and ",["$","code",null,{"children":"create-my-own-react-app"}]," packages to your local registry. If open the running Verdaccio registry at ",["$","$Lb",null,{"prefetch":false,"href":"http://localhost:4873","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"http://localhost:4873","target":"_blank","rel":"noreferrer","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}]," you should see the published packages."]}],["$","p",null,{"children":["$","img",null,{"src":"/documentation/blog/images/2023-08-10/D72hvW4nrl_DSYyMQU0DQ.avif","alt":"","loading":"lazy"}]}],["$","p",null,{"children":["3. Now, you can run ",["$","code",null,{"children":"npx create-my-own-react-app"}]," just like a developer using our CLI would. For example, go to the tmp directory and create a ",["$","code",null,{"children":"my-own-react"}]," workspace named ",["$","code",null,{"children":"test"}],":"]}],["$","$Ld",null,{"language":"shell","fileName":"","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"cd tmp\nnpx create-my-own-react-app@1.0.0 test\n"}],["$","p",null,{"children":["Wh
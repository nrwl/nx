,{"children":["To do this, we will fill in the preset generator under ",["$","code",null,{"children":"src/generators/preset"}]]}],["$","p",null,{"children":["A generator is a function that makes modifications to a file system representation known as the ",["$","code",null,{"children":"Tree"}],". These modifications will then be applied to the real file system. In our case, the preset generator will create the files for a React app."]}],["$","p",null,{"children":["Currently, the file at ",["$","code",null,{"children":"src/generators/preset/generator.ts"}]," looks like:"]}],["$","$Ld",null,{"fileName":"","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"import {\n  addProjectConfiguration,\n  formatFiles,\n  generateFiles,\n  Tree,\n} from '@nx/devkit';\nimport * as path from 'path';\nimport { PresetGeneratorSchema } from './schema';\n\nexport async function presetGenerator(\n  tree: Tree,\n  options: PresetGeneratorSchema\n) {\n  const projectRoot = `libs/${options.name}`;\n  addProjectConfiguration(tree, options.name, {\n    root: projectRoot,\n    projectType: 'library',\n    sourceRoot: `${projectRoot}/src`,\n    targets: {},\n  });\n  generateFiles(tree, path.join(__dirname, 'files'), projectRoot, options);\n  await formatFiles(tree);\n}\n\nexport default presetGenerator;\n"}],["$","p",null,{"children":"The preset generator does 2 things:"}],["$","ul",null,{"children":[["$","li",null,{"children":["Create an Nx project using the ",["$","code",null,{"children":"addProjectConfiguration"}]," function. This creates a ",["$","code",null,{"children":"project.json"}]," file which allows Nx to run commands on it."]}],["$","li",null,{"children":["Generates files in the project using the ",["$","code",null,{"children":"generateFiles"}]," function. This uses the templates under ",["$","code",null,{"children":"src/generators/preset/files"}]," which are interpolated to become the files that are generated for the user."]}],["$","li",null,{"children":["Format the generated files with ",["$","code",null,{"children":"prettier"}]," with the ",["$","code",null,{"children":"formatFiles"}]," function"]}]]}],["$","p",null,{"children":[["$","img",null,{"src":"/documentation/blog/images/2023-08-10/38RvkLIwUAvVDDrEp5sFPQ.avif","alt":"","loading":"lazy"}]," ",["$","em",null,{"children":"preset generator"}]]}],["$","p",null,{"children":["The ",["$","code",null,{"children":"addProjectConfiguration"}]," and ",["$","code",null,{"children":"generateFiles"}]," functions are from ",["$","$Lb",null,{"prefetch":false,"href":"/nx-api/devkit/documents/nx_devkit","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"@nx/devkit","target":"$undefined","rel":"$undefined","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}],", a library that contains utility functions for writing plugins for Nx. For the future, see the ",["$","$Lb",null,{"prefetch":false,"href":"/nx-api/devkit/documents/nx_devkit","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"complete list of utility functions","target":"$undefined","rel":"$undefined","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}],"."]}],["$","ol",null,{"children":["$","li",null,{"children":["Change the project which is created with ",["$","code",null,{"children":"addProjectConfiguration"}],":"]}]}],["$","$Ld",null,{"fileName":"","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"const projectRoot = '.';\naddProjectConfiguration(tree, options.name, {\n  root: projectRoot,\n  projectType: 'application',\n  targets: {}\n});\n"}],["$","ul",null,{"children":[["$","li",null,{"children":["The ",["$","code",null,{"children":"projectRoot"}]," will be ''.', the root of a workspace"]}],["$","li",nu
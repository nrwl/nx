erate a new workspace with the new preset version (npx create-my-own-react-app@1.0.2 test3), we should now see our ",["$","code",null,{"children":"package.json"}]," ",["$","code",null,{"children":"start"}],"script being generated."]}],["$","p",null,{"children":["$","img",null,{"src":"/documentation/blog/images/2023-08-10/Rb6xWqUiK51DsZsAGdtNbQ.avif","alt":"","loading":"lazy"}]}],["$","p",null,{"children":"To run the app we either run"}],["$","ul",null,{"children":[["$","li",null,{"children":["$","code",null,{"children":"npm start"}]}],["$","li",null,{"children":["or ",["$","code",null,{"children":"npx nx start"}]," which would automatically pick up the ",["$","code",null,{"children":"start"}]," script in the ",["$","code",null,{"children":"package.json"}]]}]]}],["$","p",null,{"children":[["$","img",null,{"src":"/documentation/blog/images/2023-08-10/qVf6zEOndAgYkIRgZxTYZA.avif","alt":"","loading":"lazy"}]," ",["$","img",null,{"src":"/documentation/blog/images/2023-08-10/K7YZDNyIWp0Bu9tLl5VixA.avif","alt":"","loading":"lazy"}]," ",["$","em",null,{"children":"serve output"}]]}],["$","h2",null,{"id":"step-7-add-a-prompt-to-the-cli-to-customize-the-starter-app","className":"group scroll-mt-20","children":["Step 7: Add a Prompt to the CLI to Customize the Starter App",["$","$Lb",null,{"aria-hidden":"true","href":"#step-7-add-a-prompt-to-the-cli-to-customize-the-starter-app","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":"Now, you have a CLI that 
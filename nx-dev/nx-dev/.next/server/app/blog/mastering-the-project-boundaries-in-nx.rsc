late-400 dark:ring-slate-800","children":[["$","span",null,{"children":["$","$Lc",null,{"alt":"Miroslav Jonaš","title":"Miroslav Jonaš","loading":"lazy","width":"40","height":"40","decoding":"async","src":"/documentation/blog/images/authors/Miroslav Jonaš.jpeg","className":"rounded-full ring-1 ring-white grayscale dark:ring-slate-900"}]}],["$","span",null,{"className":"text-balance","children":"Miroslav Jonaš"}],["$","a",null,{"href":"https://twitter.com/meeroslav","target":"_blank","aria-label":"Follow Miroslav Jonaš on X","children":["$","svg",null,{"fill":"currentColor","role":"img","preserveAspectRatio":"xMidYMid meet","viewBox":"0 0 24 24","xmlns":"http://www.w3.org/2000/svg","aria-hidden":"true","className":"h-5 w-5","children":["$","path",null,{"d":"M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"}]}]}],["$","a",null,{"href":"https://github.com/meeroslav","target":"_blank","aria-label":"View Miroslav Jonaš's GitHub profile","children":["$","svg",null,{"fill":"currentColor","role":"img","xmlns":"http://www.w3.org/2000/svg","viewBox":"0 0 16 16","aria-hidden":"true","className":"h-5 w-5","children":["$","path",null,{"d":"M8 0a8 8 0 0 0-2.53 15.59c.4.07.55-.17.55-.38l-.01-1.49c-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.42 7.42 0 0 1 4 0c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48l-.01 2.2c0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8a8 8 0 0 0-8-8z"}]}]}]]}]]}]]}],["$","span",null,{"className":"text-sm text-slate-400 dark:text-slate-600","children":"December 17, 2021"}]]}]]}],["$","header",null,{"className":"mx-auto mb-16 mt-8 px-4","children":["$","h1",null,{"className":"text-center text-4xl font-semibold text-slate-900 dark:text-white","children":"Taming Code Organization with Module Boundaries in Nx"}]}],["$","div",null,{"className":"mx-auto mb-16 w-full max-w-screen-md","children":["$","$Lc",null,{"className":"w-full object-cover md:rounded-md","src":"/documentation/blog/images/2021-12-17/PIUl1QGk7mOpSFdEwFQ8OA.png","alt":"Taming Code Organization with Module Boundaries in Nx","width":1400,"height":735}]}]]}],["$","div",null,{"className":"mx-auto max-w-7xl px-4 lg:px-8","data-content-area":true,"children":["$","div",null,{"className":"relative isolate grid grid-cols-1 gap-8 xl:grid-cols-[200px_minmax(0,1fr)_200px]","children":[["$","div",null,{"className":"hidden min-h-full xl:block","children":"$undefined"}],["$","div",null,{"className":"w-full min-w-0 md:mx-auto md:max-w-screen-md","children":["$undefined",["$","div",null,{"data-document":"main","className":"prose prose-lg prose-slate dark:prose-invert w-full max-w-none","children":["$","article",null,{"children":[["$","p",null,{"children":"As your repository grows, it becomes more challenging to organize and name the applications and libraries. This organization, when done right, feels intuitive and allows team members to easily find projects and understand how they work together. When done poorly, it results in a mess we eventually end up calling \"the legacy software\". This article will show you different ways how you can prevent your repo from descending into chaos."}],["$","p",null,{"children":["Our book ",["$","$Lb",null,{"prefetch":false,"href":"https://go.nx.dev/angular-enterprise-monorepo-patterns-new-book","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"Enterprise Angular Monorepo Patterns","target":"_blank","rel":"noreferrer","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}]," presents an in-depth guide to assist you with naming and organization. If you still haven't read this book, we warmly recommend you do. Don't let the name fool you, though — the architecture guidelines explained in this book apply to any framework."]}],["$","p",null,{"children":"On large projects, you will most likely find multiple teams working on different parts of the solution. Those projects are usually split into logical domains, where each team focuses on a single domain. Each domain block can have a clear public API which other domains can use to consume the information."}],["$","p",null,{"children":["But the code organization is just one piece of the puzzle. The physical organization does not prevent developers from consuming the domains or parts of those domains, that should otherwise be outside of their reach. Nx ships with ",["$","code",null,{"children":"enforce-module-boundaries"}]," ESLint rule that helps restrict that possibility."]}],["$","h2",null,{"id":"understanding-the-default-configuration","className":"group scroll-mt-20","children":["Understanding the default configuration",["$","$Lb",null,{"aria-hidden":"true","href":"#understanding-the-default-configuration","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":["When you generate the first project in your workspace using one of our generators, one of the things you get for free is the full linter setup. The linter is preconfigured with a default ruleset that includes a set of best practices. Alongside the standard set of rules, the initial generated configuration includes a setup for ",["$","code",null,{"children":"enforce-module-boundaries"}]," rule."]}],["$","$Ld",null,{"language":"json5","fileName":".eslintrc.json","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"{\n  // ... default ESLint config here\n\n  overrides: [\n    {\n      files: ['*.ts', '*.tsx', '*.js', '*.jsx'],\n      rules: {\n        '@nrwl/nx/enforce-module-boundaries': [\n          'error',\n          {\n            allow: [],\n            depConstraints: [\n              {\n                sourceTag: '*',\n                onlyDependOnLibsWithTags: ['*'],\n              },\n            ],\n            enforceBuildableLibDependency: true,\n          },\n        ],\n      },\n    },\n\n    // ... more ESLint overrides here\n  ],\n}\n"}],["$","p",null,{"children":"Let's dissect what each of these properties does."}],["$","p",null,{"children":["The ",["$","code",null,{"children":"allow"}]," array acts as a whitelist listing the import definitions that should be omitted from further checks. You can read more about it in the ",["$","strong",null,{"children":"Overriding the overrides"}]," section below."]}],["$","p",null,{"children":["The ",["$","code",null,{"children":"depConstraints"}]," section is the one you will be spending most time fine-tuning. It represents an array of constraints, each consisting of ",["$","code",null,{"children":"sourceTag"}]," and ",["$","code",null,{"children":"onlyDependOnLibsWithTags"}]," properties. The default configuration has a wildcard ",["$","code",null,{"children":"*"}]," set as a value for both of them, meaning that any project can import (depend on) any other project."]}],["$","blockquote",null,{"children":["$","p",null,{"children":["Note, the wildcard only applies to libraries. Applications and E2E applications cannot be imported. It wouldn't make any sense. If you want to combine applications, you should use the ",["$","$Lb",null,{"prefetch":false,"href":"/recipes/angular/dynamic-module-federation-with-angular","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"micro-frontends","target":"$undefined","rel":"$undefined","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}]," approach with the module federation."]}]}],["$","p",null,{"children":["The circular dependency chains such as ",["$","code",null,{"children":"lib A -> lib B -> lib C -> lib A"}]," are also not allowed. The self circular dependency (when lib imports from a named alias of itself), while not recommended, can be overridden by setting the flag ",["$","code",null,{"children":"allowCircularSelfDependency"}]," to true."]}],["$","$Ld",null,{"language":"json5","fileName":".eslintrc.json","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"// ... more ESLint config here\n\n\"@nrwl/nx/enforce-module-boundaries\": [\n  \"error\",\n  {\n    \"allowCircularSelfDependency\": true,\n    \"depConstraints\": [\n      // ...list of constraints\n    ]\n  }\n]\n\n// ... more ESLint config here\n"}],["$","p",null,{"children":["Finally, the flag ",["$","code",null,{"children":"enforceBuildableLibDependency"}]," prevents us from importing a non-buildable library into a buildable one. You can read more on what buildable libraries are used for in ",["$","$Lb",null,{"prefetch":false,"href":"/concepts/buildable-and-publishable-libraries","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"our docs","target":"$undefined","rel":"$undefined","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}],"."]}],["$","h2",null,{"id":"using-tags-to-enforce-boundaries","className":"group scroll-mt-20","children":["Using tags to enforce boundaries",["$","$Lb",null,{"aria-hidden":"true","href":"#using-tags-to-enforce-boundaries","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":"To best express the need for the boundaries and assist us through the explanation, we will be using the repository represented by the following graph:"}],["$","p",null,{"children":[["$","img",null,{"src":"/documentation/blog/images/2021-12-17/z3ap5kyCXG4p8bcBQXx9tA.avif","alt":"","loading":"lazy"}]," ",["$","em",null,{"children":"The graph representation of the repository"}]]}],["$","p",null,{"children":"Our repository consists of two applications — Store and Admin. Each of them is composed of several feature libraries — Products (for Store), Sales, and Invoices (for Admin). Also, both of these applications depend on the Core library, and every project in our repo depends on our Shared library. Using common sense, we would like to enforce certain boundaries:"}],["$","ul",null,{"children":[["$","li",null,{"children":"A shared or core library should not be able to depend on a feature library"}],["$","li",null,{"children":"A feature library can depend on another feature library or a shared library"}]]}],["$","p",null,{"children":["First, we will use the project configuration to annotate our projects with ",["$","code",null,{"children":"tags"}],"."]}],["$","ul",null,{"children":["$","li",null,{"children":["Tags used to live in ",["$","code",null,{"children":"nx.json"}]," but were in the recent version moved closer to the project, so you can locate them now in your ",["$","code",null,{"children":"project.json"}]," or ",["$","code",null,{"children":"workspace.json"}]]}]}],["$","p",null,{"children":"Let's define the types of projects. We will use the following tags:"}],["$","ul",null,{"children":[["$","li",null,{"children":[["$","code",null,{"children":"type:app"}]," for application"]}],["$","li",null,{"children":[["$","code",null,{"children":"type:feature"}]," for feature library"]}],["$","li",null,{"children":[["$","code",null,{"children":"type:util"}]," for utility library"]}]]}],["$","p",null,{"children":"Your changed project configuration should now have the tags section defined."}],["$","$Ld",null,{"language":"json5","fileName":"project.json","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"{\n  // ... more project configuration here\n\n  tags: ['type:app'],\n}\n"}],["$","p",null,{"children":"Your enhanced graph will now look similar to this:"}],["$","p",null,{"children":[["$","img",null,{"src":"/documentation/blog/images/2021-12-17/kTiRazA4qhZ7kD-lGgGyjg.avif","alt":"","loading":"lazy"}]," ",["$","em",null,{"children":"Graph with type tags set"}]]}],["$","p",null,{"children":["The above list of library types is not complete. You might add specific ones for E2E projects or UI component libraries. Using the naming format ",["$","code",null,{"children":"type:*"}]," is just a suggestion. Consider this being a hashtag on your favorite social app. You can use any prefix or format you feel fitting. The important thing is that it's readable and intuitive to all the members of your team."]}],["$","p",null,{"children":["Now, that we have marked all of our projects, we can continue to define the rules in the root ",["$","code",null,{"children":".eslintrc.json."}]]}],["$","$Ld",null,{"language":"json5","fileName":".eslintrc.json","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"{\n  // ... more ESLint config here\n\n  '@nrwl/nx/enforce-module-boundaries': [\n    'error',\n    {\n      // update depConstraints based on your tags\n      depConstraints: [\n        {\n          sourceTag: 'type:app',\n          onlyDependOnLibsWithTags: ['type:feature', 'type:util'],\n        },\n        {\n          sourceTag: 'type:feature',\n          onlyDependOnLibsWithTags: ['type:feature', 'type:util'],\n        },\n        {\n          sourceTag: 'type:util',\n          onlyDependOnLibsWithTags: ['type:util'],\n        },\n      ],\n    },\n  ],\n\n  // ... more ESLint config here\n}\n"}],["$","h2",null,{"id":"adding-a-second-dimension","className":"group scroll-mt-20","children":["Adding a second dimension",["$","$Lb",null,{"aria-hidden":"true","href":"#adding-a-second-dimension","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":["We said that a feature library can depend on any other feature library, but there is a small catch. Our two apps could be built with a different framework so mixing feature libraries would not be possible. To avoid any future impediments, we don't want to allow a feature library used in ",["$","code",null,{"children":"Store"}]," to depend on the feature library from ",["$","code",null,{"children":"Admin"}]," and vice versa. Additionally, only our apps should be able to load the ",["$","code",null,{"children":"Core"}]," library."]}],["$","p",null,{"children":[["$","img",null,{"src":"/documentation/blog/images/2021-12-17/mr_MbGgWVbBcfBhss0hNqA.avif","alt":"","loading":"lazy"}]," ",["$","em",null,{"children":"Project graph with type tags and technology badges"}]]}],["$","p",null,{"children":"Let's add another dimension to allow such restrictions. We will define the necessary scope tags:"}],["$","ul",null,{"children":[["$","li",null,{"children":[["$","code",null,{"children":"scope:store"}]," for store app-related projects"]}],["$","li",null,{"children":[["$","code",null,{"children":"scope:admin"}]," for admin app related projects"]}],["$","li",null,{"children":[["$","code",null,{"children":"scope:shared"}]," for shared projects"]}],["$","li",null,{"children":[["$","code",null,{"children":"scope:core"}]," for core projects"]}]]}],["$","p",null,{"children":"Our diagram should now look like this:"}],["$","p",null,{"children":[["$","img",null,{"src":"/documentation/blog/images/2021-12-17/KeO1ZnEkUtmS2uj8M2rqKA.avif","alt":"","loading":"lazy"}]," ",["$","em",null,{"children":"Full project graph with two-dimensional tags"}]]}],["$","p",null,{"children":"Let us now define our missing rules!"}],["$","$Ld",null,{"language":"json5","fileName":".eslintrc.json","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"{\n  // ... more ESLint config here\n\n  '@nrwl/nx/enforce-module-boundaries': [\n    'error',\n    {\n      // update depConstraints based on your tags\n      depConstraints: [\n        // ...previous project type related rules\n        {\n          sourceTag: 'scope:store',\n          onlyDependOnLibsWithTags: [\n            'scope:store',\n            'scope:shared',\n            'scope:core',\n          ],\n        },\n        {\n          sourceTag: 'scope:admin',\n          onlyDependOnLibsWithTags: [\n            'scope:admin',\n            'scope:shared',\n            'scope:core',\n          ],\n        },\n        {\n          sourceTag: 'scope:core',\n          onlyDependOnLibsWithTags: ['scope:shared'],\n        },\n        {\n          sourceTag: 'scope:shared',\n          onlyDependOnLibsWithTags: ['scope:shared'],\n        },\n      ],\n    },\n  ],\n\n  // ... more ESLint config here\n}\n"}],["$","h2",null,{"id":"finegrained-external-dependencies","className":"group scroll-mt-20","children":["Fine-grained external dependencies",["$","$Lb",null,{"aria-hidden":"true","href":"#finegrained-external-dependencies","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":["You may want to constrain what external packages a project may import. In our example above, we want to make sure projects in the ",["$","code",null,{"children":"scope:store"}]," does not import any angular packages, and projects from the ",["$","code",null,{"children":"scope:admin"}]," do not import any react library. You can ban these imports using ",["$","code",null,{"children":"bannedExternalImports"}]," property in your dependency constraints configuration."]}],["$","p",null,{"children":"We can now enhance our rule configuration by providing additional information."}],["$","$Ld",null,{"language":"json5","fileName":".eslintrc.json","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"$e"}],["$","p",null,{"children":["Using the wildcard ",["$","code",null,{"children":"*"}]," to match multiple projects e.g. ",["$","code",null,{"children":"react*"}]," we can save ourselves the effort of manually specifying every single project we want to ban."]}],["$","h2",null,{"id":"restricting-transitive-dependencies","className":"group scroll-mt-20","children":["Restricting transitive dependencies",["$","$Lb",null,{"aria-hidden":"true","href":"#restricting-transitive-dependencies","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":["Our solution doesn't contain only internal projects but also depends on various external NPM packages. These external dependencies are explicitly declared in our ",["$","code",null,{"children":"package.json"}],". Unfortunately, a package is rarely an island. They often consist of a tree of transitive dependencies branching out leading to thousands of packages being installed in your ",["$","code",null,{"children":"node_modules"}]," folder. Although we have control over what version or which direct dependency we install, we have no control over what versions of what packages this dependency depends on. The transitive dependencies are often the source of our app's vulnerabilities. We can also never guarantee those dependencies will be there. Just by simply running ",["$","code",null,{"children":"npm install"}]," parent may get updated to a patch or minor version that would wipe out one of the transitive dependencies or replace it with one with breaking changes."]}],["$","p",null,{"children":"Therefore it's wise not to allow developers to import transitive dependencies in their projects. Our ESLint plugin provides a simple flag to turn this restriction on."}],["$","$Ld",null,{"language":"json5","fileName":".eslintrc.json","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"{\n  // ... more ESLint config here\n\n  '@nrwl/nx/enforce-module-boundaries': [\n    'error',\n    {\n      // ... more rule config here\n      banTransitiveDependencies: true,\n    },\n  ],\n\n  // ... more ESLint config here\n}\n"}],["$","p",null,{"children":"If you now try to import a transitive dependency, your linter responds with an error. This flag is disabled by default for now, but we highly recommend you enable it."}],["$","h2",null,{"id":"overriding-the-overrides","className":"group scroll-mt-20","children":["Overriding the overrides",["$","$Lb",null,{"aria-hidden":"true","href":"#overriding-the-overrides","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":"Sometimes, we just need to override this configuration for a given project. The scenario for this might be testing or during the development, if we are unsure yet how a certain project will be tagged. While we strongly encourage you to plan your architecture carefully and never override the boundaries configuration, you still have an option to bale out and override it."}],["$","$Ld",null,{"language":"json5","fileName":".eslintrc.json","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"{\n  // ... default ESLint config here\n\n  overrides: [\n    {\n      files: ['*.ts', '*.tsx', '*.js', '*.jsx'],\n      rules: {\n        '@nrwl/nx/enforce-module-boundaries': [\n          'error',\n          {\n            // ignore any checks for these projects for now\n            allow: ['a-wip-project', 'this-one-is-broken-so-ignore-it'],\n            depConstraints: [\n              // ...dependency constraints here\n            ],\n          },\n        ],\n      },\n    },\n\n    // ... more ESLint overrides here\n  ],\n}\n"}],["$","h2",null,{"id":"summary","className":"group scroll-mt-20","children":["Summary",["$","$Lb",null,{"aria-hidden":"true","href":"#summary","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":"Monorepos are often viewed only from the technical side, but they also bring a shift in human resources organization. Teams that were once isolated, now have to work together on the same solution."}],["$","p",null,{"children":"Having a clean separation of concerns and well-defined cohesive units helps us scale our organization more easily and gives us more confidence in our architecture. not only does Nx provide tools to speed up the overall performance, but it provides tooling to enforce the organizational constraints in an automated way."}],["$","p",null,{"children":"In this post, we listed several strategies which you can use to restrict your packages from being misused or use unplanned external resources. Use them thoroughly and on time, before things go out of hand."}],["$","blockquote",null,{"children":["$","p",null,{"children":["Prefer a visual presentation over text? Then check out this talk recording by Juri Strumpflohner: ",["$","$Lb",null,{"prefetch":false,"href":"https://www.youtube.com/watch?v=pER_Ak1yUaA&t=687s","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"https://www.youtube.com/watch?v=pER_Ak1yUaA&t=687s","target":"_blank","rel":"noreferrer","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}]]}]}]]}]}]]}],["$","div",null,{"className":"hidden xl:block","children":["$","div",null,{"className":"sticky top-24"}]}]]}]}],["$","section",null,{"className":"mt-24 border-b border-t border-slate-200 bg-slate-50 py-24 sm:py-32 dark:border-slate-800 dark:bg-slate-900","children":["$","div",null,{"className":"mx-auto max-w-7xl px-4 sm:px-6 lg:px-8","children":["$","div",null,{"className":"mx-auto max-w-2xl lg:mx-0 lg:max-w-none","children":[["$","h2",null,{"className":"mb-8 flex items-center gap-3 text-2xl font-semibold text-slate-900 dark:text-white","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"h-7 w-7","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0ZM3.75 12h.007v.008H3.75V12Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm-.375 5.25h.007v.008H3.75v-.008Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"}]]}],"More Articles"]}],["$","div",null,{"className":"md:hidden","children":["$","div",null,{"className":"mx-auto","children":[["$","$Lb","nx-made-cursor-smarter",{"href":"/blog/nx-made-cursor-smarter","className":"relative flex items-center gap-6 border-b border-slate
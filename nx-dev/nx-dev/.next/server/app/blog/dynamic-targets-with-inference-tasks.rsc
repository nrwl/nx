get":"_blank","rel":"noreferrer","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}],". Nicolas is an experienced Staff Engineer at PayFit and believer in open source. He is passionate about improving the DX on large monorepo thought architecture and tooling to empower others to shine brighter. With his experience spanning from DevOps, to backend and frontend, he likes to share his knowledge through teaching at his local university and online. In his free time, when he's not running some experiments, he's probably playing board games, tweaking his home server, or looking over his gemstone collection. You can find him on ",["$","$Lb",null,{"prefetch":false,"href":"https://x.com/beaussan","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"X/Twitter","target":"_blank","rel":"noreferrer","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}],", ",["$","$Lb",null,{"prefetch":false,"href":"https://bsky.app/profile/beaussan.io","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"Bluesky","target":"_blank","rel":"noreferrer","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}],", and ",["$","$Lb",null,{"prefetch":false,"href":"https://github.com/beaussan","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"GitHub","target":"_blank","rel":"noreferrer","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}],"."]}]}],["$","p",null,{"children":"Ever tried juggling multiple Storybook instances in a monorepo, only to face port conflicts? It's like trying to fit several square pegs into the same round hole. But what if I told you there's a way to give each project its own unique port, automatically? Enter Nx's task inference feature – the beacon of hope for our monorepo Storybook aspirations."}],["$","p",null,{"children":"Want to skip to the code?"}],["$","div",null,{"className":"not-prose group relative mx-auto my-12 flex w-full max-w-md items-center gap-3 overflow-hidden rounded-lg bg-slate-50 shadow-md transition hover:text-white dark:bg-slate-800/60","children":[["$","div",null,{"className":"absolute inset-0 z-0 w-2 bg-blue-500 transition-all duration-150 group-hover:w-full dark:bg-sky-500"}],["$","div",null,{"className":"w-2 bg-blue-500 dark:bg-sky-500"}],["$","div",null,{"className":"z-10 flex flex-grow items-center py-3","children":[["$","svg",null,{"className":"h-10 w-10 rounded-full object-cover","viewBox":"0 0 16 16","fill":"currentColor","children":["$","path",null,{"fillRule":"evenodd","d":"M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"}]}],["$","div",null,{"className":"mx-3","children":["$","p",null,{"children":["Jump to the code",["$","a",null,{"href":"https://github.com/juristr/dynamic-storybook-targets","target":"_blank","rel":"noreferrer","className":"block text-sm font-medium opacity-80","children":[["$","span",null,{"className":"absolute inset-0","aria-hidden":"true"}],"/juristr/dynamic-storybook-targets"]}]]}]}]]}],["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mr-4 h-6 w-6 transition-all group-hover:translate-x-3","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"m8.25 4.5 7.5 7.5-7.5 7.5"}]]}]]}],["$","h2",null,{"id":"the-problem","className":"group scroll-mt-20","children":["The problem",["$","$Lb",null,{"aria-hidden":"true","href":"#the-problem","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":"Consider the following setup:"}],["$","$Le",null,{"language":"json","fileName":"packages/buttons/package.json","highlightLines":[8],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"{\n  \"name\": \"@design-system/buttons\",\n  ...\n  \"scripts\": {\n    ...\n    \"storybook\": \"storybook dev\",\n    \"build-storybook\": \"storybook build\",\n    \"test-storybook\": \"start-server-and-test 'storybook dev --port 3000 --no-open' http://localhost:3000 'test-storybook --index-json --url=http://localhost:3000'\"\n  },\n  ...\n}\n"}],["$","p",null,{"children":["For each package in your monorepo, you have a ",["$","code",null,{"children":"test-storybook"}]," script that runs the Storybook test runner for that specific package. Now if you want to run them all in parallel (which you definitely should on CI), you will quickly run into port conflicts:"]}],["$","p",null,{"children":["$","img",null,{"src":"/documentation/blog/images/articles/storybook-port-clashes.avif","alt":"","loading":"lazy"}]}],["$","p",null,{"children":"To fix it, you can manually assign different ports to each package. But not only is this annoying but it also won't scale."}],["$","h2",null,{"id":"the-power-of-createnodes","className":"group scroll-mt-20","children":["The power of createNodes",["$","$Lb",null,{"aria-hidden":"true","href":"#the-power-of-createnodes","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":"The createNodes feature in Nx is a game-changer for creating inferences on projects. Today, we're diving into how we can leverage this to create dynamic Storybook targets with unique ports across our entire monorepo."}],["$","p",null,{"children":"Why is this important? Well, imagine running multiple dev servers, test environments, and Storybook instances without worrying about port clashes. It's not just convenient – it's a productivity booster!"}],["$","h2",null,{"id":"creating-a-workspace-inference-plugin","className":"group scroll-mt-20","children":["Creating a workspace inference plugin",["$","$Lb",null,{"aria-hidden":"true","href":"#creating-a-workspace-inference-plugin","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":["To make this magic happen, we need to create a workspace plugin. Here's how: first, we create a new file for your plugin (eg ",["$","code",null,{"children":"tools/storybook.ts"}],"). In this file, we will define the base of our inference:"]}],["$","$Le",null,{"language":"ts","fileName":"tools/storybook.ts","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"import { CreateNodesV2 } from '@nx/devkit';\n\nexport const createNodesV2: CreateNodesV2 = [\n  '**/.storybook/main.{js,ts,mjs,mts,cjs,cts}',\n  async (configFiles, options, context) => {\n    return [];\n  },\n];\n"}],["$","p",null,{"children":["Here, we can see the ",["$","code",null,{"children":"createNodesV2"}]," is an array, the first element being the entry point for our inference. In this case, we're looking for files with the ",["$","code",null,{"children":".storybook/main.{js,ts,mjs,mts,cjs,cts}"}]," pattern as we want to capture all the Storybook configurations in our monorepo."]}],["$","p",null,{"children":["The second element is a function that will be called with the matching files. ",["$","code",null,{"children":"configFiles"}]," is an array of all the files found that matches the glob. This is where we can get creative with our dynamic configuration."]}],["$","p",null,{"children":["Finally, to be able to use it, you need to update your ",["$","code",null,{"children":"nx.json"}]," file to include the plugin:"]}],["$","$Le",null,{"language":"json","fileName":"nx.json","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"{\n  \"plugins\": [\"./tools/storybook\"]\n}\n"}],["$","p",null,{"children":["To see whether you plugin loaded properly you can go to ",["$","code",null,{"children":".nx/workspace-data/d/daemon.log"}]," and search for your plugin name. Behind the scenes the ",["$","$Lb",null,{"prefetch":false,"href":"/concepts/nx-daemon","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"Nx Daemon","target":"$undefined","rel":"$undefined","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}]," re-calculates the project graph and loads all plugins, including ours."]}],["$","$Ld",null,{"type":"info","title":"TypeScript configuration","expanded":false,"children":["$","p",null,{"children":["Make sure you have some ",["$","code",null,{"children":"tsconfig.json"}]," file in the monorepo root. Nx loads the plugin dynamically (without you having to precompile it) which requires some TypeScript context to be present. ",["$","$Lb",null,{"prefetch":false,"href":"https://github.com/juristr/dynamic-storybook-targets/blob/main/tsconfig.base.json","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"Have a look at the repo setup","target":"_blank","rel":"noreferrer","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}],"."]}]}],["$","h2",null,{"id":"dynamic-projects-creation","className":"group scroll-mt-20","children":["Dynamic projects creation",["$","$Lb",null,{"aria-hidden":"true","href":"#dynamic-projects-creation","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":"Now comes the fun part – dynamically creating project.json configurations. A static configuration of Storybook for your project might look as follows:"}],["$","$Le",null,{"language":"json","fileName":"packages/somelib/project.json","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"{\n  \"targets\": {\n    \"storybook\": {\n      \"command\": \"storybook dev --port 3000\",\n      ...\n    }\n  }\n}\n"}],["$","p",null,{"children":["We want to make the ",["$","code",null,{"children":"--port 3000"}]," part dynamic, so we can run multiple Storybook instances in parallel."]}],["$","p",null,{"children":"Here's the gist of what we're doing:"}],["$","ul",null,{"children":[["$","li",null,{"children":"Loop over the config files"}],["$","li",null,{"children":"Create one project per config file found"}]]}],["$","p",null,{"children":["To do this, we will extract code from the ",["$","$Lb",null,{"prefetch":false,"href":"https://github.com/nrwl/nx/blob/fb403661802a3500299d6f11ecc888117188b92b/packages/nx/src/project-graph/plugins/utils.ts#L13-L30","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"Nx codebase","target":"_blank","rel":"noreferrer","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}]," to add our dynamic index to our function:"]}],["$","$Le",null,{"language":"ts","fileName":"tools/storybook.ts","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"$f"}],["$","p",null,{"children":["If you look closely, you will see that we construct our port based on the ",["$","code",null,{"children":"index"}]," of the file. This is where we can generate unique ports for each project."]}],["$","$Le",null,{"language":"ts","fileName":"tools/storybook.ts","highlightLines":[4],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"configFiles.map(async (file, index) => {\n  try {\n    // create a dynamic port for each file\n    const value = processFile(file, context, 3000 + index);\n    ...\n  } catch (e) {\n    errors.push([file, e as Error] as const);\n  }\n})\n"}],["$","p",null,{"children":["We're using the ",["$","code",null,{"children":"index"}]," to generate unique ports. Project 1 gets port 3000, project 2 gets 3001, and so on. It's simple, but effective."]}],["$","p",null,{"children":"Now, we can process our files to actually create targets:"}],["$","$Le",null,{"language":"ts","fileName":"","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"$10"}],["$","h2",null,{"id":"reaping-the-benefits","className":"group scroll-mt-20","children":["Reaping the benefits",["$","$Lb",null,{"aria-hidden":"true","href":"#reaping-the-benefits","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":"With this setup, we can now:"}],["$","ul",null,{"children":[["$","li",null,{"children":"Run concurrent Storybook instances without conflicts"}],["$","li",null,{"children":"Have consistent ports within each project"}],["$","li",null,{"children":"Easily spin up dev servers and test environments on matching ports"}]]}],["$","p",null,{"children":"And the best part? It just works. Running a graph inspection on your projects will show each one with its unique port, ready for action."}],["$","p",null,{"children":["Do you want to see it in action? ",["$","$Lb",null,{"prefetch":false,"href":"https://github.com/beaussan/nx-storybook-dynamic-ports","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"Check out the repo","target":"_blank","rel":"noreferrer","className":"text-blue-600 transition-colors ease-out hover:text-blue-700 dark:text-sky-500 dark:hover:text-sky-400"}],", and run the following commands:"]}],["$","$Le",null,{"language":"shell","fileName":"","highlightLines":[],"lineGroups":{},"command":"","title":"","path":"","skipRescope":false,"enableCopy":true,"lineWrap":0,"children":"npm install\nnpm run nx run-many -t test-storybook\n"}],["$","p",null,{"children":"And it will run all the tests in all the projects, with the matching ports, without any conflicts!"}],["$","h2",null,{"id":"looking-ahead-the-infinite-task-proposal","className":"group scroll-mt-20","children":["Looking ahead: The infinite task proposal",["$","$Lb",null,{"aria-hidden":"true","href":"#looking-ahead-the-infinite-task-proposal","children":["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","fill":"none","viewBox":"0 0 24 24","strokeWidth":1.5,"stroke":"currentColor","aria-hidden":"true","data-slot":"icon","aria-labelledby":"$undefined","className":"mb-1 ml-2 inline h-5 w-5 opacity-0 group-hover:opacity-100","children":[null,["$","path",null,{"strokeLinecap":"round","strokeLinejoin":"round","d":"M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244"}]]}]}]]}],["$","p",null,{"children":["While our current setup is pretty slick, the future looks even brighter. In our example, we had to rely on ",["$","code",null,{"children":"start-server-and-test"}]," ",["$","$Lb",null,{"prefetch":false,"href":"https://www.npmjs.com/package/start-server-and-test","passHref":true,"replace":false,"scroll":true,"shallow":false,"children":"package","target":"_blank","rel":"nor
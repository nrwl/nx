-federation-deployments.png","ogImageType":"png","filePath":"public/documentation/blog/2024-09-12-next-gen-module-federation-deployments.md","slug":"next-gen-module-federation-deployment","youtubeUrl":"$undefined","registrationUrl":"$undefined","podcastYoutubeId":"$undefined","podcastSpotifyId":"$undefined","podcastIHeartUrl":"$undefined","podcastAppleUrl":"$undefined","podcastAmazonUrl":"$undefined","published":true,"metrics":"$undefined"},{"content":"$40","title":"Better security with Personal Access Tokens","description":"Introducing Personal Access Tokens in Nx Cloud, a major security upgrade that provides enhanced control over cached artifacts access.","authors":["$1f"],"eventDate":"2024-09-10T21:20:25.064Z","date":"2024-09-10T21:20:25.064Z","time":"$undefined","status":"$undefined","cover_image":"/documentation/blog/images/2024-09-10/personal-access-tokens-header.avif","tags":["nx-cloud"],"reposts":[],"pinned":false,"ogImage":"documentation/blog/images/2024-09-10/personal-access-tokens-header.png","ogImageType":"png","filePath":"public/documentation/blog/2024-09-10-personal-access-tokens.md","slug":"personal-access-tokens","youtubeUrl":"https://youtu.be/i51LPtagb2s","registrationUrl":"$undefined","podcastYoutubeId":"$undefined","podcastSpotifyId":"$undefined","podcastIHeartUrl":"$undefined","podcastAppleUrl":"$undefined","podcastAmazonUrl":"$undefined","published":true,"metrics":"$undefined"},{"content":"---\ntitle: Introduction to Nx! | Nx Live\nslug: nx-live-intro-to-nx\nauthors: ['Zack DeRose', 'Mike Hartington']\ntags: [livestream]\ncover_image: /blog/images/2024-09-05/thumbnail.png\nyoutubeUrl: https://youtube.com/live/dgtZ6GHZ-tA\ndescription: Watch a live coding session where Zack guides Mike through building a full-stack app with Nx, showcasing key features and best practices.\n---\n\nIn this episode of Nx Live, Zack introduces new Nx team member Mike Hartington to the value of Nx. Together, Zack and Mike build out a full-stack application in their workspace - complete with linting, testing, and end-to-end tests using Nx's generators, and they look at the capabilities that Nx offers in terms of defining their workspace, and how Nx can leverage that information for task-running - especially in CI!\n","title":"Introduction to Nx! | Nx Live","description":"Watch a live coding session where Zack guides Mike through building a full-stack app with Nx, showcasing key features and best practices.","authors":["$2b","$30"],"eventDate":"2024-09-05T21:20:25.063Z","date":"2024-09-05T21:20:25.063Z","time":"$undefined","status":"$undefined","cover_image":"/documentation/blog/images/2024-09-05/thumbnail.png","tags":["livestream"],"reposts":[],"pinned":false,"ogImage":"documentation/blog/images/2024-09-05/thumbnail.png","ogImageType":"png","filePath":"public/documentation/blog/2024-09-05-nx-live-introduction-to-nx.md","slug":"nx-live-intro-to-nx","youtubeUrl":"https://youtube.com/live/dgtZ6GHZ-tA","registrationUrl":"$undefined","podcastYoutubeId":"$undefined","podcastSpotifyId":"$undefined","podcastIHeartUrl":"$undefined","podcastAppleUrl":"$undefined","podcastAmazonUrl":"$undefined","published":true,"metrics":"$undefined"},{"content":"$41","title":"Announcing your Monorepo World Speakers","description":"Meet the first round of Monorepo World speakers, including experts from Zephyr Cloud, Atlassian, GitHub, and HeroDevs, discussing bundlers, dependency graphs, and monorepo best practices.","authors":["$30"],"eventDate":"2024-08-30T21:20:25.063Z","date":"2024-08-30T21:20:25.063Z","time":"$undefined","status":"$undefined","cover_image":"/documentation/blog/images/2024-08-30/mw-blog-post.avif","tags":["monorepo-world"],"reposts":[],"pinned":false,"ogImage":"documentation/blog/images/2024-08-30/mw-blog-post.png","ogImageType":"png","filePath":"public/documentation/blog/2024-08-30-announcing-your-monorepo-world-speakers.md","slug":"announcing-your-monorepo-world-speakers","youtubeUrl":"$undefined","registrationUrl":"$undefined","podcastYoutubeId":"$undefined","podcastSpotifyId":"$undefined","podcastIHeartUrl":"$undefined","podcastAppleUrl":"$undefined","podcastAmazonUrl":"$undefined","published":true,"metrics":"$undefined"},{"content":"---\ntitle: How to Fast-Track Your PRs with Trunk.io | Nx Live\nslug: nx-live-trunk-io\nauthors: ['Zack DeRose']\ntags: [livestream]\ncover_image: /blog/images/2024-08-29/nx-live-trunk.png\nyoutubeUrl: https://youtube.com/live/E8Gh-Vkxok0\ndescription: Live demo with Trunk.io's David on optimizing PR workflows using Nx and Trunk Merge Queues, featuring first-class Nx support for improved dev efficiency.\n---\n\nIn this episode of Nx Live, Zack sits down with David from [Trunk.io](https://trunk.io) to explore hands-on examples of how to fast-track your PRs using Nx and Trunk Merge Queues. They also discuss the latest [first-class support for Nx](https://docs.trunk.io/merge-queue/parallel-queues/nx) recently added to Trunk, demonstrating how these tools can streamline your development workflow.\n","title":"How to Fast-Track Your PRs with Trunk.io | Nx Live","description":"Live demo with Trunk.io's David on optimizing PR workflows using Nx and Trunk Merge Queues, featuring first-class Nx support for improved dev efficiency.","authors":["$2b"],"eventDate":"2024-08-29T21:20:25.063Z","date":"2024-08-29T21:20:25.063Z","time":"$undefined","status":"$undefined","cover_image":"/documentation/blog/images/2024-08-29/nx-live-trunk.png","tags":["livestream"],"reposts":[],"pinned":false,"ogImage":"documentation/blog/images/2024-08-29/nx-live-trunk.png","ogImageType":"png","filePath":"public/documentation/blog/2024-08-29-nx-live-with-trunk.md","slug":"nx-live-trunk-io","youtubeUrl":"https://youtube.com/live/E8Gh-Vkxok0","registrationUrl":"$undefined","podcastYoutubeId":"$undefined","podcastSpotifyId":"$undefined","podcastIHeartUrl":"$undefined","podcastAppleUrl":"$undefined","podcastAmazonUrl":"$undefined","published":true,"metrics":"$undefined"},{"content":"$42","title":"New Table Log View on CI with Nx Cloud","description":"Nx Cloud introduces a structured table view for CI logs, enhancing monorepo task tracking and visibility.","authors":["$e"],"eventDate":"2024-08-28T21:20:25.062Z","date":"2024-08-28T21:20:25.062Z","time":"$undefined","status":"$undefined","cover_image":"/documentation/blog/images/2024-08/nx-cloud-table-log-output-thumb.jpg","tags":["nx-cloud","release"],"reposts":[],"pinned":false,"ogImage":"documentation/blog/images/2024-08/nx-cloud-table-log-output-thumb.jpg","ogImageType":"jpg","filePath":"public/documentation/blog/2024-08-28-nxcloud-improved-ci-log.md","slug":"improved-ci-log-with-nx-cloud","youtubeUrl":"https://youtu.be/aacrw0H0m4Q","registrationUrl":"$undefined","podcastYoutubeId":"$undefined","podcastSpotifyId":"$undefined","podcastIHeartUrl":"$undefined","podcastAppleUrl":"$undefined","podcastAmazonUrl":"$undefined","published":true,"metrics":"$undefined"},{"content":"$43","title":"Nx Enterprise Podcast Episode 4: Cvent Platform Architecture Panel","description":"Discover how Cvent's Platform Architects leverage Nx in their platform engineering strategy to empower teams across their organization.","authors":["$2b"],"eventDate":"2024-08-21T21:20:25.062Z","date":"2024-08-21T21:20:25.062Z","time":"$undefined","status":"$undefined","cover_image":"/documentation/blog/images/2024-08-21/ep-4-cvent.png","tags":["podcast"],"reposts":[],"pinned":false,"ogImage":"documentation/blog/images/2024-08-21/ep-4-cvent.png","ogImageType":"png","filePath":"public/documentation/blog/2024-08-21-podcast-epsiode-4-cvent.md","slug":"cvent-podcast-3","youtubeUrl":"$undefined","registrationUrl":"$undefined","podcastYoutubeId":"_7uK1V_xu9k","podcastSpotifyId":"1zWuMFxcnGy90AN41gkodx","podcastIHeartUrl":"https://www.iheart.com/podcast/269-the-enterprise-software-po-186891508/episode/the-enterprise-software-podcast-by-nx-207751657/","podcastAppleUrl":"https://podcasts.apple.com/us/podcast/the-enterprise-software-podcast-by-nx-4-cvent/id1752704996?i=1000666133320","podcastAmazonUrl":"https://music.amazon.com/podcasts/a221fdad-36fd-4695-a5b4-038d7b99d284/episodes/7e19eb25-76f9-4d1e-89c0-c2fd1f585f9b/the-enterprise-software-podcast-by-nx-the-enterprise-software-podcast-by-nx-4-cvent-platform-architect-panel","published":true,"metrics":"$undefined"},{"content":"$44","title":"Nx Enterprise Podcast Episode 3: Ahmed Elsakaan","description":"Join Nx Champion Ahmed Elsakaan as he discusses his tools noodle and OrbitKit, exploring how they improve monorepo setup and module creation.","authors":["$2b"],"eventDate":"2024-08-14T21:20:25.062Z","date":"2024-08-14T21:20:25.062Z","time":"$undefined","status":"$undefined","cover_image":"/documentation/blog/images/2024-08-14/ep-3-ahmed.png","tags":["podcast"],"reposts":[],"pinned":false,"ogImage":"documentation/blog/images/2024-08-14/ep-3-ahmed.png","ogImageType":"png","filePath":"public/documentation/blog/2024-08-14-podcast-episode-3-ahmed-elsakaan.md","slug":"ahmed-elsakaan-podcast-3","youtubeUrl":"$undefined","registrationUrl":"$undefined","podcastYoutubeId":"l_b6EOXqYRg","podcastSpotifyId":"4d4oE8B3y9BmECZ3P4uvDP","podcastIHeartUrl":"https://www.iheart.com/podcast/269-the-enterprise-software-po-186891508/episode/the-enterprise-software-podcast-by-nx-205664230/","podcastAppleUrl":"https://podcasts.apple.com/us/podcast/the-enterprise-software-podcast-by-nx-3-ahmed-elsakaan/id1752704996?i=1000665363260","podcastAmazonUrl":"https://music.amazon.com/podcasts/a221fdad-36fd-4695-a5b4-038d7b99d284/episodes/28209cf9-1b88-48b5-a798-7b24c843e9b1/the-enterprise-software-podcast-by-nx-the-enterprise-software-podcast-by-nx-3-ahmed-elsakaan","published":true,"metrics":"$undefined"},{"content":"$45","title":"Nx 19.5 is here! Stackblitz, Bun, Incremental Builds for Vite, Gradle Test Atomizer","description":"Nx 19.5 brings StackBlitz support, Bun and Pnpm v9 compatibility, local flaky task detection, and more.","authors":["$2b"],"eventDate":"2024-08-01T21:20:25.061Z","date":"2024-08-01T21:20:25.061Z","time":"$undefined","status":"$undefined","cover_image":"/documentation/blog/images/2024-08-01/nx-19-5-thumbnail.png","tags":["nx","release"],"reposts":[],"pinned":false,"ogImage":"documentation/blog/images/2024-08-01/nx-19-5-thumbnail.png","ogImageType":"png","filePath":"public/documentation/blog/2024-08-01-nx-19-5-update.md","slug":"nx-19-5-adds-stackblitz-new-features-and-more","youtubeUrl":"$undefined","registrationUrl":"$undefined","podcastYoutubeId":"$undefined","podcastSpotifyId":"$undefined","podcastIHeartUrl":"$undefined","podcastAppleUrl":"$undefined","podcastAmazonUrl":"$undefined","published":true,"metrics":"$undefined"},{"content":"$46","title":"Introducing Explain with AI","description":"Explain with AI in Nx Cloud Pro helps debug CI failures with AI explanations and suggested fixes.","authors":["$1f"],"eventDate":"2024-07-29T21:20:25.059Z","date":"2024-07-29T21:20:25.059Z","time":"$undefined","status":"$undefined","cover_image":"/documentation/blog/images/2024-07-29/explain-with-ai-header.avif","tags":["nx","nx-cloud","ai","release"],"reposts":[],"pinned":false,"ogImage":"documentation/blog/images/2024-07-29/explain-with-ai-header.png","ogImageType":"png","filePath":"public/documentation/blog/2024-07-29-explain-with-ai.md","slug":"explain-with-ai","youtubeUrl":"https://youtu.be/g2m9cHp-O-Q?si=ax-SKCO0Xvy9vFIz","registrationUrl":"$undefined","podcastYoutubeId":"$undefined","podcastSpotifyId":"$undefined","podcastIHeartUrl":"$undefined","podcastAppleUrl":"$undefined","podcastAmazonUrl":"$undefined","published":true,"metrics":"$undefined"},{"content":"$47","title":"Nx Enterprise Podcast Episode 2: Tine Kondo","description":"Explore insights from Nx Champion Tine Kondo on monorepo benefits and the potential of Nx Gradle plugin for Java development.","authors":["$2b"],"eventDate":"2024-07-19T21:20:25.059Z","date":"2024-07-19T21:20:25.059Z","time":"$undefined","status":"$undefined","cover_image":"/documentation/blog/images/2024-07-19/ep-2-tine.png","tags":["podcast"],"reposts":[],"pinned":false,"ogImage":"documentation/blog/images/2024-07-19/ep-2-tine.png","ogImageType":"png","filePath":"public/documentation/blog/2024-07-19-podcast-episode-2-tine-kondo.md","slug":"tine-kondo-podcast-2","youtubeUrl":"$undefined","registrationUrl":"$undefined","podcastYoutubeId":"Nzf3BmymfEo","podcastSpotifyId":"0CCQaWCln7rvwkkVvsyxsk","podcastIHeartUrl":"https://www.iheart.com/podcast/269-the-enterprise-software-po-186891508/episode/the-enterprise-software-podcast-by-nx-197335640/","podcastAppleUrl":"https://podcasts.apple.com/us/podcast/the-enterprise-software-podcast-by-nx-2-tine-kondo/id1752704996?i=1000662764990","podcastAmazonUrl":"https://music.amazon.com/podcasts/a221fdad-36fd-4695-a5b4-038d7b99d284/episodes/53934cd9-c521-441e-8523-8b947ed207ca/the-enterprise-software-podcast-by-nx-the-enterprise-software-podcast-by-nx-2-tine-kondo","published":true,"metrics":"$undefined"},{"content":"$48","title":"Monorepos and CI can be a Mess - Here's How Nx and Nx Cloud Fixed It","description":"Continuous Integration (CI) in monorepos can be notoriously slow and unreliable, quickly become a bottleneck for scaling monorepos. Learn how Nx and Nx Cloud's new task-based approach ensures fast, resilient, and efficient CI for your monorepo projects.","authors":["$e"],"eventDate":"2024-06-26T21:20:25.059Z","date":"2024-06-26T21:20:25.059Z","time":"$undefined","status":"Past - Gated","cover_image":"/documentation/blog/images/2024-06-26/June-Webinar-card.png","tags":["webinar"],"reposts":[],"pinned":false,"ogImage":"documentation/blog/images/2024-06-26/June-Webinar-card.png","ogImageType":"png","filePath":"public/documentation/blog/2024-06-26-monorepos-and-ci-can-be-a-mess-heres-how-nx-and-nx-cloud-fixed-it.md","slug":"monorepos-and-ci-can-be-a-mess-heres-how-nx-and-nx-cloud-fixed-it","youtubeUrl":"$undefined","registrationUrl":"https://go.nx.dev/june-webinar","podcastYoutubeId":"$undefined","podcastSpotifyId":"$undefined","podcastIHeartUrl":"$undefined","podcastAppleUrl":"$undefined","podcastAmazonUrl":"$undefined","published":true,"metrics":"$undefined"},{"content":"$49","title":"Nx Enterprise Podcast Episode 1: Hicham El Hammouchi","description":"Join Zack DeRose as he discusses enterprise software development with veteran Hicham El Hammouchi, exploring challenges and emerging trends.","authors":["$2b"],"eventDate":"2024-06-18T21:20:25.058Z","date":"2024-06-18T21:20:25.058Z","time":"$undefined","status":"$undefined","cover_image":"/documentation/blog/images/2024-06-18/ep-1-hicham.png","tags":["podcast"],"reposts":[],"pinned":false,"ogImage":"documentation/blog/images/2024-06-18/ep-1-hicham.png","ogImageType":"png","filePath":"public/documentation/blog/2024-06-18-podcast-episode-1-hicham-el-hammouchi.md","slug":"hicham-el-hammouchi-podcast-1","youtubeUrl":"$undefined","registrationUrl":"$undefined","podcastYoutubeId":"8iiLB_2djZ8","podcastSpotifyId":"24yagCNpu9EGj0fCwSDQkj","podcastIHeartUrl":"https://www.iheart.com/podcast/269-the-enterprise-software-po-186891508/episode/the-enterprise-software-podcast-by-nx-186891511/","podcastAppleUrl":"https://podcasters.spotify.com/pod/show/enterprise-software/episodes/The-Enterprise-Software-Podcast-By-Nx-1--Hicham-El-Hamouchi-e2l0302","podcastAmazonUrl":"https://music.amazon.com/podcasts/a221fdad-36fd-4695-a5b4-038d7b99d284/episodes/899a2e4c-2e56-4dfa-a3e3-e69eb216f2b0/the-enterprise-software-podcast-by-nx-the-enterprise-software-podcast-by-nx-1-hicham-el-hamouchi","published":true,"metrics":"$undefined"},{"content":"$4a","title":"Nx 19.0 Release!!","description":"Explore Nx 19.0, returning to our six-month release cycle with enhanced Project Crystal plugins that work seamlessly with minimal configuration.","authors":["$2b"],"eventDate":"2024-05-08T21:20:25.058Z","date":"2024-05-08T21:20:25.058Z","time":"$undefined","status":"$undefined","cover_image":"/documentation/blog/images/2024-05-08/nx-19-thumbnail.png","tags":["nx","release"],"reposts":[],"pinned":false,"ogImage":"documentation/blog/images/2024-05-08/nx-19-thumbnail.png","ogImageType":"png","filePath":"public/documentation/blog/2024-05-08-nx-19-release.md","slug":"nx-19-release","youtubeUrl":"$undefined","registrationUrl":"$undefined","podcastYoutubeId":"$undefined","podcastSpotifyId":"$undefined","podcastIHeartUrl":"$undefined","podcastAppleUrl":"$undefined","podcastAmazonUrl":"$undefined","published":true,"metrics":"$undefined"},{"content":"$4b","title":"Manage Your Gradle Project using Nx","description":"Learn how to manage Gradle projects in Nx workspaces using the new @nx/gradle plugin for better library visualization and multi-tech stack support.","authors":[{"name":"Emily Xiong","image":"/blog/images/Emily Xiong.jpeg","twitter":"xiongemily","github":"xiongemi"}],"eventDate":"2024-04-19T21:20:25.055Z","date":"2024-04-19T21:20:25.055Z","time":"$undefined","status":"$undefined","cover_image":"/documentation/blog/images/2024-04-19/featured_img.png","tags":["nx","gradle","how-to"],"reposts":[],"pinned":false,"ogImage":"documentation/blog/images/2024-04-19/featured_img.png","ogImageType":"png","filePath":"public/documentation/blog/2024-04-19-manage-your-gradle.md","slug":"manage-your-gradle-project-using-nx","youtubeUrl":"$undefined","registrationUrl":"$undefined","podcastYoutubeId":"$undefined","podcastSpotifyId":"$undefined","podcastIHeartUrl":"$undefined","podcastAppleUrl":"$undefined","podcastAmazonUrl":"$undefined","published":true,"metrics":"$undefined"},{"content":"---\ntitle: 'Making the Argument for Monorepos'\ndescription: 'Trying to convince your colleagues to use a monorepo? Already using a monorepo and need to justify that decision? Check out this webinar to learn 7 essential reasons for using monorepos and bust a few myths and misconceptions along the way.'\ndate: 2024-04-17\nslug: 'making-the-argument-for-monorepos'\nauthors: ['Miroslav Jonaš']\ntags: [webinar]\ncover_image: /blog/images/2024-04-17/april-webinar.png\nstatus: Past - Gated\nregistrationUrl: https://go.nx.dev/april-webinar\n---\n\nPresented by Miroslav Jonaš\n\nTrying to convince your colleagues to use a monorepo? Already using a monorepo and need to justify that decision? Check out this webinar to learn 7 essential reasons for using monorepos and bust a few myths and misconceptions along the way.\n\n{% call-to-action title=\"Download the recording\" url=\"https://go.nx.dev/april-webinar\" description=\"Sign up to gain access\" /%}\n","title":"Making the Argument for Monorepos","description":"Trying to convince your colleagues to use a monorepo? Already using a monorepo and need to justify that decision? Check out this webinar to learn 7 essential reasons for using monorepos and bust a few myths and misconceptions along the way.","authors":["$4c"],"eventDate":"2024-04-17T21:20:25.055Z","date":"2024-04-17T21:20:25.055Z","time":"$undefined","status":"Past - Gated","cover_image":"/documentation/blog/images/2024-04-17/april-webinar.png","tags":["webinar"],"reposts":[],"pinned":false,"ogImage":"documentation/blog/images/2024-04-17/april-webinar.png","ogImageType":"png","filePath":"public/documentation/blog/2024-04-17-making-the-argument-for-monorepos.md","slug":"making-the-argument-for-monorepos","youtubeUrl":"$undefined","registrationUrl":"https://go.nx.dev/april-webinar","podcastYoutubeId":"$undefined","podcastSpotifyId":"$undefined","podcastIHeartUrl":"$undefined","podcastAppleUrl":"$undefined","podcastAmazonUrl":"$undefined","published":true,"metrics":"$undefined"},{"content":"$4d","title":"Reliable CI. A new execution model fixing both flakiness and slowness","description":"Learn how Nx Cloud revolutionizes CI with a task-based execution model that solves both flaky tests and slow pipelines.","authors":["$14"],"eventDate":"2024-03-21T21:20:25.054Z","date":"2024-03-21T21:20:25.054Z","time":"$undefined","status":"$undefined","cover_image":"/documentation/blog/images/2024-03-21/featured_img.png","tags":["nx","nx-cloud","releases"],"reposts
","podcastSpotifyId":"$undefined","podcastIHeartUrl":"$undefined","podcastAppleUrl":"$undefined","podcastAmazonUrl":"$undefined","published":true,"metrics":"$undefined"},{"content":"$5c","title":"State Management Nx React Native/Expo Apps with TanStack Query and Redux","description":"Implementing state management in Nx React Native/Expo apps with TanStack Query and Redux, covering setup, dev tools, and unit testing.","authors":["$5a"],"eventDate":"2023-11-08T21:20:25.036Z","date":"2023-11-08T21:20:25.036Z","time":"$undefined","status":"$undefined","cover_image":"/documentation/blog/images/2023-11-08/featured_img.webp","tags":["nx","React Native"],"reposts":[],"pinned":false,"ogImage":"documentation/blog/images/2023-11-08/featured_img.webp","ogImageType":"webp","filePath":"public/documentation/blog/2023-11-08-state-management.md","slug":"state-management-nx-react-native-expo-apps-with-tanstack-query-and-redux","youtubeUrl":"$undefined","registrationUrl":"$undefined","podcastYoutubeId":"$undefined","podcastSpotifyId":"$undefined","podcastIHeartUrl":"$undefined","podcastAppleUrl":"$undefined","podcastAmazonUrl":"$undefined","published":true,"metrics":"$undefined"},{"content":"$5d","title":"Nx 17 has Landed","description":"Nx 17 released with Vue.js support, Module Federation enhancements, generator path improvements, AI chatbot integration, and more.","authors":["$e","$2b"],"eventDate":"2023-10-20T21:20:25.034Z","date":"2023-10-20T21:20:25.034Z","time":"$undefined","status":"$undefined","cover_image":"/documentation/blog/images/2023-10-20/featured_img.png","tags":["nx","release"],"reposts":[],"pinned":false,"ogImage":"documentation/blog/images/2023-10-20/featured_img.png","ogImageType":"png","filePath":"public/documentation/blog/2023-10-20-nx-17-release.md","slug":"nx-17-release","youtubeUrl":"$undefined","registrationUrl":"$undefined","podcastYoutubeId":"$undefined","podcastSpotifyId":"$undefined","podcastIHeartUrl":"$undefined","podcastAppleUrl":"$undefined","podcast
{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "es2021", "esnext"],
    "tsBuildInfoFile": "./tsconfig.tsbuildinfo",
    "jsx": "preserve",
    "allowJs": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "composite": true,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "skipLibCheck": true,
    "noEmitOnError": false,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "types": ["node", "jest"],
  "include": [
    "**/*.js",
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "public/documentation/**/*.json",
    "../../nx-dev/nx-dev/.next/types/**/*.ts"
  ],
  "references": [
    {
      "path": "../ui-primitives"
    },
    {
      "path": "../ui-common"
    },
    {
      "path": "../feature-ai"
    },
    {
      "path": "../data-access-documents"
    },
    {
      "path": "../data-access-courses"
    },
    {
      "path": "../util-ai"
    },
    {
      "path": "../ui-video-courses"
    },
    {
      "path": "../ui-courses"
    }
  ],
  "exclude": [
    "**/*.spec.ts",
    "**/*.test.ts",
    "**/*.spec.tsx",
    "**/*.test.tsx",
    "jest.config.ts",
    "node_modules",
    "../../node_modules",
    "**/node_modules",
    "../../packages/*/node_modules/**",
    "node_modules/.pnpm/**"
  ]
}

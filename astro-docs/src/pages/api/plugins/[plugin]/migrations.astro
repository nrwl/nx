---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const pluginDocs = await getCollection(
    'plugin-docs',
    (entry) => entry.data.docType === 'migrations'
  );
  
  const nxRefDocs = await getCollection(
    'nx-reference-packages',
    (entry) => entry.data.docType === 'migrations' && ['nx', 'plugin', 'web', 'workspace'].includes(entry.data.packageType)
  );

  // Generate paths for both collections
  const pluginPaths = pluginDocs.map((p) => ({
    params: { plugin: p.data.pluginName },
    props: { doc: p },
  }));
  
  const nxRefPaths = nxRefDocs.map((p) => ({
    params: { plugin: p.data.packageType },
    props: { doc: p },
  }));

  return [...pluginPaths, ...nxRefPaths];
}

const { doc } = Astro.props;
const pluginName = doc.collection === 'nx-reference-packages' 
  ? doc.data.packageType 
  : doc.data.pluginName;

if (!doc.body) {
  throw new Error(`No content found for plugin: ${pluginName}`);
}
const {Content, headings } = await render(doc);
---

<StarlightPage
  frontmatter={{
    title: `@nx/${pluginName} - migrations`,
    description: `@nx/${pluginName} plugin migrations`,
  }}
  headings={headings || []}
>
    <Content />
</StarlightPage>

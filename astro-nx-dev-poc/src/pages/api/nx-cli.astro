---
import { getCollection, render } from 'astro:content';
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';

export async function getStaticPaths() {
  // This will generate a single static path for the CLI reference page
  return [{ params: {} }];
}

const entries = await getCollection('cli-docs');
const entry = entries[0];

const { Content, headings } = await render(entry);
---
<StarlightPage
  frontmatter={{
    title: entry?.data?.title || 'Nx CLI Reference',
    description: 'Complete reference for all Nx CLI commands and their options',

  }}
>
    <Content />
</StarlightPage>

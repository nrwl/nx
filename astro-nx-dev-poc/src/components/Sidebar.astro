---
import Default from '@astrojs/starlight/components/Sidebar.astro';
import { sidebarGroups, getActiveGroup } from '../config/sidebar.config';

const currentPath = Astro.url.pathname;
const activeGroupId = getActiveGroup(currentPath);

// Get sidebar data from Starlight's route context
const { sidebar } = Astro.locals.starlightRoute;

// Build sidebar sections for each group
const groupSections = sidebarGroups.map(group => {
  const groupItems = sidebar?.filter(item => {
    if (item.type === 'group') {
      // Check if this sidebar item belongs to this group
      // by matching labels or checking if any entries match the group's pattern
      return group.items.some(configItem => 
        configItem.label === item.label ||
        (configItem.autogenerate?.directory && item.label?.toLowerCase().includes(configItem.autogenerate.directory))
      );
    }
    return false;
  });
  
  return {
    ...group,
    entries: groupItems || []
  };
});
---

{!sidebar || sidebar.length === 0 ? (
  <Default {...Astro.props} />
) : (

<nav class="sl-sidebar tabbed-sidebar" aria-label="Main">
  <div class="sidebar-tabs" role="tablist">
    {sidebarGroups.map(group => (
      <button 
        class="sidebar-tab"
        data-tab-id={group.id}
        aria-controls={`tabpanel-${group.id}`}
        aria-selected={activeGroupId === group.id ? 'true' : 'false'}
        role="tab"
      >
        {group.icon && <span class="tab-icon">{group.icon}</span>}
        <span class="tab-label">{group.label}</span>
      </button>
    ))}
  </div>
  
  <div class="sidebar-content sl-sidebar-content">
    {groupSections.map(section => (
      <div 
        id={`tabpanel-${section.id}`} 
        class="tab-panel" 
        role="tabpanel" 
        style={activeGroupId === section.id ? '' : 'display: none'}
      >
        {section.entries.length > 0 ? (
          <ul class="top-level">
            {section.entries.map((entry: any) => (
              <li>
                {entry.type === 'group' ? (
                  <details open>
                    <summary>
                      <div class="group-label">
                        <span>{entry.label}</span>
                      </div>
                    </summary>
                    <ul>
                      {entry.entries.map((item: any) => (
                        <li>
                          {item.type === 'link' ? (
                            <a href={item.href} aria-current={item.isCurrent ? 'page' : undefined}>
                              <span>{item.label}</span>
                            </a>
                          ) : item.type === 'group' ? (
                            <details open={!item.collapsed}>
                              <summary>
                                <div class="group-label">
                                  <span>{item.label}</span>
                                </div>
                              </summary>
                              <ul>
                                {item.entries.map((subitem: any) => (
                                  <li>
                                    {subitem.type === 'link' && (
                                      <a href={subitem.href} aria-current={subitem.isCurrent ? 'page' : undefined}>
                                        <span>{subitem.label}</span>
                                      </a>
                                    )}
                                  </li>
                                ))}
                              </ul>
                            </details>
                          ) : null}
                        </li>
                      ))}
                    </ul>
                  </details>
                ) : null}
              </li>
            ))}
          </ul>
        ) : (
          <div class="empty-state">
            <p>No items in this section yet.</p>
          </div>
        )}
      </div>
    ))}
  </div>
</nav>

<script>
  import { sidebarGroups, getActiveGroup } from '../config/sidebar.config';
  
  // Tab switching functionality
  document.addEventListener('DOMContentLoaded', () => {
    const tabs = document.querySelectorAll('.sidebar-tab');
    const panels = document.querySelectorAll('.tab-panel');
    
    function switchTab(tabId: string) {
      tabs.forEach(tab => {
        const isActive = tab.getAttribute('data-tab-id') === tabId;
        tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });
      
      panels.forEach(panel => {
        const isActive = panel.id === `tabpanel-${tabId}`;
        panel.style.display = isActive ? '' : 'none';
      });
      
      localStorage.setItem('activeDocTab', tabId);
    }
    
    // Add click handlers
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const tabId = tab.getAttribute('data-tab-id');
        if (tabId) switchTab(tabId);
      });
    });
    
    // Handle navigation - update active tab based on URL
    function updateActiveTabFromUrl() {
      const currentPath = window.location.pathname;
      const activeGroup = getActiveGroup(currentPath);
      switchTab(activeGroup);
    }
    
    // Update on initial load
    updateActiveTabFromUrl();
    
    // Listen for navigation changes
    window.addEventListener('popstate', updateActiveTabFromUrl);
    
    // For Astro View Transitions (if enabled)
    document.addEventListener('astro:after-swap', updateActiveTabFromUrl);
  });
</script>

<style>
  .tabbed-sidebar {
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .sidebar-tabs {
    display: flex;
    border-bottom: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-bg-sidebar);
    position: sticky;
    top: 0;
    z-index: 10;
    flex-wrap: wrap;
  }

  .sidebar-tab {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    flex: 1;
    min-width: 0;
    background: transparent;
    border: none;
    border-bottom: 3px solid transparent;
    color: var(--sl-color-gray-2);
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .sidebar-tab:hover {
    color: var(--sl-color-text);
    background: var(--sl-color-gray-6);
  }

  .sidebar-tab[aria-selected="true"] {
    color: var(--sl-color-text-accent);
    border-bottom-color: var(--sl-color-text-accent);
  }

  .tab-icon {
    font-size: 1.125rem;
    flex-shrink: 0;
  }

  .tab-label {
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .sidebar-content {
    flex: 1;
    overflow-y: auto;
    padding: 1rem 0;
  }

  /* Match Starlight sidebar styles */
  .top-level {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  details {
    position: relative;
  }

  summary {
    list-style: none;
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    margin-inline-start: -0.5rem;
    border-radius: 0.25rem;
  }

  summary:hover {
    background-color: var(--sl-color-gray-6);
  }

  summary::marker,
  summary::-webkit-details-marker {
    display: none;
  }

  details[open] > summary::before {
    transform: rotate(90deg);
  }

  summary::before {
    content: '▸';
    display: inline-block;
    margin-inline-end: 0.25rem;
    transition: transform 0.2s;
  }

  .group-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    color: var(--sl-color-white);
  }

  ul {
    list-style: none;
    padding-inline-start: 1rem;
    margin: 0;
  }

  a {
    display: block;
    padding: 0.25rem 0.5rem;
    margin-inline-start: -0.5rem;
    color: var(--sl-color-gray-2);
    text-decoration: none;
    border-radius: 0.25rem;
    transition: all 0.2s;
  }

  a:hover {
    background-color: var(--sl-color-gray-6);
    color: var(--sl-color-white);
  }

  a[aria-current="page"] {
    background-color: var(--sl-color-gray-6);
    color: var(--sl-color-white);
    font-weight: 600;
  }

  .empty-state {
    padding: 2rem 1rem;
    text-align: center;
    color: var(--sl-color-gray-3);
  }

  /* Responsive adjustments */
  @media (max-width: 50rem) {
    .sidebar-tabs {
      gap: 0.25rem;
    }
    
    .sidebar-tab {
      padding: 0.5rem 0.75rem;
      font-size: 0.8125rem;
    }
    
    .tab-icon {
      font-size: 1rem;
    }
  }
</style>
)}
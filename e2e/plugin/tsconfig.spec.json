{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "out-tsc/spec",
    "types": ["jest", "node"]
  },
  "exclude": ["out-tsc"],
  "include": [
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.test.tsx",
    "**/*.spec.js",
    "**/*.test.js",
    "**/*.spec.jsx",
    "**/*.test.jsx",
    "src/**/*.ts",
    "**/*.d.ts",
    "jest.config.ts"
  ]
}

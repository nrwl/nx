{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "isolatedModules": true,
    "outDir": "out-tsc/spec",
    "types": ["jest", "node"],
    "rootDir": "."
  },
  "exclude": ["out-tsc"],
  "include": [
    "jest.config.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.ts"
  ]
}

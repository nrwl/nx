{
  "name": "plugin",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/plugin/src",
  "projectType": "library",
  "release": {
    "version": {
      "generator": "@nx/js:release-version",
      "preserveLocalDependencyProtocols": true,
      "manifestRootsToUpdate": ["packages/{projectName}"]
    }
  },
  "targets": {
    "build": {
      "command": "node ./scripts/copy-readme.js plugin packages/plugin/readme-template.md packages/plugin/README.md",
      "inputs": ["copyReadme"],
      "outputs": ["{projectRoot}/README.md"]
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "packages/{projectName}"
      }
    }
  },
  "implicitDependencies": ["vitest"]
}

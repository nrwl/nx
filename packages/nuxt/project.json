{
  "name": "nuxt",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/nuxt",
  "projectType": "library",
  "targets": {
    "build": {
      "outputs": ["{projectRoot}/README.md"],
      "command": "node ./scripts/copy-readme.js nuxt packages/nuxt/readme-template.md packages/nuxt/README.md",
      "inputs": ["copyReadme"]
    }
  },
  "implicitDependencies": ["cypress", "playwright"]
}

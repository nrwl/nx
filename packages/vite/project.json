{
  "name": "vite",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/vite",
  "projectType": "library",
  "release": {
    "version": {
      "generator": "@nx/js:release-version",
      "preserveLocalDependencyProtocols": true,
      "manifestRootsToUpdate": ["packages/{projectName}"]
    }
  },
  "targets": {
    "nx-release-publish": {
      "options": {
        "packageRoot": "packages/{projectName}"
      }
    },
    "build": {
      "outputs": ["{projectRoot}/README.md"],
      "command": "node ./scripts/copy-readme.js vite packages/vite/readme-template.md packages/vite/README.md",
      "inputs": ["copyReadme"]
    }
  },
  "implicitDependencies": ["eslint"]
}

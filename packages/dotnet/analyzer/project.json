{
  "name": "MsbuildAnalyzer",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "targets": {
    "build": {
      "executor": "nx:noop",
      "dependsOn": ["build:dotnet"]
    },
    "run": {
      "executor": "nx:noop"
    },
    "build:dotnet": {
      "inputs": ["...", "{workspaceRoot}/Directory.Build.props"]
    },
    "build:dotnet:release": {
      "inputs": ["...", "{workspaceRoot}/Directory.Build.props"]
    },
    "publish": {
      "inputs": ["...", "{workspaceRoot}/Directory.Build.props"],
      "outputs": ["{projectRoot}/bin/Release/publish", "{projectRoot}/obj"]
    }
  }
}

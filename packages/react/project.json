{
  "name": "react",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/react",
  "projectType": "library",
  "targets": {
    "build": {
      "dependsOn": ["build-base"],
      "command": "node ./scripts/copy-readme.js react packages/react/readme-template.md packages/react/README.md",
      "inputs": ["copyReadme"],
      "outputs": ["{projectRoot}/README.md"]
    },
    "build-base": {
      "dependsOn": [
        {
          "projects": [
            "nx",
            "devkit",
            "workspace",
            "js",
            "cypress",
            "docker",
            "eslint",
            "module-federation",
            "node",
            "playwright",
            "rollup",
            "rsbuild",
            "rspack",
            "storybook",
            "vite",
            "vitest",
            "web",
            "webpack",
            "nest"
          ],
          "target": "build-base"
        },
        "build-native",
        "copy-assets"
      ]
    },
    "nx-release-publish": {
      "dependsOn": []
    }
  },
  "implicitDependencies": ["rspack"]
}

      "types": "./dist/module-federation.d.ts",
      "default": "./dist/module-federation.js"
    },
    "./webpack-plugin": {
      "@nx/nx-source": "./webpack-plugin.ts",
      "types": "./dist/webpack-plugin.d.ts",
      "default": "./dist/webpack-plugin.js"
    },

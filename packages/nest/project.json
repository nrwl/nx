{
  "name": "nest",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/nest",
  "projectType": "library",
  "release": {
    "version": {
      "generator": "@nx/js:release-version",
      "preserveLocalDependencyProtocols": true,
      "manifestRootsToUpdate": ["packages/{projectName}"]
    }
  },
  "targets": {
    "build": {
      "outputs": ["{projectRoot}/README.md"],
      "command": "node ./scripts/copy-readme.js nest packages/nest/readme-template.md packages/nest/README.md",
      "inputs": ["copyReadme"]
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "packages/{projectName}"
      }
    }
  },
  "implicitDependencies": ["node", "eslint", "nx"]
}

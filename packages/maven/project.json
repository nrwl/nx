{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/maven/src",
  "projectType": "library",
  "targets": {
    "nx-release-publish": {
      "dependsOn": ["^nx-release-publish", "nx-maven-plugin:_install"]
    },
    "build": {
      "command": "node ./scripts/copy-readme.js maven packages/maven/readme-template.md packages/maven/README.md",
      "inputs": ["copyReadme"],
      "outputs": ["{projectRoot}/README.md"]
    },
    "copy-assets": {
      "dependsOn": ["maven-batch-runner:_package"]
    }
  },
  "tags": ["maven:dev.nx.maven"],
  "implicitDependencies": ["maven-batch-runner", "nx-maven-plugin"]
}

{
  "name": "@nx/gradle",
  "version": "0.0.1",
  "private": false,
  "type": "commonjs",
  "files": [
    "dist",
    "!dist/tsconfig.tsbuildinfo",
    "!dist/spec",
    "migrations.json",
    "executors.json",
    "generators.json"
  ],
  "description": "The Nx Plugin for Gradle allows Gradle tasks to be run through Nx",
  "repository": {
    "type": "git",
    "url": "https://github.com/nrwl/nx.git",
    "directory": "packages/gradle"
  },
  "keywords": [
    "Monorepo",
    "Java",
    "Gradle",
    "CLI",
    "Backend"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "plugin-v1": [
        "dist/plugin-v1.d.ts"
      ],
      "src/*": [
        "dist/src/*.d.ts"
      ],
      "src/*.js": [
        "dist/src/*.d.ts"
      ]
    }
  },
  "author": "Victor Savkin",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/nrwl/nx/issues"
  },
  "homepage": "https://nx.dev",
  "generators": "./generators.json",
  "exports": {
    ".": {
      "@nx/nx-source": "./index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./plugin-v1": {
      "@nx/nx-source": "./plugin-v1.ts",
      "types": "./dist/plugin-v1.d.ts",
      "default": "./dist/plugin-v1.js"
    },
    "./executors/*/schema.json": "./src/executors/*/schema.json",
    "./executors/*/schema": "./dist/src/executors/*/schema.d.ts",
    "./generators/*/schema.json": "./src/generators/*/schema.json",
    "./generators/*/schema": "./dist/src/generators/*/schema.d.ts",
    "./package.json": "./package.json",
    "./migrations.json": "./migrations.json",
    "./generators.json": "./generators.json",
    "./src/*": {
      "@nx/nx-source": "./src/*.ts",
      "types": "./dist/src/*.d.ts",
      "default": "./dist/src/*.js"
    },
    "./src/*.js": {
      "@nx/nx-source": "./src/*.ts",
      "types": "./dist/src/*.d.ts",
      "default": "./dist/src/*.js"
    }
  },
  "nx-migrations": {
    "migrations": "./migrations.json"
  },
  "dependencies": {
    "@nx/devkit": "workspace:*",
    "toml-eslint-parser": "^0.10.0",
    "tree-kill": "catalog:",
    "tslib": "catalog:typescript"
  },
  "devDependencies": {
    "nx": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "executors": "./executors.json"
}

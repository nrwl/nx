{
  "name": "gradle",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/gradle/src",
  "projectType": "library",
  "targets": {
    "nx-release-publish": {
      "dependsOn": ["^nx-release-publish"],
      "executor": "@nx/js:release-publish",
      "options": {
        "packageRoot": "dist/packages/gradle"
      }
    },
    "build": {
      "outputs": ["{workspaceRoot}/dist/packages/gradle/README.md"],
      "command": "node ./scripts/copy-readme.js gradle",
      "inputs": ["copyReadme"],
      "dependsOn": ["^build", "build-base"]
    },
    "copy-assets": {
      "dependsOn": [":gradle-batch-runner:gradle:assemble"]
    },
    "build-base": {
      "dependsOn": [
        "^build-base",
        "build-native",
        "copy-assets",
        ":gradle-batch-runner:gradle:assemble"
      ]
    }
  },
  "tags": [],
  "implicitDependencies": [":gradle-project-graph", ":gradle-batch-runner"]
}

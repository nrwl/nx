{
  "name": "gradle",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/gradle/src",
  "projectType": "library",
  "release": {
    "version": {
      "generator": "@nx/js:release-version",
      "preserveLocalDependencyProtocols": true,
      "manifestRootsToUpdate": ["packages/{projectName}"]
    }
  },
  "targets": {
    "nx-release-publish": {
      "dependsOn": ["^nx-release-publish"],
      "executor": "@nx/js:release-publish",
      "options": {
        "packageRoot": "packages/{projectName}"
      }
    },
    "build": {
      "outputs": ["{projectRoot}/README.md"],
      "command": "node ./scripts/copy-readme.js gradle packages/gradle/readme-template.md packages/gradle/README.md",
      "inputs": ["copyReadme"],
      "dependsOn": ["^build", "build-base"]
    },
    "copy-assets": {
      "dependsOn": [":gradle-batch-runner:gradle:assemble"]
    },
    "build-base": {
      "dependsOn": [
        "^build-base",
        "build-native",
        "copy-assets",
        ":gradle-batch-runner:gradle:assemble"
      ]
    }
  },
  "tags": [],
  "implicitDependencies": [":gradle-project-graph", ":gradle-batch-runner"]
}

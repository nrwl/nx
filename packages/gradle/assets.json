{
  "outDir": "packages/gradle/dist",
  "assets": [
    { "glob": "**/files/**" },
    { "glob": "src/**/schema.json" },
    { "glob": "src/**/schema.d.ts" },
    { "glob": "src/migrations/**/*.md" },
    {
      "glob": "**/*.jar",

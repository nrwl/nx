{
  "outDir": "dist/packages/gradle",
  "assets": [
    { "glob": "**/files/**" },
    {
      "glob": "**/*.json",
      "ignore": ["tsconfig*.json", "project.json", ".eslintrc.json"]
    },
    { "glob": "**/*.js", "ignore": ["**/jest.config.js"] },
    { "glob": "**/*.d.ts" },
    {
      "glob": "**/*.jar",
      "input": "packages/gradle/batch-runner",
      "output": "/batch-runner",
      "includeIgnoredFiles": true
    },
    "LICENSE"
  ]
}

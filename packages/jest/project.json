{
  "name": "jest",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/jest",
  "projectType": "library",
  "targets": {
    "build": {
      "outputs": ["{projectRoot}/README.md"],
      "command": "node ./scripts/copy-readme.js jest packages/jest/readme-template.md packages/jest/README.md",
      "inputs": ["copyReadme"],
      "dependsOn": ["^build", "build-base"]
    }
  }
}

{
  "name": "rsbuild",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/rsbuild",
  "projectType": "library",
  "targets": {
    "build": {
      "outputs": ["{projectRoot}/README.md"],
      "command": "node ./scripts/copy-readme.js rsbuild packages/rsbuild/readme-template.md packages/rsbuild/README.md",
      "inputs": ["copyReadme"]
    }
  }
}

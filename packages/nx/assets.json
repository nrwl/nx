{
  "outDir": "packages/nx/dist",
  "assets": [
    { "glob": "**/files/**" },
    { "glob": "**/files/**/.gitkeep" },
    {
      "glob": "**/*.json",
      "ignore": [
        "**/tsconfig*.json",
        "**/project.json",
        "**/__fixtures__/**",
        ".eslintrc.json",
        "executors.json",
        "generators.json",
        "migrations.json",
        "package.json"
      ]
    },
    {
      "glob": "**/*.{mjs,cjs,js,css,html,svg,wasm,node}",
      "ignore": ["**/jest.config.js"]
    }
  ]
}

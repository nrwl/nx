<% if (e2ePreset) { -%>
import { nxE2EPreset } from '@nx/cypress/plugins/cypress-preset';
<% } -%>
import { defineConfig } from 'cypress';
<% if (!e2ePreset) { %>
<% } -%>
export default defineConfig({<% if (e2ePreset) { %>
  e2e: {
    ...nxE2EPreset(import.meta.url, <%- presetOptions %>),<% if (baseUrl) { %>
    baseUrl: '<%- baseUrl %>',<% } %>
  },
<% } %>});

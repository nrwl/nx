<% if (e2ePreset) { -%>
const { nxE2EPreset } = require('@nx/cypress/plugins/cypress-preset');
<% } -%>
const { defineConfig } = require('cypress');
<% if (!e2ePreset) { %>
<% } -%>
module.exports = defineConfig({<% if (e2ePreset) { %>
  e2e: {
    ...nxE2EPreset(__filename, <%- presetOptions %>),<% if (baseUrl) { %>
    baseUrl: '<%- baseUrl %>',<% } %>
  },
<% } %>});

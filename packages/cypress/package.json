{
  "name": "@nx/cypress",
  "version": "0.0.1",
  "private": false,
  "description": "The Nx Plugin for Cypress contains executors and generators allowing your workspace to use the powerful Cypress integration testing capabilities.",
  "repository": {
    "type": "git",
    "url": "https://github.com/nrwl/nx.git",
    "directory": "packages/cypress"
  },
  "keywords": [
    "Monorepo",
    "Angular",
    "React",
    "Web",
    "Node",
    "Nest",
    "Jest",
    "Cypress",
    "CLI",
    "Front-end",
    "Testing"
  ],
  "main": "./index.js",
  "type": "commonjs",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./package.json": "./package.json",
    "./package": "./package.json",
    "./generators.json": "./generators.json",
    "./executors.json": "./executors.json",
    "./migrations.json": "./migrations.json",
    "./generators": "./generators.json",
    "./executors": "./executors.json",
    "./migrations": "./migrations.json",
    "./plugin": {
      "types": "./plugin.d.ts",
      "default": "./plugin.js"
    },
    "./plugin.js": {
      "types": "./plugin.d.ts",
      "default": "./plugin.js"
    },
    "./plugins/*": {
      "types": "./plugins/*.d.ts",
      "default": "./plugins/*.js"
    },
    "./plugins/*.js": {
      "types": "./plugins/*.d.ts",
      "default": "./plugins/*.js"
    },
    "./src/*/schema.json": "./src/*/schema.json",
    "./src/*": {
      "types": "./src/*.d.ts",
      "default": "./src/*.js"
    },
    "./src/*.js": {
      "types": "./src/*.d.ts",
      "default": "./src/*.js"
    }
  },
  "author": "Victor Savkin",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/nrwl/nx/issues"
  },
  "homepage": "https://nx.dev",
  "generators": "./generators.json",
  "executors": "./executors.json",
  "ng-update": {
    "requirements": {},
    "migrations": "./migrations.json"
  },
  "dependencies": {
    "@nx/devkit": "workspace:*",
    "@nx/eslint": "workspace:*",
    "@nx/js": "workspace:*",
    "@phenomnomnominal/tsquery": "catalog:typescript",
    "detect-port": "^2.1.0",
    "semver": "catalog:",
    "tree-kill": "catalog:",
    "tslib": "catalog:typescript"
  },
  "devDependencies": {
    "nx": "workspace:*"
  },
  "peerDependencies": {
    "cypress": ">= 13 < 16"
  },
  "peerDependenciesMeta": {
    "cypress": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}

{
  "name": "js",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/js/src",
  "projectType": "library",
  "release": {
    "version": {
      "generator": "@nx/js:release-version",
      "preserveLocalDependencyProtocols": true,
      "manifestRootsToUpdate": ["packages/{projectName}"]
    }
  },
  "targets": {
    "nx-release-publish": {
      "options": {
        "packageRoot": "packages/{projectName}"
      }
    },
    "build-base": {
      "dependsOn": [
        { "projects": ["nx", "devkit", "workspace"], "target": "build-base" },
        "build-native",
        "copy-assets"
      ]
    },
    "build": {
      "dependsOn": ["build-base"],
      "outputs": ["{projectRoot}/README.md"],
      "command": "node ./scripts/copy-readme.js js packages/js/readme-template.md packages/js/README.md",
      "inputs": ["copyReadme"]
    }
  },
  "implicitDependencies": [
    "eslint",
    "jest",
    "rollup",
    "vite",
    "vitest",
    "esbuild"
  ],
  "tags": []
}

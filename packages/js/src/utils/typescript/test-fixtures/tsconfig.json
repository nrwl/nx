{
  "compilerOptions": {
    "target": "es5",
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "incremental": false,
    "module": "esnext",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "noUncheckedSideEffectImports": false,
    "types": ["*"],
    "esModuleInterop": false
  }
}

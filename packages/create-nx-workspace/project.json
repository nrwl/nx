{
  "name": "create-nx-workspace",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/create-nx-workspace",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/dist/bin/create-nx-workspace.js",
        "{projectRoot}/README.md"
      ],
      "options": {
        "commands": [
          {
            "command": "node ./scripts/chmod packages/create-nx-workspace/dist/bin/create-nx-workspace.js"
          },
          {
            "command": "node ./scripts/copy-readme.js create-nx-workspace packages/create-nx-workspace/readme-template.md packages/create-nx-workspace/README.md"
          },
          {
            "command": "node ./scripts/replace-versions.js packages/create-nx-workspace/dist/bin/create-nx-workspace.js"
          }
        ],
        "parallel": false
      },
      "inputs": [
        "copyReadme",
        {
          "dependentTasksOutputFiles": "**/bin/create-nx-workspace.js"
        },
        "{workspaceRoot}/scripts/replace-versions.js",
        "{workspaceRoot}/scripts/chmod.js"
      ]
    }
  },
  "implicitDependencies": [
    "workspace",
    "js",
    "react",
    "expo",
    "next",
    "angular",
    "nest",
    "express",
    "vue"
  ]
}

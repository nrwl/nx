{
  "name": "react-native",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/react-native/src",
  "projectType": "library",
  "release": {
    "version": {
      "generator": "@nx/js:release-version",
      "preserveLocalDependencyProtocols": true,
      "manifestRootsToUpdate": ["packages/{projectName}"]
    }
  },
  "targets": {
    "build": {
      "command": "node ./scripts/copy-readme.js react-native packages/react-native/readme-template.md packages/react-native/README.md",
      "inputs": ["copyReadme"],
      "outputs": ["{projectRoot}/README.md"]
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "packages/{projectName}"
      }
    }
  },
  "implicitDependencies": ["jest", "vite", "webpack"]
}

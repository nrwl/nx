{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "outDir": "../../dist/packages/workspace",
    "types": ["node"],
    "tsBuildInfoFile": "../../dist/packages/workspace/tsconfig.tsbuildinfo"
  },
  "exclude": ["**/*.spec.ts", "**/*.test.ts", "jest.config.ts"],
  "include": ["**/*.ts", "*.json"],

{
  "name": "@nx/workspace",
  "version": "0.0.1",
  "private": false,
  "description": "The Workspace plugin contains executors and generators that are useful for any Nx workspace. It should be present in every Nx workspace and other plugins build on it.",
  "repository": {
    "type": "git",
    "url": "https://github.com/nrwl/nx.git",
    "directory": "packages/workspace"
  },
  "keywords": [
    "Monorepo",
    "Angular",
    "React",
    "Web",
    "Node",
    "Nest",
    "Jest",
    "Cypress",
    "CLI"
  ],
  "main": "./index.js",
  "type": "commonjs",
  "types": "./index.d.ts",
  "author": "Victor Savkin",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/nrwl/nx/issues"
  },
  "homepage": "https://nx.dev",
  "generators": "./generators.json",
  "executors": "./executors.json",
  "ng-update": {
    "requirements": {},
    "migrations": "./migrations.json",
    "packageGroup": {
      "nx-cloud": "latest",
      "nx": "*"
    }
  },
  "dependencies": {
    "@nx/devkit": "workspace:*",
    "@zkochan/js-yaml": "catalog:",
    "chalk": "catalog:",
    "enquirer": "catalog:",
    "picomatch": "catalog:",
    "semver": "catalog:",
    "tslib": "catalog:typescript",
    "yargs-parser": "catalog:"
  },
  "devDependencies": {
    "nx": "workspace:*"
  },
  "peerDependencies": {
    "@nx/angular": "workspace:*",
    "@nx/eslint": "workspace:*",
    "@nx/expo": "workspace:*",
    "@nx/express": "workspace:*",
    "@nx/jest": "workspace:*",
    "@nx/js": "workspace:*",
    "@nx/nest": "workspace:*",
    "@nx/next": "workspace:*",
    "@nx/node": "workspace:*",
    "@nx/nuxt": "workspace:*",
    "@nx/react": "workspace:*",
    "@nx/react-native": "workspace:*",
    "@nx/vue": "workspace:*",
    "@nx/web": "workspace:*",
    "typescript": "catalog:typescript"
  },
  "peerDependenciesMeta": {
    "@nx/angular": {
      "optional": true
    },
    "@nx/eslint": {
      "optional": true
    },
    "@nx/expo": {
      "optional": true
    },
    "@nx/express": {
      "optional": true
    },
    "@nx/jest": {
      "optional": true
    },
    "@nx/js": {
      "optional": true
    },
    "@nx/nest": {
      "optional": true
    },
    "@nx/next": {
      "optional": true
    },
    "@nx/node": {
      "optional": true
    },
    "@nx/nuxt": {
      "optional": true
    },
    "@nx/react": {
      "optional": true
    },
    "@nx/react-native": {
      "optional": true
    },
    "@nx/vue": {
      "optional": true
    },
    "@nx/web": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}

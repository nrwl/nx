{
  "name": "examples-angular-rspack-mf-host",
  "version": "0.0.1",
  "private": true,
  "scripts": {},
  "dependencies": {
    "@angular/common": "~22.0.0",
    "@angular/core": "~22.0.0",
    "@angular/platform-browser": "~22.0.0",
    "@angular/router": "~22.0.0",
    "rxjs": "^7.8.0",
    "zone.js": "~0.16.2"
  },
  "devDependencies": {
    "@nx/angular-rspack": "link:../../../../packages/angular-rspack",
    "@nx/module-federation": "link:../../../../packages/module-federation",
    "@rspack/core": "^2.0.4",
    "@rspack/cli": "^2.0.4",
    "typescript": "~6.0.3"
  },
  "nx": {
    "targets": {
      "serve": {
        "dependsOn": [
          "^build"
        ]
      },
      "build": {
        "inputs": [
          "production",
          "^production",
          {
            "dependentTasksOutputFiles": "**/*.js",
            "transitive": true
          },
          "{workspaceRoot}/tsconfig.base.json",
          "{workspaceRoot}/tsconfig.json"
        ],
        "outputs": [
          "{projectRoot}/dist"
        ],
        "dependsOn": [
          "^build"
        ]
      }
    }
  }
}

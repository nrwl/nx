{
  "name": "examples-angular-rspack-csr-tailwind",
  "version": "0.0.1",
  "private": true,
  "scripts": {},
  "dependencies": {
    "@nx/angular-rspack": "workspace:*",
    "@tailwindcss/postcss": "catalog:tailwind"
  },
  "devDependencies": {
    "@rspack/core": "catalog:rspack",
    "@rspack/cli": "catalog:rspack"
  },
  "nx": {
    "targets": {
      "build": {
        "inputs": [
          "production",
          "^production",
          {
            "dependentTasksOutputFiles": "**/*.js",
            "transitive": true
          },
          "{workspaceRoot}/examples/angular-rspack/tsconfig.base.json",
          "{workspaceRoot}/LICENSE",
          "{workspaceRoot}/tsconfig.json"
        ],
        "outputs": [
          "{projectRoot}/dist"
        ],
        "dependsOn": [
          "^build"
        ]
      }
    }
  }
}

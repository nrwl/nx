{
  "name": "examples-angular-rspack-csr-i18n",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "postinstall": "cd ../../.. && pnpm nx run-many -t build -p nx angular-rspack rspack",
    "validate": "nx run-many -t build"
  },
  "dependencies": {
    "@angular/common": "~22.0.0",
    "@angular/core": "~22.0.0",
    "@angular/platform-browser": "~22.0.0",
    "@angular/router": "~22.0.0",
    "@angular/localize": "~22.0.0",
    "rxjs": "^7.8.0",
    "zone.js": "~0.16.2"
  },
  "devDependencies": {
    "@nx/angular-rspack": "link:../../../packages/angular-rspack",
    "@nx/rspack": "link:../../../packages/rspack",
    "@rspack/core": "^2.0.4",
    "@rspack/cli": "^2.0.4",
    "typescript": "~6.0.3",
    "nx": "link:../../../packages/nx"
  },
  "nx": {
    "i18n": {
      "sourceLocale": "en-GB",
      "locales": {
        "fr": {
          "translation": "src/locale/messages.fr.xlf"
        },
        "es": {
          "translation": "src/locale/messages.es.xlf",
          "subPath": "es-ES"
        }
      }
    },
    "includedScripts": []
  }
}

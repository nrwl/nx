{
  "name": "examples-angular-rspack-zoneless-csr-css",
  "version": "0.0.1",
  "private": true,
  "scripts": {},
  "dependencies": {
    "@nx/angular-rspack": "workspace:*"
  },
  "devDependencies": {
    "@rspack/core": "catalog:rspack",
    "@rspack/cli": "catalog:rspack"
  },
  "nx": {
    "targets": {
      "serve-api": {
        "continuous": true,
        "command": "node ./src/api.mjs",
        "options": {
          "cwd": "examples/angular-rspack/zoneless-csr-css"
        }
      },
      "serve": {
        "dependsOn": [
          "^build",
          "serve-api"
        ]
      },
      "build": {
        "inputs": [
          "production",
          "^production",
          {
            "dependentTasksOutputFiles": "**/*.js",
            "transitive": true
          },
          "{workspaceRoot}/examples/angular-rspack/patch-devkit-request-path.js",
          "{workspaceRoot}/examples/angular-rspack/tsconfig.base.json",
          "{workspaceRoot}/LICENSE",
          "{workspaceRoot}/tsconfig.json",
          "{workspaceRoot}/examples/angular-rspack/shared/**/*"
        ],
        "outputs": [
          "{projectRoot}/dist"
        ],
        "dependsOn": [
          "^build"
        ]
      }
    }
  }
}

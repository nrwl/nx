{
  "name": "benchmarks",
  "version": "0.0.0",
  "private": true,
  "dependencies": {
    "nx": "workspace:*"
  },
  "scripts": {
    "bench": "tsx run-benchmarks.ts",
    "bench:version": "hyperfine --show-output --warmup 1 --min-runs 10 --export-json results-version.json 'nx --version'",
    "bench:show-projects": "hyperfine --show-output --warmup 1 --min-runs 5 --export-json results-show-projects.json 'nx show projects --tui=false'",
    "bench:lint-warm": "hyperfine --show-output --warmup 1 --min-runs 5 --export-json results-lint-warm.json 'nx run-many -t lint --tui=false'",
    "disabled:bench:build-warm": "hyperfine --show-output --warmup 1 --min-runs 5 --export-json results-build-warm.json 'nx run-many -t build --tui=false'"
  },
  "nx": {
    "targets": {
      "bench": {
        "dependsOn": [
          "bench:*"
        ]
      },
      "bench:version": {
        "dependsOn": [
          "^build"
        ],
        "parallelism": false
      },
      "bench:show-projects": {
        "dependsOn": [
          "^build"
        ],
        "parallelism": false
      },
      "bench:lint-warm": {
        "dependsOn": [
          "^build"
        ],
        "parallelism": false
      },
      "disabled:bench:build-warm": {
        "dependsOn": [
          "^build"
        ],
        "parallelism": false
      }
    }
  }
}
